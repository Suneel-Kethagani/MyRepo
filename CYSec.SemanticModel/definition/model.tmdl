/// Contains all Custom Dimension Tables which are loaded typically once from static sources
queryGroup 'Custom Dimension Tables'

	annotation PBI_QueryGroupOrder = 2

queryGroup Rimes

	annotation PBI_QueryGroupOrder = 3

queryGroup Dealgen

	annotation PBI_QueryGroupOrder = 4

queryGroup 'Incremental Refresh Config Tables'

	annotation PBI_QueryGroupOrder = 5

annotation PBI_QueryOrder = ["Fx Rate","Company","Accounting Unit","Framework","Reporting Currency","Portfolios","Securities_old","Securities Transaction GA Fact","Securities Position Fact","Securities Sublot Fact","Securities Lots Fact","Transaction History Slicer","Impairment Slicer","Book Values","Indonesian FX Rate(Old)","Index Constituent","Securities Changes","Private Deal Schedule Funding  Fact","Private Deal Dim","Private Deal Commitment Fact","Private Security Dim","Entities","Portfolios Attributes","Index Attributes","Securities","Period","Fx Rate DQ","Securities Lookthrough Position Fact","Securities Transaction Costs GA Fact","Total Market Value GA Fact","Indonesian FX Rate","Maximis CTA Holdings Fact","Securities Tax Lot Deferred Pl Fact","Securities Elim Lot Fact","Securities JVE Fact","Security Ratings Periods Fact","Country Dim","Securities Elim Transaction PL Tax Lot Fact","Cat Staging Text Fact","CAT Adjmt Config Table","Adjust GL Reclass Fact","Last N Days Position Data","Securities Transaction AOCI GA Fact","Securities Elim Transaction PL Tax Lot AOCI Fact","Securities_Lots_Fact_PBI_Config","Securities_Position_Fact_PBI_Config","Securities_Transaction_Fact_PBI_Config","Asset_Dim_PBI_Config","RangeStart","RangeEnd","Securities GL Txn fact - Elim","Portfolios-Bank Accounts","pCutOffDate","Accounting Framework Philosophy","HostName","HTTPPath","Catalog","DirectQuery to AS - PBI Data Dictionary","Consolidated GL Balance Fact"]

