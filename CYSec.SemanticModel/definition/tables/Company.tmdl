table Company
	lineageTag: ece73412-8b0a-489f-9eca-a8ef396b321e

	/// Count of Companies as a metric
	measure #Company = ```
			
			DISTINCTCOUNT ( Company[Company] )
			
			```
		formatString: #,0
		lineageTag: 0864d847-dba9-45f9-9641-65d987688433

	measure 'Framework Exists' =
			
			SWITCH (
			    SELECTEDVALUE ( Framework[Framework] ),
			    "IAS39", COUNT ( 'Company'[IAS39 Ind] ),
			    "NAIC", COUNT ( 'Company'[NAIC Ind] ),
			    "JGAAP", COUNT ( 'Company'[JGAAP Ind] ),
			    "USGAAP", COUNT ( 'Company'[USGAAP Ind] ),
			    "IFRS9", COUNT ( 'Company'[IFRS Ind] ),
			    "USTAX", COUNT ( 'Company'[USTAX Ind] )
			)
			-- To check if the selected framework from Menu page exists for corresponding portfolio
		formatString: 0
		lineageTag: a4e27ed8-4b29-46e8-a89e-63947de95221

	column Company
		dataType: string
		isKey
		lineageTag: 55446d15-a1a2-459c-be22-ebbad122c194
		summarizeBy: none
		sourceColumn: Company

		annotation SummarizationSetBy = Automatic

