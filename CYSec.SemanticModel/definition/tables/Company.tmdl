	column 'Company Code & Name Display' =
			
			IF (
			    Company[Company Code & Name]
			        IN { "Not Applicable - Not Applicable", "Not Available - Not Available" },
			    "9999 - Off Balance Sheet Company",
			    Company[Company Code & Name]
			)
		lineageTag: e70641ba-9606-4249-888f-c396462fec84
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

