	measure 'Percentage Difference' = ```
			
			DIVIDE(
			    SUM('Securities Lots Fact'[Fair Value Unaccrued - Local])-SUM('Securities Lots Fact'[Book Value - Local]),
			    SUM('Securities Lots Fact'[Book Value - Local]),0)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c3a8e05b-da0c-4323-91e2-db4a4d8ab087

		changedProperty = FormatString

	measure 'Decline Category' =
			
			SWITCH(
			    TRUE(),
			    [Percentage Difference]>0,"Gain",
			    AND([Percentage Difference]<0,[Percentage Difference]>=-0.1),"0%-10%",
			    AND([Percentage Difference]<-0.1,[Percentage Difference]>=-0.2),"11%-20%",
			    AND([Percentage Difference]<-0.2,[Percentage Difference]>=-0.3),"21%-30%",
			    AND([Percentage Difference]<-0.3,[Percentage Difference]>=-0.4),"31%-40%",
			    AND([Percentage Difference]<-0.4,[Percentage Difference]>=-0.5),"41%-50%",
			    AND([Percentage Difference]<-0.5,[Percentage Difference]>=-0.6),"51%-60%",
			    AND([Percentage Difference]<-0.6,[Percentage Difference]>=-0.7),"61%-70%",
			    AND([Percentage Difference]<-0.7,[Percentage Difference]>=-0.8),"71%-80%",
			    AND([Percentage Difference]<-0.8,[Percentage Difference]>=-0.9),"81%-90%",
			    "100%")
		lineageTag: 339a41dc-edb8-4498-9c4d-9d64381431d2

