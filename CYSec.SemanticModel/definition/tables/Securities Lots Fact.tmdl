	measure 'Maturity Days (Sec Lots)' = ```
			
			var mat = 
			CALCULATE (
			    FIRSTNONBLANK ( 'Securities'[Maturity Days (D)], TRUE () ),
			    CROSSFILTER ( 'Securities Lots Fact'[Security NK], 'Securities'[Security NK], BOTH )
			)
			var calc = 
			IF (
			    mat < 0,
			    mat * -1,
			    mat
			)
			return calc
			
