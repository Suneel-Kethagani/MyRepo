	measure 'ECL/CECL Impairment - Rep (Sec Lots)' = ```
			
			VAR FW =
			    SELECTEDVALUE ( Framework[Framework] )
			VAR IFRS9_FW = 'Securities Lots Fact'[Balance CL Allowance - Rep (Sec Lots)] + 'Securities Lots Fact'[Balance Write Off - Rep (Sec Lots)]
			VAR USGAAP_FW = 'Securities Lots Fact'[Balance Recog CL Allowance - Rep (Sec Lots)] + 'Securities Lots Fact'[Balance Write Off - Rep (Sec Lots)]
			VAR IAS39_JGAAP_NAIC_FW = 'Securities Lots Fact'[OTTI Impairment - Rep (Sec Lots)] + 'Securities Lots Fact'[Balance Write Off - Rep (Sec Lots)]
			RETURN
			    SWITCH(
			        TRUE(),
			        FW = "IFRS9",IFRS9_FW,
			        FW = "USGAAP",USGAAP_FW,
			        FW = "IAS39"|| FW = "JGAAP"|| FW = "NAIC" ,IAS39_JGAAP_NAIC_FW,
			        BLANK ()
			    )
			
