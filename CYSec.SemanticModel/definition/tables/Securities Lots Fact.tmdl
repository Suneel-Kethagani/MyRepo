	measure 'AOCI Remain Balance Non BV - Rep (Sec Lots)' = ```
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Lots Fact'[AOCI Remain Balance Non BV - Base]),
			    CALCULATE(
			        SUM('Securities Lots Fact'[AOCI Remain Balance Non BV - Base]),
			        LASTDATE('Securities Lots Fact'[As Of Date])
			    )
			),
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX (
			        'Securities Lots Fact',
			        'Securities Lots Fact'[AOCI Remain Balance Non BV - Local] * 'Fx Rate DQ'[Rep Rate]
			    ),
			    CALCULATE(
			        SUMX (
			            'Securities Lots Fact',
			            'Securities Lots Fact'[AOCI Remain Balance Non BV - Local] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        LASTDATE('Securities Lots Fact'[As Of Date])
			    )
			))
			/*IF (
				SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
				SUM ( 'Securities Lots Fact'[AOCI Remain Balance Non BV - Base] ),
			    IF (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "USD",
			        SUM ( 'Securities Lots Fact'[AOCI Remain Balance Non BV - USD] ),
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "CAD",
			            SUM ( 'Securities Lots Fact'[AOCI Remain Balance Non BV - CAD] ),
						IF (
							SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "Company",
							SUM ( 'Securities Lots Fact'[AOCI Remain Balance Non BV - FUNC] ),
							SUM ( 'Securities Lots Fact'[AOCI Remain Balance Non BV - HKD] )
							)
						)
					)
				)*/
			
			
			
			```
		lineageTag: e2d4c1ee-ab36-4ddd-b2f1-a932dbd9217e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AOCI Remain Balance Rep - Rep (Sec Lots)' = ```
			
			SWITCH(
