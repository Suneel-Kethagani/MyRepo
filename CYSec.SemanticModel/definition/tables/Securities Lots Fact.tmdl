	measure 'Fair Value Unaccrued - Rep (LH)' = ```
			
			VAR Prd =
			    MAX ( Period[Period] )
			RETURN
			    CALCULATE (
			        IF (
				SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
				SUM ( 'Securities Lots Fact'[Fair Value Unaccrued - Base] ),
			    IF (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "USD",
			        SUMX ('Securities Lots Fact','Securities Lots Fact'[Fair Value Unaccrued - Local]*RELATED('Fx Rate DQ'[USD BS Rate])),
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "CAD",
			            SUMX ('Securities Lots Fact','Securities Lots Fact'[Fair Value Unaccrued - Local]*RELATED('Fx Rate DQ'[CAD BS Rate])),
						IF (
							SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "Company",
							SUMX ('Securities Lots Fact','Securities Lots Fact'[Fair Value Unaccrued - Local]*RELATED('Fx Rate DQ'[FUNC BS Rate])),
							SUMX ('Securities Lots Fact','Securities Lots Fact'[Fair Value Unaccrued - Local]*RELATED('Fx Rate DQ'[HKD BS Rate]))
							)
						)
					)
				),
			        ALL(Period),
			        'Securities Lots Fact'[As Of Period] <= Prd
			        
			    )
			
			```
		isHidden
		displayFolder: Lots Research Attributes
		lineageTag: e71a6c4b-89cb-42d1-b2ac-275b977b53d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

