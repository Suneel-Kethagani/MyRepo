					)
				)
			
			VAR USGAAP_FW =
			    IF (
				SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
				SUM ( 'Securities Lots Fact'[Balance Recog CL Allowance - Base] ),
			    IF (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "USD",
			        SUM ( 'Securities Lots Fact'[Balance Recog CL Allowance - USD] ),
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "CAD",
			            SUM ( 'Securities Lots Fact'[Balance Recog CL Allowance - CAD] ),
						IF (
							SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "Company",
							SUM ( 'Securities Lots Fact'[Balance Recog CL Allowance - FUNC] ),
							SUM ( 'Securities Lots Fact'[Balance Recog CL Allowance - HKD] )
							)
						)
					)
				)
			
			
			VAR IAS39_JGAAP_NAIC_FW =
			    IF (
				SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
				SUM ( 'Securities Lots Fact'[Balance Impairment - Base] ),
			    IF (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "USD",
			        SUM ( 'Securities Lots Fact'[Balance Impairment - USD] ),
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "CAD",
			            SUM ( 'Securities Lots Fact'[Balance Impairment - CAD] ),
						IF (
							SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "Company",
							SUM ( 'Securities Lots Fact'[Balance Impairment - FUNC] ),
							SUM ( 'Securities Lots Fact'[Balance Impairment - HKD] )
							)
						)
					)
				)
			
			
			RETURN
			    IF (
			        FW = "IFRS9",
			        IFRS9_FW,
			        IF (
			            FW = "USGAAP",
			            USGAAP_FW,
			        IF(
			            (FW="IAS39" || FW= "JGAAP" || FW= "NAIC"),
			            IAS39_JGAAP_NAIC_FW,
			            BLANK()
			        )
			        )
			    )*/
			
