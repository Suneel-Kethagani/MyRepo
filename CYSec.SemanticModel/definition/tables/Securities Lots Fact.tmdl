			RELATED(Securities[SCD Security Type]) = "PRV CORPBD" && 'Securities Lots Fact'[GL_BUCKET] = BLANK() && 'Securities Lots Fact'[Primary Security ID (Sec Lots)] <> "50221#AA2", "D1",
			RELATED(Securities[SCD Security Type]) = "PRV CORPBD" && 'Securities Lots Fact'[GL_BUCKET] = "LT" && 'Securities Lots Fact'[Primary Security ID (Sec Lots)] <> "50221#AA2", "D1",
			RELATED(Securities[SCD Security Type]) = "PRV CORPBD" && 'Securities Lots Fact'[GL_BUCKET] = "NONE" && 'Securities Lots Fact'[Primary Security ID (Sec Lots)] <> "50221#AA2", "D1",
			RELATED(Securities[SCD Security Type]) = "PRV CORPBD" && 'Securities Lots Fact'[GL_BUCKET] = "CCE" && 'Securities Lots Fact'[Primary Security ID (Sec Lots)] <> "50221#AA2", "D1",
			RELATED(Securities[SCD Security Type]) = "PRV CORPBD" && 'Securities Lots Fact'[GL_BUCKET] = "ST" && 'Securities Lots Fact'[Primary Security ID (Sec Lots)] <> "50221#AA2", "DA1",
			'Securities Lots Fact'[Primary Security ID (Sec Lots)] = "50221#AA2", "B",
			RELATED(Securities[SCD Security Type]) = "REVOLVER" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "D1",
			RELATED(Securities[SCD Security Type]) = "REVOLVER" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "D1",
			RELATED(Securities[SCD Security Type]) = "REVOLVER" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "D1",
			RELATED(Securities[SCD Security Type]) = "REVOLVER" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "D1",
			RELATED(Securities[SCD Security Type]) = "REVOLVER" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			RELATED(Securities[SCD Security Type]) = "TERM LOAN" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "D1",
			RELATED(Securities[SCD Security Type]) = "TERM LOAN" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "D1",
			RELATED(Securities[SCD Security Type]) = "TERM LOAN" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "D1",
			RELATED(Securities[SCD Security Type]) = "TERM LOAN" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "D1",
			RELATED(Securities[SCD Security Type]) = "TERM LOAN" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			RELATED(Securities[SCD Security Type]) = "PRV CONVBD" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "D1",
			RELATED(Securities[SCD Security Type]) = "PRV CONVBD" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "D1",
			RELATED(Securities[SCD Security Type]) = "PRV CONVBD" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "D1",
			RELATED(Securities[SCD Security Type]) = "PRV CONVBD" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "D1",
			RELATED(Securities[SCD Security Type]) = "PRV CONVBD" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			RELATED(Securities[SCD Security Type]) = "PRIV DEBT" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "D1",
			RELATED(Securities[SCD Security Type]) = "PRIV DEBT" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "D1",
			RELATED(Securities[SCD Security Type]) = "PRIV DEBT" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "D1",
			RELATED(Securities[SCD Security Type]) = "PRIV DEBT" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "D1",
			RELATED(Securities[SCD Security Type]) = "PRIV DEBT" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			
			//New additional condition after prod testing by Kevin on 7/6 : Start
			//RELATED(Securities[SCD Security Type]) = "CP" && 'Securities Lots Fact'[GL_BUCKET] = "CCE" && RELATED(Securities[ML NAIC Report Part Cd]) = "1" , "E2",
			
			--RELATED(Securities[SCD Security Type]) = "PRV CONVBD" && 'Securities Lots Fact'[GL_BUCKET] = "LT" && RELATED(Securities[ML NAIC Report Part Cd]) = BLANK() , "D1",
			--RELATED(Securities[SCD Security Type]) = "PRV CONVBD" && 'Securities Lots Fact'[GL_BUCKET] = "NONE" && RELATED(Securities[ML NAIC Report Part Cd]) = BLANK() , "D1",
			
			RELATED(Securities[SCD Security Type]) = "PRIVSTK", "D2.2",
			//New additional condition after prod testing by Kevin on 7/6 : End
			BLANK())
