	column 'Blue Book Code' = ```
			SWITCH(TRUE(), 
			
			RELATED(Securities[ML NAIC Report Part Cd]) = "BA" && 'Securities Lots Fact'[Primary Security ID (Sec Lots)] <> "40479@AA4" && 'Securities Lots Fact'[Primary Security ID (Sec Lots)] <> "40479*AA6" && 'Securities Lots Fact'[Primary Security ID (Sec Lots)] <> "40479*AB4", "BA",
			'Securities Lots Fact'[Primary Security ID (Sec Lots)] = "40479@AA4", "D1",
			'Securities Lots Fact'[Primary Security ID (Sec Lots)] = "40479*AA6", "D1",
			'Securities Lots Fact'[Primary Security ID (Sec Lots)] = "40479*AB4", "D1",
			
			//Exception List
			RELATED(Securities[SCD Security ID]) = "BBG000BBV9N3", "D1",
			RELATED(Securities[SCD Security ID]) = "BBG000PWXXY5", "D1",
			RELATED(Securities[SCD Security ID]) = "BBG000PWYVH7", "D1",
			RELATED(Securities[SCD Security ID]) = "BBG000PWZHX9", "D1",
			
			//Wash Sale Exceptions for the above securities
			
			RELATED(Securities[SCD Security ID]) = "WS1000259", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000393", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000624", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000625", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000627", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000648", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000651", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000652", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000653", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000656", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000657", "D1",
			RELATED(Securities[SCD Security ID]) = "WS1000691", "D1",
			
			RELATED(Securities[SCD Security ID]) = "50254692", "D2.2",
			RELATED(Securities[SCD Security ID]) = "50254693", "D2.2",
			RELATED(Securities[SCD Security ID]) = "50254212", "D2.2",
			RELATED(Securities[SCD Security ID]) = "50256903", "D2.2",
			RELATED(Securities[SCD Security ID]) = "BBG000006KY0", "D1",
			RELATED(Securities[SCD Security ID]) = "609990031", "BA",
			RELATED(Securities[SCD Security ID]) = "50185510", "BA",
			
			RELATED(Securities[SCD Security Type]) = "COVWARRANT", "D2.2",
			RELATED(Securities[SCD Security Type]) = "INV_IN_SUB", "D2.2",
			RELATED(Securities[SCD Security Type]) = "ADR", "D2.2",
			RELATED(Securities[SCD Security Type]) = "COMMON EQ", "D2.2",
			RELATED(Securities[SCD Security Type]) = "REIT", "D2.2",
			RELATED(Securities[SCD Security Type]) = "GDR", "D2.2",
			RELATED(Securities[SCD Security Type]) = "LP", "D2.2",
			RELATED(Securities[SCD Security Type]) = "RIGHT", "D2.2",
			RELATED(Securities[SCD Security Type]) = "ETF", "D2.2",
			RELATED(Securities[SCD Security Type]) = "OTH FUND", "D2.2",
			RELATED(Securities[SCD Security Type]) = "SEG FUND", "D2.2",
			RELATED(Securities[SCD Security Type]) = "WS_EQUITY", "D2.2",
			RELATED(Securities[SCD Security Type]) = "WS_PRDEBT", "D1",
			RELATED(Securities[SCD Security Type]) = "INC TRUST", "D2.2",
			RELATED(Securities[SCD Security Type]) = "REPO", "DA1",
			RELATED(Securities[SCD Security Type]) = "REV REPO", "DA1",
			RELATED(Securities[SCD Security Type]) = "RED PFD EQ", "D2.1",
			RELATED(Securities[SCD Security Type]) = "PRV WARRNT", "D2.2",
			RELATED(Securities[SCD Security Type]) = "PFD EQ", "D2.1",
			RELATED(Securities[SCD Security Type]) = "RMBS", "D1",
			RELATED(Securities[SCD Security Type]) = "LOAN CMO", "D1",
			RELATED(Securities[SCD Security Type]) = "LILO", "D1",
			RELATED(Securities[SCD Security Type]) = "CNV PFD EQ", "D2.1",
			RELATED(Securities[SCD Security Type]) = "ABS", "D1",
			RELATED(Securities[SCD Security Type]) = "CDO", "D1",
			RELATED(Securities[SCD Security Type]) = "CMBS", "D1",
			RELATED(Securities[SCD Security Type]) = "CMO", "D1",
			RELATED(Securities[SCD Security Type]) = "OIA BOND", "BA",
			RELATED(Securities[SCD Security Type]) = "OIA EA", "BA",
			RELATED(Securities[SCD Security Type]) = "OIA PFD", "BA",
			RELATED(Securities[SCD Security Type]) = "OIA STK", "BA",
			RELATED(Securities[SCD Security Type]) = "PRV REIT", "BA",
			RELATED(Securities[SCD Security Type]) = "FED AG BD", "D1",
			RELATED(Securities[SCD Security Type]) = "FED IDX BD", "D1",
			RELATED(Securities[SCD Security Type]) = "MUNI BD", "D1",
			RELATED(Securities[SCD Security Type]) = "PROV AG BD", "D1",
			RELATED(Securities[SCD Security Type]) = "WS_BOND", "D1",
			RELATED(Securities[SCD Security Type]) = "MUT FUND", "D2.2",
			RELATED(Securities[SCD Security Type]) = "PRV CNVPFD", "D2.1",
			RELATED(Securities[SCD Security Type]) = "PRV PFD EQ", "D2.1",
			RELATED(Securities[SCD Security Type]) = "PRIV EQ", "D2.2",
			
			RELATED(Securities[SCD Security Type]) = "LET CREDIT", "D1",
			RELATED(Securities[SCD Security Type]) = "LIN CREDIT", "D1",
			RELATED(Securities[SCD Security Type]) = "LOAN_LOC", "D1",
			
			RELATED(Securities[SCD Security Type]) = "PRV RED PF", "D2.1",
			RELATED(Securities[SCD Security Type]) = "WS_PRRDPFS", "D2.1",
			
			RELATED(Securities[SCD Security Type]) = "WS_PRPFEQT", "D2.1",
			RELATED(Securities[SCD Security Type]) = "WS_PREQT", "D2.2",
			RELATED(Securities[SCD Security Type]) = "WS_RDPFST", "D2.2",
			RELATED(Securities[SCD Security Type]) = "CRP IDX BD", "D1",
			
			RELATED(Securities[SCD Security Type]) = "CONV BD", "D2.2",
			RELATED(Securities[SCD Security Type]) = "WS_CONVBD", "D1",
			RELATED(Securities[SCD Security Type]) = "FED AG MBS", "D1",
			
			--STFIXINC & CEFIXINC
			RELATED(Securities[SCD Security Type]) = "CORP BD" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "E2",
			RELATED(Securities[SCD Security Type]) = "CORP BD" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			RELATED(Securities[SCD Security Type]) = "CORP BD" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "D1",
			RELATED(Securities[SCD Security Type]) = "CORP BD" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "D1", 
			RELATED(Securities[SCD Security Type]) = "CORP BD" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "D1", 
			RELATED(Securities[SCD Security Type]) = "FED BD" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "E2",
			RELATED(Securities[SCD Security Type]) = "FED BD" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			RELATED(Securities[SCD Security Type]) = "FED BD" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "D1",
			RELATED(Securities[SCD Security Type]) = "FED BD" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "D1",
			RELATED(Securities[SCD Security Type]) = "FED BD" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "D1",
			RELATED(Securities[SCD Security Type]) = "PROV BD" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			RELATED(Securities[SCD Security Type]) = "PROV BD" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "D1",
			RELATED(Securities[SCD Security Type]) = "PROV BD" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "D1",
			RELATED(Securities[SCD Security Type]) = "PROV BD" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "D1",
			RELATED(Securities[SCD Security Type]) = "PROV BD" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "D1",
			
			--MM
			RELATED(Securities[SCD Security Type]) = "FED TBILL" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "DA1",
			RELATED(Securities[SCD Security Type]) = "FED TBILL" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			RELATED(Securities[SCD Security Type]) = "FED TBILL" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "E2",
			RELATED(Securities[SCD Security Type]) = "FED TBILL" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "DA1",
			RELATED(Securities[SCD Security Type]) = "FED TBILL" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "DA1",
			RELATED(Securities[SCD Security Type]) = "PROV TBILL" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "DA1",
			RELATED(Securities[SCD Security Type]) = "PROV TBILL" && 'Securities Lots Fact'[GL_BUCKET] = "ST", "DA1",
			RELATED(Securities[SCD Security Type]) = "PROV TBILL" && 'Securities Lots Fact'[GL_BUCKET] = "CCE", "E2",
			RELATED(Securities[SCD Security Type]) = "PROV TBILL" && 'Securities Lots Fact'[GL_BUCKET] = "NONE", "DA1",
			RELATED(Securities[SCD Security Type]) = "PROV TBILL" && 'Securities Lots Fact'[GL_BUCKET] = "LT", "DA1",
			RELATED(Securities[SCD Security Type]) = "CP" && 'Securities Lots Fact'[GL_BUCKET] = BLANK(), "DA1",
