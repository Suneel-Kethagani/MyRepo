	column 'Public/Private Ind' = ```
			
			var secType = RELATED('Securities'[Asset Type])
			return Switch (True(),
			secType in {"PRV CNVPFD",
			"PRV PFD EQ",
			"PRV REIT",
			"Private Equity"}, "Private",
			NOT(secType  IN {"PRV CNVPFD",
			"PRV PFD EQ",
			"PRV REIT",
			"Private Equity"}), "Public", "All")
			
			```
		lineageTag: d20a1874-e968-428b-ad12-f69753f91375
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Process Flag' = "N"
		lineageTag: 1da6d61e-bdff-4fc8-a639-4ff59ecc03ff
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'SCD Impairment Tran Code' =
			
			IF(SELECTEDVALUE('Impairment Slicer'[Values])="Credit Recovery","ImpPartRevTaxLot","ImpStrtTaxLot")
		lineageTag: 2a5476e8-4e24-4b93-a6de-3f3378c192da
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column '# of quarters in loss position' =
			
			SWITCH(
			TRUE(),
			'Securities Lots Fact'[Num of Days in Lost Position]<=91,"1",
			'Securities Lots Fact'[Num of Days in Lost Position]<=182,"2",
			'Securities Lots Fact'[Num of Days in Lost Position]<=273,"3",
			'Securities Lots Fact'[Num of Days in Lost Position]<=365,"4",
			'Securities Lots Fact'[Num of Days in Lost Position]<=456,"5",
			'Securities Lots Fact'[Num of Days in Lost Position]<=547,"6",
			'Securities Lots Fact'[Num of Days in Lost Position]<=638,"7",
			'Securities Lots Fact'[Num of Days in Lost Position]<=730,"8",
			'Securities Lots Fact'[Num of Days in Lost Position]<=821,"9",
			"10+")
		lineageTag: 720d2b26-1ea9-44f8-8b2d-8ead9f8eef1c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column '# of months in loss position' =
			
			SWITCH(TRUE(),
			'Securities Lots Fact'[Num of Days in Lost Position]<=91,"0 to 3 Months",
			'Securities Lots Fact'[Num of Days in Lost Position]<=182,"3 to 6 Months",
			'Securities Lots Fact'[Num of Days in Lost Position]<=273,"6 to 9 Months",
			'Securities Lots Fact'[Num of Days in Lost Position]<=365,"9 to 12 Months",
			'Securities Lots Fact'[Num of Days in Lost Position]<=730,"12 to 24 Months",
			"24 Months+"
			)
		lineageTag: 9d339d3f-a20b-4121-8a8d-aaa5f81168ae
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Original Drop %' =
			
			var calc =100 - ('Securities Lots Fact'[Fair Value Unaccrued - Local]/'Securities Lots Fact'[Original Cost - Local] )
			return
			if('Securities Lots Fact'[Original Cost - Local] = 0,BLANK(),calc)
		lineageTag: 456e31a7-826e-4248-b0b6-c8b53cf27f41
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Current Drop %' =
			
			var calc =100 - ('Securities Lots Fact'[Fair Value Unaccrued - Local]/'Securities Lots Fact'[Book Value - Base] )
			return
			if('Securities Lots Fact'[Book Value - Base] = 0,BLANK(),calc)
