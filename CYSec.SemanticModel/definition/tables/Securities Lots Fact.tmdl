	measure 'Adjusted GL Class (Sec Lots)' = ```
			
			VAR vMaxPeriodDate = MAX(Period[Date])
			VAR vLotId = VALUES('Securities Lots Fact'[Transaction No])
			VAR vAddRankFlagTable = 
			CALCULATETABLE(
			    ADDCOLUMNS(
			        'Adjust GL Reclass Fact',
			        "@Rank",RANKX('Adjust GL Reclass Fact','Adjust GL Reclass Fact'[Txn Dt])
			    ),
			    REMOVEFILTERS(period),
			    'Adjust GL Reclass Fact'[Txn Dt]<=vMaxPeriodDate,
			    TREATAS(vLotId,'Adjust GL Reclass Fact'[Scd Lot Id])
			)
			
			RETURN
			IF(COUNTROWS('Securities Lots Fact')>0, 
			MAXX(
			    vAddRankFlagTable, IF ([@Rank]=1 , 'Adjust GL Reclass Fact'[gl classification] )
			)
			)
			```
		lineageTag: 82beb634-439a-460e-b66b-c001610c0cc5

	measure 'Balance NAIC Carrying Value - Rep (Sec Lots)' =
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Lots Fact'[Balance NAIC Carrying Value Base]),
			    CALCULATE(
			        SUM('Securities Lots Fact'[Balance NAIC Carrying Value Base]),
			        LASTDATE('Securities Lots Fact'[As Of Date])
			    )
			),
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX (
			        'Securities Lots Fact',
			        'Securities Lots Fact'[Balance NAIC Carrying Value Local] * 'Fx Rate DQ'[Rep Rate]
			    ),
			    CALCULATE(
			        SUMX (
			            'Securities Lots Fact',
			            'Securities Lots Fact'[Balance NAIC Carrying Value Local] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        LASTDATE('Securities Lots Fact'[As Of Date])
			    )
			))
