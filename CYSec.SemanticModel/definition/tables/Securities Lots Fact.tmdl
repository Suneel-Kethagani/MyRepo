	measure 'FV Final - Rep (Sec Lots)' = ```
			
			VAR vIFRS9Purpose = SUMMARIZE('Securities Lots Fact',Securities[Primary Security ID],'Securities Lots Fact'[IFRS9 Purpose])
			VAR vIFRS9Chk = ADDCOLUMNS(vIFRS9Purpose,"@IFRS9_Chk",IF('Securities Lots Fact'[IFRS9 Purpose] IN {"FVTPL","FVOCI"},1))
			VAR vIFRS9Max = ADDCOLUMNS(vIFRS9Chk,"@IFRS9_Max",CALCULATE(MAXX(vIFRS9Chk,[@IFRS9_Chk]),REMOVEFILTERS('Securities Lots Fact'[IFRS9 Purpose])))
			
			VAR vIAS39Purpose = SUMMARIZE('Securities Lots Fact',Securities[Primary Security ID],'Securities Lots Fact'[Purpose])
			VAR vIAS39Chk = ADDCOLUMNS(vIAS39Purpose,"@IAS39_Chk",IF('Securities Lots Fact'[Purpose] IN {"FVTPL","FVOCI","AFS"},1))
			VAR vIAS9Max = ADDCOLUMNS(vIAS39Chk,"@IAS39_Max",CALCULATE(MAXX(vIAS39Chk,[@IAS39_Chk]),REMOVEFILTERS('Securities Lots Fact'[Purpose])))
			
			VAR vResult =
			SWITCH(
			    SELECTEDVALUE (Framework[Framework]),    
			    "IFRS9",    
			    SUMX(
			        SUMMARIZE('Securities Lots Fact',[IFRS9 Purpose]),
			        IF([IFRS9 Purpose] IN {"FVTPL","FVOCI"},'Securities Lots Fact'[Carrying Value - Rep (Sec Lots)],[Fair Value Unaccrued - Rep (Sec Lots)]
			        )
			    )+SUMX(SUMMARIZE(vIFRS9Max,Securities[Primary Security ID],[@IFRS9_Max]),IF([@IFRS9_Max]=1,[Carrying Value - Adjustment Rep (Sec Lots)])),
			    "IAS39",
			    SUMX(
			        SUMMARIZE('Securities Lots Fact',[Purpose]),
			        IF([Purpose] IN {"FVTPL","FVOCI","AFS"},'Securities Lots Fact'[Carrying Value - Rep (Sec Lots)],[Fair Value Unaccrued - Rep (Sec Lots)]        
			        )
			    )+SUMX(SUMMARIZE(vIAS9Max,Securities[Primary Security ID],[@IAS39_Max]),IF([@IAS39_Max]=1,[Carrying Value - Adjustment Rep (Sec Lots)]))
			    ,[Fair Value Unaccrued - Rep (Sec Lots)]
			)
			
			RETURN vResult
			
			```
		lineageTag: 2e820803-171a-4ee1-86cd-b7b62de94c83

		annotation PBI_FormatHint = {"isGeneralNumber":true}

