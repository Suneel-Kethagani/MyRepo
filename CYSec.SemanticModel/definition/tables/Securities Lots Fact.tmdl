	measure 'Security Lots Title' = ```
			
			VAR maxdate =
			    MAX ( 'Securities Lots Fact'[As Of Date] )
			RETURN
			    "Security Lots" & ", "
			        & SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) & ", "
			        & SELECTEDVALUE ( Framework[Framework Display] ) & ", "
			        & FORMAT ( maxdate, "dd-mmm-yy" )
			
			```
		lineageTag: 5234d812-33b3-4dbf-a32c-6d1373c8bf25

	measure 'Rep Rate (Security Lots)' = ```
			
			VAR maxd =
			    MAX ( 'Period'[Period] )
			VAR fxrate =
			    SWITCH (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			        "USD",
			            CALCULATE (
			                MIN ( 'Securities Lots Fact'[Local To USD Rate] ),
			                FILTER (
			                    'Securities Lots Fact',
			                    'Securities Lots Fact'[As Of Period] = maxd
			                )
			            ),
			        "CAD",
			            CALCULATE (
			                MIN ( 'Securities Lots Fact'[Local To CAD Rate] ),
			                FILTER (
			                    'Securities Lots Fact',
			                    'Securities Lots Fact'[As Of Period] = maxd
			                )
			            ),
			        "HKD",
			            CALCULATE (
			                MIN ( 'Securities Lots Fact'[Local To HKD Rate] ),
			                FILTER (
			                    'Securities Lots Fact',
			                    'Securities Lots Fact'[As Of Period] = maxd
			                )
			            ),
			        "Company",
			            CALCULATE (
			                MIN ( 'Securities Lots Fact'[Local To FUNC Rate] ),
			                FILTER (
			                    'Securities Lots Fact',
			                    'Securities Lots Fact'[As Of Period] = maxd
			                )
			            )
			        ,"SCD Base",
			            CALCULATE (
			                MIN ( 'Securities Lots Fact'[Local Exchange Rate] ),
			                FILTER (
			                    'Securities Lots Fact',
			                    'Securities Lots Fact'[As Of Period] = maxd
			                )
			            )
			    )
			RETURN
			    fxrate
			
			```
		formatString: 0.000000
		lineageTag: b427a513-aca3-483c-811f-6badb56b7e0e

	measure 'Reporting Currency (Security Lots)' = ```
			
			VAR SelectedCurrency =
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			VAR ReportingCurrency =
			    IF (
			        NOT ISEMPTY ( 'Securities Lots Fact' ),
			        IF (
			            SelectedCurrency = "Company",
			            FIRSTNONBLANK ( 'Securities Lots Fact'[Functional Ccy Code], TRUE () ),
			            IF (
			                SelectedCurrency = "SCD Base",
			                FIRSTNONBLANK ( 'Securities Lots Fact'[Base Currency Code], TRUE () ),
			                SelectedCurrency
			            )
			        )
			    )
			RETURN
			    ReportingCurrency
			
			```
		lineageTag: 68e410f4-f0e1-438a-9379-be700e4cb4a2

	measure 'Original Cost - Rep (Sec Lots)' =
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Lots Fact'[Original Cost - Base]),
			    CALCULATE (
			        SUM('Securities Lots Fact'[Original Cost - Base]),
			        LASTDATE ( 'Securities Lots Fact'[As Of Date] )
			    )
			),
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX (
			        'Securities Lots Fact',
			        'Securities Lots Fact'[Original Cost - Local] * 'Fx Rate DQ'[Rep Rate]
			    ),
			    CALCULATE(
			        SUMX (
			            'Securities Lots Fact',
			            'Securities Lots Fact'[Original Cost - Local] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        LASTDATE ( 'Securities Lots Fact'[As Of Date] )
			    )
			))
			/*IF (
				SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
				SUM ( 'Securities Lots Fact'[Original Cost - Base] ),
			    IF (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "USD",
			        SUM ( 'Securities Lots Fact'[Original Cost - USD] ),
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "CAD",
			            SUM ( 'Securities Lots Fact'[Original Cost - CAD] ),
						IF (
							SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "Company",
							SUM ( 'Securities Lots Fact'[Original Cost - FUNC] ),
							SUM ( 'Securities Lots Fact'[Original Cost - HKD] )
							)
						)
					)
				)
			*/
		lineageTag: 6a5d6d10-c85d-4cff-8fad-361eb7ec092f

