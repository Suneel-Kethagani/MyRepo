			        IF (
			            FW = "IAS39",
			            SELECTEDVALUE ( Portfolios[IAS39 Trading Philosophy Code (D)] ),
			            IF (
			                FW = "USGAAP",
			                SELECTEDVALUE ( Portfolios[USGAAP Trading Philosophy Code (D)] ),
			                IF (
			                    FW = "JGAAP",
			                    SELECTEDVALUE ( Portfolios[JGAAP Trading Philosophy Code (D)] ),
			                    IF (
			                        FW = "IFRS9",
			                        
			                        SELECTEDVALUE ( Portfolios[IFRS Trading Philosophy Code (D)] ),
			                        --(FW= "USTAX" || FW= "NAIC"),
			                        IF (
			                            NOT (
			                                ISEMPTY ( 'Securities Lots Fact' )
			                            ),
			                            "AFS"
			                        )
			                    )
			                )
			            )
			        ),
			        FILTER (
			            'Securities Lots Fact',
			            'Securities Lots Fact'[As Of Date]
			                = MAX ( 'Securities Lots Fact'[As Of Date] )
			        )
			    )
