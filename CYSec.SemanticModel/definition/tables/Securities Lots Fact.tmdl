	measure 'Final Staging text' = ```
			
			VAR vCreditimpairmentStage = MAX('Securities Lots Fact'[Credit Impairment Stage])
			RETURN
			IF(
			    ISINSCOPE(Securities[Primary Security ID & Desc]),
			    VAR vCATStagingText =
			    MAXX(
			        'Securities Lots Fact',
			        VAR vAssetID = 'Securities Lots Fact'[SCD Security ID]
			        VAR vFramework='Securities Lots Fact'[Framework Code]
			        VAR vPeriod='Securities Lots Fact'[As Of Period]
			        VAR vLatestDate = 
			        CALCULATE(
			            MAX('Cat Staging Text Fact'[Txn Dt]),
			            'Cat Staging Text Fact'[Asset Id]=vAssetID,
			            'Cat Staging Text Fact'[Framework Cd]=vFramework,
			            'Cat Staging Text Fact'[Txn Period]<=vPeriod
			        )
			        RETURN
			        
			        CALCULATE(
			            MAX('Cat Staging Text Fact'[Staging Txt]),
			            'Cat Staging Text Fact'[Asset Id]=vAssetID,
			            'Cat Staging Text Fact'[Framework Cd]=vFramework,
			            'Cat Staging Text Fact'[Txn Dt]=vLatestDate
			        )
			    )
			    RETURN
			    COALESCE(vCATStagingText,vCreditimpairmentStage)
			)
			
			```
		lineageTag: c0bfaec5-3393-43d1-8ba3-f5a65f919904

