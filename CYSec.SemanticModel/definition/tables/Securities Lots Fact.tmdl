		lineageTag: 60aa0544-7bf8-4dbe-9705-9c9a495a08df

	measure 'Activity Filter' = ```
			
			var activitytype = SELECTEDVALUE('Impairment Slicer'[Values])
			return
			SWITCH(
			    TRUE(),
			    AND(activitytype = "Private Equity OTTI Impairment",SELECTEDVALUE('Securities Lots Fact'[Public/Private Ind]) = [Activity Slicer]), 1, 
			    AND(activitytype = "Public Equity OTTI Impairment",AND(SELECTEDVALUE('Securities Lots Fact'[Public/Private Ind]) = [Activity Slicer],[Activity Slicer]<>"Fixed Income")), 1, 
			     AND(FIND("Credit",activitytype,1,0) = 1,SELECTEDVALUE('Securities Lots Fact'[Asset Class (Sec Lots)]) = [Activity Slicer]),1,0)
			```
		formatString: 0
		lineageTag: 136ccee4-c1a6-4042-b3ed-0e5130fc5bcd

	measure 'Impairment Amount QC' = ```
			
			VAR curr = 
			SELECTEDVALUE('Securities Lots Fact'[Local])
			VAR activity =
			    SELECTEDVALUE ( 'Impairment Slicer'[Values] )
			VAR target =
			    SWITCH(TRUE(),
			    NOT curr IN {"KRW","VND","JPY","IDR"},
			        SELECTEDVALUE(  'Securities Lots Fact'[Nominal] ) * (1-SELECTEDVALUE ( 'Target Loss'[Loss Percent] )/100),
			        ROUND(SELECTEDVALUE(  'Securities Lots Fact'[Nominal] ) * (1-SELECTEDVALUE ( 'Target Loss'[Loss Percent] )/100),0))
			
			VAR BV =
			    SUM ( 'Securities Lots Fact'[Book Value - Base] )
			VAR calc =
			    IF (
			        activity = "Credit Impairment",
			        BV - target,
			        IF (
			            activity = "Credit Recovery",
			            target - BV,
			            SELECTEDVALUE( 'Securities Lots Fact'[Fair Value Unaccrued - Local] ) - BV
			        )
			    )
			RETURN
			    calc
			```
		formatString: #,0.00
		lineageTag: c9cea669-ad5d-4234-85c2-7da195b8d16b

