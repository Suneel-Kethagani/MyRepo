	measure 'Impairment Amount Local' = ```
			
			var selact = SELECTEDVALUE('Impairment Slicer'[Values])
			var losspct= SELECTEDVALUE('Target Loss'[Loss Percent])
			RETURN
			SWITCH(
			TRUE(),
			selact="Equity OTTI Impairment",
			SUMX (
			    'Securities Lots Fact',
			    'Securities Lots Fact'[Fair Value Unaccrued - Local] - 'Securities Lots Fact'[Original Cost - Local]
			),
			selact="Credit Impairment",
			SUMX (
			    'Securities Lots Fact',
			    'Securities Lots Fact'[Book Value - Base]-'Securities Lots Fact'[Nominal]*(losspct)  
			),
			
			SUMX (
			    'Securities Lots Fact',
			     -'Securities Lots Fact'[Book Value - Base]+'Securities Lots Fact'[Nominal]*(losspct)  
			)
			)
			
			
			```
