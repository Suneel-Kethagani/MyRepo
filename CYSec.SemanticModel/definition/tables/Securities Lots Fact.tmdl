	measure 'Activity Slicer' = ```
			
			var activityType= SELECTEDVALUE('Impairment Slicer'[Values])
			var sectype = SELECTEDVALUE('Securities Lots Fact'[Asset Class (Sec Lots)])
			var ret = 
			SWITCH(TRUE(),  activityType = "Private Equity OTTI Impairment",  "Private",
			AND(activityType = "Public Equity OTTI Impairment" ,NOT(sectype="Fixed Income")),"Public",
			"Fixed Income"
			)
			return ret
