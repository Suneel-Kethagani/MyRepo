			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX (
			        'Securities Lots Fact',
			        'Securities Lots Fact'[Adjusted Book Value Local] * 'Fx Rate DQ'[Rep Rate]
			    ),
			    CALCULATE (
			        SUMX (
			            'Securities Lots Fact',
