			            + SUM ( 'Securities Lots Fact'[Balance Write Off - Local] ),
			        LASTDATE('Securities Lots Fact'[As Of Date])
			    )),
			"USGAAP",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Lots Fact'[Balance Recog CL Allowance - Local] )
			            + SUM ( 'Securities Lots Fact'[Balance Write Off - Local] ),
			    CALCULATE (
