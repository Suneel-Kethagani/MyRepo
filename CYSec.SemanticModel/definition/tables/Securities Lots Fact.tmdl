	measure 'Balance Deferred PL - Rep (Sec Lots)' =
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Lots Fact'[Balance Deferred PL - Base]),
			    CALCULATE (
			        SUM('Securities Lots Fact'[Balance Deferred PL - Base]),
			        LASTDATE ( 'Securities Lots Fact'[As Of Date] )
			    )
