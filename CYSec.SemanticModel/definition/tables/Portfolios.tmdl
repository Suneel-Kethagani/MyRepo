table Portfolios
	lineageTag: a980d11d-2492-4e95-aebd-411c948adaba

	/// The folder contains the Portfolio Changes Report attributes
	measure 'Portfolio Changes Title' = ```
			
			VAR _min =
			    EDATE ( MIN ( 'Period'[End of Month] ), -0 )
			VAR MIN_PRD =
			    VALUE ( YEAR ( _min ) & FORMAT ( MONTH ( _min ), "00" ) )
			VAR MAX_PRD =
			    MAX ( Period[Period] )
			VAR startDate =
			    CALCULATE (
			        MIN ( Portfolios[As of Date (D)] ),
			        Portfolios[As of Period] = MIN_PRD
			    )
			VAR endDate =
			    CALCULATE (
			        MAX ( Portfolios[As of Date (D)] ),
			        Portfolios[As of Period] = MAX_PRD
			    )
			var st = date(year(startDate),month(startDate),1)
			RETURN
			    "Portfolio Changes, " & FORMAT ( if(isblank(startDate),startDate,st), "dd-mmm-yy" ) & " - "
			        & FORMAT ( endDate, "dd-mmm-yy" )
			
			```
		displayFolder: Portfolio Changes Report Attributes
		lineageTag: b15a9441-9e4f-4813-8bb2-6b27dc1755dd

