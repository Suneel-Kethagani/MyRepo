	/// The folder contains the Portfolio Changes Report attributes
	measure 'Portfolio Change Master' = ```
			
			VAR maxDateRange =
			    MAX ( Period[Period] )
			VAR priorDateRange =
			    CALCULATE (
			        FIRSTNONBLANK ( Period[Period], TRUE () ),
			        FILTER (
			            ALL ( Period ),
			            Period[End of Month]
			                = (
			                    CALCULATE (
			                        FIRSTNONBLANK ( Period[Start of Month], TRUE () ),
			                        FILTER ( ALL ( Period ), Period[Period] = MIN ( Period[Period] ) )
			                    ) - 1
			                )
			        )
			    )
			VAR minport =
			    CALCULATE (
			        COUNTROWS ( Portfolios ),
			             FILTER ( Portfolios, Portfolios[Start Date Period] = priorDateRange)
			    )
			VAR maxport =
			    CALCULATE (
			        COUNTROWS ( Portfolios ),
			       FILTER ( Portfolios, Portfolios[Start Date Period] = maxDateRange )
			    )
			VAR minport1 =
			    CALCULATE (
			        COUNTROWS ( Portfolios ),
			         FILTER ( Portfolios, Portfolios[Termination Period] = priorDateRange)
			    )
			VAR maxport1 =
			    CALCULATE (
			        COUNTROWS ( Portfolios ),
			        FILTER ( Portfolios, Portfolios[Termination Period] = maxDateRange)
			    )
			VAR minman =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Portfolio Manager Name (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxman =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Portfolio Manager Name (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minopc =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Operating Ccy Code], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxopc =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Operating Ccy Code], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minbcur =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Base Ccy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxbcur =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Base Ccy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minsfnd =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Subfund ID (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxsfnd =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Subfund ID (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minIFRS =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[IFRS Trading Philosophy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxIFRS =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[IFRS Trading Philosophy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minUSGAAP =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[USGAAP Trading Philosophy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxUSGAAP =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[USGAAP Trading Philosophy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minIAS39 =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[IAS39 Trading Philosophy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxIAS39 =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[IAS39 Trading Philosophy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minJGAAP =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[JGAAP Trading Philosophy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxJGAAP =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[JGAAP Trading Philosophy Code (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minWorkArea =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Work Area (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxWorkArea =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Work Area (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minName =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Portfolio Name], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxName =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Portfolio Name], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			RETURN
			    IF (
			        AND ( OR ( minport1 = 0, ISBLANK ( minport1 ) ), maxport1 > 0 ),
			        "Removed",//"New",
			        --If port has no prior ref then New
			        IF (  AND ( OR ( minport = 0, ISBLANK ( minport ) ), maxport > 0 ),
			            //AND ( minport1 > 0, OR ( maxport1 = 0, ISBLANK ( maxport1 ) ) ),
			             "New",//"Removed",
			            -- else if prior port is absent in latest date, then removed
			            IF (
			                COALESCE ( minman, "" ) <> COALESCE ( maxman, "" ),
			                "Changed",
			                -- else if manager changes then 
			                IF (
			                    COALESCE ( minopc, "" ) <> COALESCE ( maxopc, "" ),
			                    "Changed",
			                    --else if OPC changed then "OPC"
			                    IF (
			                        COALESCE ( minbcur, "" ) <> COALESCE ( maxbcur, "" ),
			                        "Changed",
			                        IF (
			                            COALESCE ( minsfnd, "" ) <> COALESCE ( maxsfnd, "" ),
			                            "Changed",
			                            IF (
			                                COALESCE ( minName, "" ) <> COALESCE ( maxName, "" ),
			                                "Changed",
			                                IF (
			                                    COALESCE ( minIFRS, "" ) <> COALESCE ( maxIFRS, "" ),
			                                    "Changed",
			                                    IF (
			                                        COALESCE ( minUSGAAP, "" ) <> COALESCE ( maxUSGAAP, "" ),
			                                        "Changed",
			                                        IF (
			                                            COALESCE ( minIAS39, "" ) <> COALESCE ( maxIAS39, "" ),
			                                            "Changed",
			                                            IF (
			                                                COALESCE ( minJGAAP, "" ) <> COALESCE ( maxJGAAP, "" ),
			                                                "Changed",
			                                                IF (
			                                                    COALESCE ( minWorkArea, "" ) = COALESCE ( maxWorkArea, "" ),
			                                                    BLANK (),
			                                                    "Changed"
			                                                )
			                                            )
			                                        )
			                                    )
			                                )
			                            )
			                        )
			                    )
			                )
			            )
			        )
			    )
			
			```
		formatString: 0
		displayFolder: Portfolio Changes Report Attributes
		lineageTag: 41ac794f-5392-4693-ad53-69f28f8e3b38

	/// The folder contains the Portfolio Changes Report attributes
	measure 'New Port Legal ID' = ```
			
			VAR MDS =
			    MAX ( Period[Period] )
			RETURN
			    IF (
			        [Portfolio Change Master] = "New",
			        CALCULATE (
			            FIRSTNONBLANK ( Portfolios[Lawson Legal ID (D)], TRUE () ),
			            FILTER ( Portfolios, Portfolios[As of Period] = mds )
			        ),
			        BLANK ()
			    )
			
			```
		formatString: 0
		displayFolder: Portfolio Changes Report Attributes
		lineageTag: 7c4660d9-1075-4d2d-a1b6-11c3f36f524b

	/// The folder contains the Portfolio Changes Report attributes
	measure 'Port Manager Changes' =
			
			VAR maxDateRange =
			    MAX ( Period[Period] )
			VAR priorDateRange =
			    CALCULATE (
			        FIRSTNONBLANK ( Period[Period], TRUE () ),
			        FILTER (
			            ALL ( Period ),
			            Period[End of Month]
			                = (
			                    CALCULATE (
			                        FIRSTNONBLANK ( Period[Start of Month], TRUE () ),
			                        FILTER ( ALL ( Period ), Period[Period] = MIN ( Period[Period] ) )
			                    ) - 1
			                )
			        )
			    )
			VAR minport =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Portfolio Manager Name (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = priorDateRange )
			    )
			VAR maxport =
			    CALCULATE (
			        FIRSTNONBLANK ( Portfolios[Portfolio Manager Name (D)], TRUE () ),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDateRange )
			    )
			VAR minsec =
			    CALCULATE (
			        COUNTROWS ( 'Portfolios' ),
			        FILTER (
			            'Portfolios',
			            'Portfolios'[As Of Period] = priorDateRange
			        )
			    )
			VAR maxsec =
			    CALCULATE (
			        COUNTROWS ( 'Portfolios' ),
			        FILTER (
			            'Portfolios',
			            'Portfolios'[As Of Period] = maxDateRange
			        )
			    )
			RETURN
			    IF (
			        minsec > 0
			            && maxsec > 0
			            && minport <> maxport,
			        CONCATENATE ( minport, CONCATENATE ( " -> ", maxport ) ),
			        IF (
			            AND ( ISBLANK ( minport ), NOT ( ISBLANK ( maxport ) ) ),
			            maxport,
			            BLANK ()
			        )
			    )
		displayFolder: Portfolio Changes Report Attributes
		lineageTag: 98a17d4e-c356-4b4d-83b8-f0b4959812fb

