	measure 'Portfolio List Title' =
			
			VAR MAX_DT =
			    MAX ( 'Period'[Period] )
			VAR endDate =
			    CALCULATE (
			        MAX ( Portfolios[As of Date (D)] ),
			        Portfolios[As of Period] = MAX_DT
			    )
			RETURN
			    "Portfolios" & ", "
			        & SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) & ", "
			        & SELECTEDVALUE ( Framework[Framework Display] ) & ", "
			        & FORMAT ( endDate, "dd-mmm-yy" )
		lineageTag: e4cc1d4f-2895-4e02-83a3-91cb543d13f2

