	measure 'Group inception date' =
			
			VAR maxPred =
			    MAX ( 'Period'[Period] )
			return
			    CALCULATE (
			        MAX ('Portfolios'[Group inception date (d)]),
			        FILTER('Portfolios', 'Portfolios'[As of Period] = maxPred)
			    )
		formatString: yyyy-mm-dd
		lineageTag: 1f475f41-60db-42d1-94eb-79ddd1d70f50

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	measure 'Total Portfolio Accrued Market Value' = ```
			
			 VAR maxdate =MAX ( Period[Date] )
			VAR mindate = MIN(Period[Date])
			var R =
			    CALCULATE (
			       SUM ( 'Total Market Value GA Fact'[Total Portfolio Accrued Market Value]),
			        'Total Market Value GA Fact'[Effective Date] <= maxdate && 'Total Market Value GA Fact'[Effective Date] >= mindate
			,CROSSFILTER(Portfolios[Tmv_Nk],'Total Market Value GA Fact'[Tmv_Nk],Both)
			    )
			 VAR maxdate1 =MAX ( Period[Period] )
			var R1 =
			    CALCULATE (
			       SUM ( 'Total Market Value GA Fact'[Total Portfolio Accrued Market Value]),
			        'Total Market Value GA Fact'[Effective Period]= maxdate1
			,CROSSFILTER(Portfolios[Tmv_Nk],'Total Market Value GA Fact'[Tmv_Nk],Both)
			    )
			
			RETURN
			R1
			
			```
		lineageTag: d3c5fc72-76f3-4942-96e6-9c970d183442

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Balance Book Value Base Ccy' = ```
			
			VAR maxdate =MAX ( Period[Period] )
			var R =
			    CALCULATE (
			        SUM ( 'Total Market Value GA Fact'[Balance Book Value Base CCY]),
			        'Total Market Value GA Fact'[Effective Period] = maxdate ,CROSSFILTER(Portfolios[Tmv_Nk],'Total Market Value GA Fact'[Tmv_Nk],Both))
			RETURN
			R
			
			```
		formatString: #,0.00
		lineageTag: 6c61821a-1c3f-4f41-a466-d0d97a6ab006

	measure 'Carrying Value Base CCY' =
			
			VAR maxdate1 =MAX ( Period[Date] )
			VAR mindate = MIN(Period[Date])
			var R =
			    CALCULATE (
			       SUM ( 'Total Market Value GA Fact'[Carrying Value Base CCY]),
			        'Total Market Value GA Fact'[Effective Date] <= maxdate1 && 'Total Market Value GA Fact'[Effective Date] >= mindate,CROSSFILTER(Portfolios[Tmv_Nk],'Total Market Value GA Fact'[Tmv_Nk],Both))
			VAR maxdate =MAX ( Period[Period] )
			var R2 =
			    CALCULATE (
			        SUM ( 'Total Market Value GA Fact'[Carrying Value Base CCY]),
			        'Total Market Value GA Fact'[Effective Period] = maxdate ,CROSSFILTER(Portfolios[Tmv_Nk],'Total Market Value GA Fact'[Tmv_Nk],Both))
			RETURN
			R2
		lineageTag: fe871f3e-5d4a-4bb4-ad31-ef359c7cbef7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Alternate PM Team' =
			
			VAR maxPred =
			    MAX ( 'Period'[Period] )
			VAR calc =
			    CALCULATE (
			        MAX ('Portfolios'[Alternate PM Team (D)]),
			        FILTER('Portfolios', 'Portfolios'[As of Period] = maxPred)
			    )
			RETURN
			    calc
		lineageTag: f41ee5e2-72cd-4838-a256-30663770d21d

	measure LatestMonthMarker =
			
			VAR maxDate =
			    MAX ( Period[Period])
			VAR inclusion =
			    CALCULATE (
			       Count(Portfolios[As of Date (D)]),
			        FILTER ( Portfolios, Portfolios[As of Period] = maxDate )
			    )
			RETURN
			    inclusion
		formatString: 0
		isHidden
		lineageTag: d68b86f2-1139-4780-958a-7ef35822d00f

	measure LatestTMVMarker =
			
			VAR maxDate =
			    MAX ( Period[Period])
			VAR inclusion =
			    CALCULATE (
			       COUNT('Total Market Value GA Fact'[Effective Date]),
			        FILTER ( 'Total Market Value GA Fact', 'Total Market Value GA Fact'[Effective Period] = maxDate )
			    )
			RETURN
			    inclusion
		formatString: 0
		lineageTag: 9866b775-0864-4618-9c42-0340c5ad04fd

	measure 'As Kyriba' =
			
			VAR maxPred =
			    MAX ( 'Period'[Period] )
			VAR askyriba =
			    CALCULATE (
			        FIRSTNONBLANK ( 'Portfolios'[As Kyriba (D)], TRUE () ),
			        'Portfolios'[As of Period] = maxPred
			    )
			RETURN
			  askyriba
		formatString: 0
		lineageTag: 32c9a2c8-1e79-49c5-878a-00a690931da0

	measure 'Eligible Portfolios' =
			
			VAR vSelectedPeriod= VALUE(FORMAT(MAX(Period[Date]),"YYYYMM"))
			RETURN
			CALCULATE(
			    COUNTROWS(Portfolios),
			    Portfolios[As of Period]=vSelectedPeriod
			)
		formatString: 0
		lineageTag: a9fb5b19-c602-4c51-9acc-f64b326874c2

