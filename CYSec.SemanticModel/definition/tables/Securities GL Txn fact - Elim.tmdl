	partition 'Securities GL Txn fact - Elim-0f079b07-6b00-4d98-a7e4-25e4a1af2780' = m
		mode: import
		source = ```
				let
				Sql = "SELECT TXN.`COMPANY_ACCOUNTING_UNIT_CD` as `Company Accounting Unit`
				      ,TXN.`PORTFOLIO_NK` as `Portfolio NK`
				      ,TXN.`FRAMEWORK_CD` as `Framework Cd`
				      ,TXN.`TXN_DT` as `Txn Dt`
				      ,CONCAT(TXN.`ISO3_CURRENCY_CD`,'/','MYR/',CAST(TXN.`TXN_PERIOD` as STRING)) as `Fx Join Key`
				      ,TXN.`ASSET_KEY` as `Security Nk`
				      ,TXN.`GL_ACCT_NUM` as `GL Acct Num`
				      ,TXN.`ACCT_CATEGORY` as `Acct Category`
				      ,TXN.`ISO3_CURRENCY_CD` as `ISO3 Currency Cd`
				      ,'MYR' as `Functional CCY Cd`
				      ,TXN.`TXN_NUM` as `Txn Num`
				      ,TXN.`COMMENTS` as `Comments`
				      ,TXN.`CAT_ADJUSTED_ELEMENTS_TXT` as `CAT Adjusted Elements Txt`
				      ,TXN.`SCD_LOT_ID` as `Bus Trans No`
				      ,TXN.`LOCAL_TXN_AMT` as `Local Txn Amt`
				      ,TXN.`SRC` as `Src`
				,SUBSTRING(TXN.`GL_ACCT_NUM`,1,6) as `Account`
				FROM "&Catalog&".inv_semantic_ga.`CONSOLIDATED_GL_TXN_FACT_DQ` TXN
				INNER JOIN (SELECT ACC.`COMPANY_NUM_CD`, PRT.`PORTFOLIO_NK` FROM "&Catalog&".inv_semantic_ga.`PORTFOLIO_DIM` PRT JOIN "&Catalog&".inv_semantic_ga.`ACCOUNTING_UNIT_DIM` ACC ON PRT.`SUBFUND_JOIN_KEY_CD`=ACC.`COMPANY_ACCOUNTING_UNIT_CD`) CMPRT 
				ON TXN.`PORTFOLIO_NK`=CMPRT.`PORTFOLIO_NK`
				WHERE `SRC`='CAT' 
				AND `SYS_CD` IN ('JT','AS') 
				AND `CAT_ASSET_TYPE_CD`='Securities' 
				AND `COMMENTS` NOT LIKE 'TDP%' 
				AND SUBSTRING(`GL_ACCT_NUM`,1,6) IN ('850044','850064')
				AND LEFT(TXN.`COMPANY_ACCOUNTING_UNIT_CD`,4)<>CMPRT.`COMPANY_NUM_CD` 
				AND LEFT(TXN.`COMPANY_ACCOUNTING_UNIT_CD`,4)='1086'",
				    Source = Value.NativeQuery(Databricks.Catalogs(HostName, HTTPPath, [Catalog=null, Database=null, EnableAutomaticProxyDiscovery=null,CommandTimeout= #duration(0,5,0,0)]){[Name=Catalog,Kind="Database"]}[Data], Sql, null, [EnableFolding=true]),
				    #"Filtered Rows" = Table.SelectRows(Source, each true)
				in
				    #"Filtered Rows"
				```

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

