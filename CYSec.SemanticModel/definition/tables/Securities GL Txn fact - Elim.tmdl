table 'Securities GL Txn fact - Elim'
	lineageTag: 7f3a52b5-aeca-4c84-a284-d1db5074f072

	measure 'Unreal Pl BV - Local (Sec Elim Adj)' =
			
			CALCULATE(
			    SUM('Securities GL Txn fact - Elim'[Local Txn Amt]),
			    'Securities GL Txn fact - Elim'[Account]="850044"
			)
		lineageTag: f3a18c40-0041-4e4d-b6f2-d7ab2af22b58

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Unreal Pl BV - Rep (Sec Elim Adj)' = ```
			
			VAR vSelectedCurrency = SELECTEDVALUE ('Reporting Currency'[Rep In Currency])
			RETURN
			SWITCH(
			    vSelectedCurrency,
			    "CAD",
			    CALCULATE(
			        SUMX(
			            'Securities GL Txn fact - Elim',
			            'Securities GL Txn fact - Elim'[Local Txn Amt]*RELATED('Fx Rate DQ'[CAD BS Rate])
			        ),
			        'Securities GL Txn fact - Elim'[Account]="850044"
			    ),
			    "HKD",
			    CALCULATE(
			        SUMX(
			            'Securities GL Txn fact - Elim',
			            'Securities GL Txn fact - Elim'[Local Txn Amt]*RELATED('Fx Rate DQ'[HKD BS Rate])
			        ),
			        'Securities GL Txn fact - Elim'[Account]="850044"
			    ),
			    "USD",
			    CALCULATE(
			        SUMX(
			            'Securities GL Txn fact - Elim',
			            'Securities GL Txn fact - Elim'[Local Txn Amt]*RELATED('Fx Rate DQ'[USD BS Rate])
			        ),
			        'Securities GL Txn fact - Elim'[Account]="850044"
			    ),
			    
			    CALCULATE(
			        SUMX(
			            'Securities GL Txn fact - Elim',
			            'Securities GL Txn fact - Elim'[Local Txn Amt]*RELATED('Fx Rate DQ'[Func BS Rate])
			        ),
			        'Securities GL Txn fact - Elim'[Account]="850044"
			    )
			)
			
			```
		lineageTag: 6cb84352-c1f8-4750-8b4e-c0b457472ef1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

