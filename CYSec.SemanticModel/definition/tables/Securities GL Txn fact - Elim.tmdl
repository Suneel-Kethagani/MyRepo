	column Company = ```
			
			VAR vCompany = LEFT('Securities GL Txn fact - Elim'[Company Accounting Unit],4)
			VAR vCompanyName = 
			CALCULATE(
			    MAX(Company[Company Code & Name Display]),
			    Company[Company]=vCompany,
			    ALL('Securities GL Txn fact - Elim')
			)
			RETURN vCompanyName
			```
		lineageTag: 09d15776-fb1b-47bd-ba4e-5038596d0e8f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Group Structure Company' = 1086
