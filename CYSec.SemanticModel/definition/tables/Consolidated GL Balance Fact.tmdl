table 'Consolidated GL Balance Fact'
	lineageTag: 5f5ae9bd-8c66-4339-988c-ecfbf4104bd0

	measure 'Adjustment_Amount (CAD)' = ```
			
			VAR vSelectedCurrency = SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			VAR vLatestPeriodSelected = MAX(Period[Period])
			RETURN
			SUMX(
			    'Consolidated GL Balance Fact',
			    VAR vLocalCurr = 'Consolidated GL Balance Fact'[ISO3 Currency Cd]
			    VAR vFuncCurr = 'Consolidated GL Balance Fact'[Functional CCY Cd]
			    VAR vFuncBSRate = 
			        CALCULATE(
			            SELECTEDVALUE('Fx Rate DQ'[Func BS Rate]),
			            'Fx Rate DQ'[FROM_CCY]=vLocalCurr,
			            'Fx Rate DQ'[TO_CCY]=vFuncCurr,
			            'Fx Rate DQ'[PERIOD]=vLatestPeriodSelected,
			            REMOVEFILTERS('Fx Rate DQ')
			        )
			    VAR vRepBSRate = 
			        CALCULATE(
			            SELECTEDVALUE('Fx Rate DQ'[Func BS Rate]),
			            'Fx Rate DQ'[FROM_CCY]=vFuncCurr,
			            'Fx Rate DQ'[TO_CCY]="CAD",
			            'Fx Rate DQ'[PERIOD]=vLatestPeriodSelected,
			            REMOVEFILTERS('Fx Rate DQ')
			        )
			    RETURN 'Consolidated GL Balance Fact'[Local Balance Amt]*vFuncBSRate*vRepBSRate
			    
			
			)
			```
		lineageTag: cba5ecaa-6148-4d06-9911-c8ec328bc123

		annotation PBI_FormatHint = {"isGeneralNumber":true}

