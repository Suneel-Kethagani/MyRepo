	column 'GL Acct (6 digits)' = left('Consolidated GL Balance Fact'[GL Acct Num],6)
		lineageTag: 47a51ec0-1ff6-4bcb-9adb-2c5d16c02bec
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'Consolidated GL Balance Fact' = m
		mode: import
		source = ```
				let
				    Sql = "select  case when size(split(bal.ASSET_KEY, '/')) >= 3 THEN concat_ws(
				      '/',                                            -- output delimiter (literal)
				      slice(split(bal.ASSET_KEY, '/'), 1, size(split(bal.ASSET_KEY, '/') ) - 2),  -- everything before the last 2 parts
				      array('"&Date.ToText(Date.EndOfMonth(pCutOffDate),"yyyyMMdd")&"'),                              -- your replacement
				      array(element_at(split(bal.ASSET_KEY, '/'), -1))            -- last part
				    )
				 ELSE bal.ASSET_KEY -- not enough delimiters; keep string as-is
				  END as updated_key,
				  case when size(split(bal.ASSET_KEY, '/')) >= 3 then element_at(split(bal.ASSET_KEY, '/'), -2) else 0 end as key_yearmonth,
				    BAL.COMPANY_ACCOUNTING_UNIT_CD as `Company Accounting Unit Cd`,
				BAL.SUBFUND_CD as `Subfund Cd`,
				BAL.PORTFOLIO_NK as `Portfolio Nk`,
				BAL.FRAMEWORK_CD as `Framework Cd`,
				BAL.AS_OF_DT as `As of Dt`,
				BAL.AS_OF_PERIOD as `As of Period`,
				BAL.FX_JOIN_KEY as `FX Join Key`,
				BAL.ASSET_KEY as `Asset Key`,
				BAL.GL_ACCT_NUM as `GL Acct Num`,
				BAL.ACCT_CATEGORY as `Acct Category`,
				BAL.ISO3_CURRENCY_CD as `ISO3 Currency Cd`,
				BAL.FUNCTIONAL_CCY_CD as `Functional CCY Cd`,
				BAL.SYS_CD as `Sys Cd`,
				BAL.LOWEST_LVL_FLAG as `Lowest Lvl Flag`,
				BAL.TXN_TYPE as `Txn Type`,
				BAL.RE_POOL_NUM as `RE Pool Num`,
				BAL.RE_PROPERTY_SK as `RE Property Sk`,
				BAL.RE_BOOK_SK as `RE Book Sk`,
				BAL.RE_ACCT_SK as `RE Acct Sk`,
				BAL.RE_SUBFUND_PCT as `RE Subfund PCT`,
				BAL.LOAN_INV_ARRANGEMENT_KEY as `Loan Inv Arrangement Key`,
				BAL.LOAN_OWNER as `Loan Owner`,
				BAL.LOAN_BAL_TYPE_CD as `Loan Bal Type Cd`,
				BAL.LOAN_BAL_TYPE_SUBKEY_CD as `Loan Bal Type Subkey Cd`,
				BAL.LOAN_BAL_YEAR as `Loan Bal Year`,
				BAL.LOAN_BAL_YEAR_TYPE_CD as `Loan Bal Year Type Cd`,
				BAL.SCD_LOT_ID as `SCD Lot Id`,
				BAL.SCD_SUM_GL_HOLDING_IK as `SCD Sum GL Holding Ik`,
				BAL.SCD_SUM_FROM_DATE as `SCD Sum From Date`,
				BAL.SCD_SUM_TO_DATE as `SCD Sum To Date`,
				BAL.LOCAL_BALANCE_AMT as `Local Balance Amt`,
				BAL.RE_LOCAL_UNSEGMENTED_BALANCE_AMT as `RE Local Unsegmented Balance Amt`,
				BAL.SCD_BASE_BALANCE as `SCD Base Balance`,
				BAL.BATCH_DT as `Batch Dt`,
				BAL.SRC as `Src`,
				BAL.CREATED_TS as `Created Ts`,
				BAL.UPDATED_TS as `Updated Ts`,
				BAL.FUNC_BALANCE_AMT as `Func Balance Amt`,
				BAL.CAD_BALANCE_AMT as `CAD Balance Amt`,
				BAL.HKD_BALANCE_AMT as `HKD Balance Amt`,
				BAL.USD_BALANCE_AMT as `USD Balance Amt`,
				BAL.SCD_GL_CLASSIFICATION as `SCD GL Classification`,
				BAL.SCD_GL_ACCOUNT_SUBTYPE as `SCD GL Account Subtype`,
				BAL.INVESTOR_FULL_NAME as `Investor Full Name`,
				BAL.GROUP_STRUCTURE_COMPANY as `Group Structure Company`,
				BAL.GROUP_STRUCTURE_COMPANY_NAME as `Group Structure Company Name`,
				BAL.NODE_IK as `Node Ik`,
				BAL.ORIGINATION_PROPERTY_VALUATION_DT as `Origination Property Valuation Dt`,
				BAL.ORIGINATION_PROPERTY_VALUE_AMT as `Origination Property Value Amt`,
				BAL.DT_CLOSED as `Dt Closed`,
				BAL.YTD_BAL as `YTD Bal`,
				BAL.mtd_bal as `MTD Bal`,
				BAL.status_cd as `Status Cd`,
				ad.ASSET_ID as `Asset ID`
				  FROM "&Catalog&".inv_semantic_ga.consolidated_gl_balance_fact_dq as BAL
				INNER JOIN (SELECT ACC.`COMPANY_NUM_CD`, PRT.`PORTFOLIO_NK` FROM "&Catalog&".inv_semantic_ga.PORTFOLIO_DIM PRT JOIN 
				"&Catalog&".inv_semantic_ga.ACCOUNTING_UNIT_DIM ACC ON PRT.`SUBFUND_JOIN_KEY_CD`=ACC.`COMPANY_ACCOUNTING_UNIT_CD`) CMPRT 
				ON LEFT(BAL.`COMPANY_ACCOUNTING_UNIT_CD`,4)=CMPRT.`COMPANY_NUM_CD` AND BAL.`PORTFOLIO_NK`=CMPRT.`PORTFOLIO_NK`
				LEFT JOIN "&Catalog&".inv_semantic_ga.asset_dim_dq ad  on
				BAL.`ASSET_KEY`=ad.ASSET_KEY
				WHERE BAL.`SRC`='CAT' AND `SYS_CD` IN ('JT','AS') AND BAL.AS_OF_DT>= '" & Date.ToText(#"pCutOffDate","yyyy-MM-dd") &"' and SUBSTRING(`GL_ACCT_NUM`,1,6) IN 
				(SELECT CAST(GL_ACCT_NUM AS VARCHAR(1000)) FROM "&Catalog&".inv_semantic_ga.CAT_CONFIG_MAPPING_DATA)",
				    Source = Value.NativeQuery(Databricks.Catalogs(HostName, HTTPPath, [Catalog=null, Database=null, EnableAutomaticProxyDiscovery=null,CommandTimeout= #duration(0,5,0,0)]){[Name=Catalog,Kind="Database"]}[Data], Sql, null, [EnableFolding=true])
				,
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"key_yearmonth", Int64.Type}}),
				    #"Added Conditional Column" = Table.AddColumn(#"Changed Type", "New Asset Key", each if [key_yearmonth] = 0 then [Asset Key] else if [key_yearmonth] < Number.FromText(Date.ToText(Date.EndOfMonth(pCutOffDate),"yyyyMMdd")) then [updated_key] else [Asset Key]),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Added Conditional Column",{{"New Asset Key", type text}})
				in
				    #"Changed Type1"
				```

	annotation PBI_NavigationStepName = Navigation

