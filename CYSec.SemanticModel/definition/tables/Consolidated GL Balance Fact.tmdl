	column 'AssetID Date Key' = COMBINEVALUES("-",'Consolidated GL Balance Fact'[New Asset Key],'Consolidated GL Balance Fact'[Asset ID])
		lineageTag: d73c2163-1588-4f94-8743-68c97c5586f6
		summarizeBy: none

