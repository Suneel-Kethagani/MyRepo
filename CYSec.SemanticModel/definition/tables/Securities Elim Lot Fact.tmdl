	measure 'Balance Book Value Elim Local' = ```
			
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Elim Lot Fact'[Balance Book Value Local CCY]),
			    CALCULATE (
			        SUM('Securities Elim Lot Fact'[Balance Book Value Local CCY]),
			        LASTDATE ('Securities Elim Lot Fact'[Effective Date])
			       
			    )
			) 
			```
		lineageTag: 4947dd58-47c5-45d7-9db6-23627a135a52

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Balance Book Value Elim Rep' = ```
			
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        IF (
			            ISFILTERED ( Period[Date] ),
			            SUM ( 'Securities Elim Lot Fact'[Balance Book Value Base CCY] ),
			            CALCULATE (
			                SUM ( 'Securities Elim Lot Fact'[Balance Book Value Base CCY] ),
			                LASTDATE ( 'Securities Elim Lot Fact'[Effective Date] )
			            )
			        ),
			    IF (
			        ISFILTERED ( Period[Date] ),
			        SUMX (
			            'Securities Elim Lot Fact',
			            'Securities Elim Lot Fact'[Balance Book Value local CCY] * 'Fx Rate DQ'[Rep Rate]
			            
			        ),
			        CALCULATE (
			            SUMX (
			                'Securities Elim Lot Fact',
			                'Securities Elim Lot Fact'[Balance Book Value local CCY] * 'Fx Rate DQ'[Rep Rate]
			                    
			            ),
			            LASTDATE ( 'Securities Elim Lot Fact'[Effective Date] )
			        )
			    )
			)
			```
		lineageTag: c93e4aff-458a-424c-b06f-4098380a74d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Security Elim Lots Title' = ```
			
			VAR maxdate =
			    MAX ( 'Securities Elim Lot Fact'[Effective Date] )
			RETURN
			    "Security Elim Lots" & ", "
			        & SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) & ", "
			        & SELECTEDVALUE ( Framework[Framework Display] ) & ", "
			        & FORMAT ( maxdate, "dd-mmm-yy" )
			
			```
		lineageTag: 55a0bea7-e615-450c-a692-b859db78f933

