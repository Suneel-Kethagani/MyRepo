	measure 'Final Staging Text (Sec Elim)' = ```
			
			VAR vCreditimpairmentStage = MAX('Securities Elim Lot Fact'[Credit Impairment Stage])
			RETURN
			IF(
			    ISINSCOPE(Securities[Primary Security ID & Desc]),
			    VAR vCATStagingText =
			    MAXX(
			        'Securities Elim Lot Fact',
			        VAR vAssetID = 'Securities Elim Lot Fact'[SCD Security ID]
			        VAR vFramework='Securities Elim Lot Fact'[Framework Cd]
			        VAR vPeriod='Securities Elim Lot Fact'[As Of Period]
			        VAR vLatestDate = 
			        CALCULATE(
			            MAX('Cat Staging Text Fact'[Txn Dt]),
			            'Cat Staging Text Fact'[Asset Id]=vAssetID,
			            'Cat Staging Text Fact'[Framework Cd]=vFramework,
			            'Cat Staging Text Fact'[Txn Period]<=vPeriod
			        )
			        RETURN
			        
			        CALCULATE(
			            MAX('Cat Staging Text Fact'[Staging Txt]),
			            'Cat Staging Text Fact'[Asset Id]=vAssetID,
			            'Cat Staging Text Fact'[Framework Cd]=vFramework,
			            'Cat Staging Text Fact'[Txn Dt]=vLatestDate
			        )
			    )
			    RETURN
			    COALESCE(vCATStagingText,vCreditimpairmentStage)
			)
			
			```
		lineageTag: 0cdc4ad8-eff4-42b2-b037-36b77c93c963

	measure 'Staging Text (Sec Elim)' = ```
			
			IF(
			    ISINSCOPE(Securities[Primary Security ID & Desc]),
			    VAR vCATStagingText =
			    MAXX(
			        'Securities Elim Lot Fact',
			        VAR vAssetID = 'Securities Elim Lot Fact'[SCD Security ID]
			        VAR vFramework='Securities Elim Lot Fact'[Framework Cd]
			        VAR vPeriod='Securities Elim Lot Fact'[As Of Period]
			        VAR vLatestDate = 
			        CALCULATE(
			            MAX('Cat Staging Text Fact'[Txn Dt]),
			            'Cat Staging Text Fact'[Asset Id]=vAssetID,
			            'Cat Staging Text Fact'[Framework Cd]=vFramework,
			            'Cat Staging Text Fact'[Txn Period]<=vPeriod
			        )
			        RETURN
			        
			        CALCULATE(
