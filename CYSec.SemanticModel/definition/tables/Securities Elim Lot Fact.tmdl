	measure 'ECL/CECL Impairment - Local (Sec Elim)' = ```
			
			
			SWITCH(SELECTEDVALUE ( Framework[Framework] ),
			"IFRS9",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			            SUM ( 'Securities Elim Lot Fact'[Balance Cl Allowance Local CCY] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local CCY] ),
			    CALCULATE (
			                SUM ( 'Securities Elim Lot Fact'[Balance Cl Allowance Local CCY] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			        LASTDATE('Securities Elim Lot Fact'[Effective Date])
			    )),
			"USGAAP",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Elim Lot Fact'[Balance Recog CL Allowance Local ccy] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			    CALCULATE (
			        SUM ( 'Securities Elim Lot Fact'[Balance Recog CL Allowance Local ccy] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			        LASTDATE('Securities Elim Lot Fact'[Effective Date])
			    )),
			"IAS39",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Elim Lot Fact'[Balance Impairment Local ccy] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			    CALCULATE (
			        SUM ( 'Securities Elim Lot Fact'[Balance Impairment Local ccy] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			        LASTDATE('Securities Elim Lot Fact'[Effective Date])
			    )),
			"JGAAP",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Elim Lot Fact'[Balance Impairment Local ccy] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			    CALCULATE(
			        SUM ( 'Securities lots Fact'[Balance Impairment - Local] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			        LASTDATE('Securities Elim Lot Fact'[Effective Date])
			    )),
			"NAIC",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Elim Lot Fact'[Balance Impairment Local ccy] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			    CALCULATE (
			        SUM ( 'Securities Elim Lot Fact'[Balance Impairment Local ccy] )
			            + SUM ( 'Securities Elim Lot Fact'[Balance Write Off Local ccy] ),
			        LASTDATE('Securities Elim Lot Fact'[Effective Date])
			    ))
			,BLANK())
			
			```
		lineageTag: 73c23aa4-c3dd-4483-b62d-2fbe57428c39

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ECL/CECL Impairment - Rep (Sec Elim)' = ```
			
			VAR FW =
			    SELECTEDVALUE ( Framework[Framework] )
			VAR IFRS9_FW = 'Securities Elim Lot Fact'[Balance CL Allowance - Rep (Sec Elim)] + 'Securities Elim Lot Fact'[Balance Write Off - Rep (Sec Elim)]
			VAR USGAAP_FW = 'Securities Elim Lot Fact'[Balance Recog CL Allowance - Rep (Sec Elim)] + 'Securities Elim Lot Fact'[Balance Write Off - Rep (Sec Elim)]
			VAR IAS39_JGAAP_NAIC_FW = 'Securities Elim Lot Fact'[OTTI Impairment - Rep (Sec Elim)] + 'Securities Elim Lot Fact'[Balance Write Off - Rep (Sec Elim)]
			RETURN
			    SWITCH(
			        TRUE(),
			        FW = "IFRS9",IFRS9_FW,
			        FW = "USGAAP",USGAAP_FW,
			        FW = "IAS39"|| FW = "JGAAP"|| FW = "NAIC" ,IAS39_JGAAP_NAIC_FW,
			        BLANK ()
			    )
			
			```
		lineageTag: a635d13f-ad67-4802-9776-dfb8437a824d

