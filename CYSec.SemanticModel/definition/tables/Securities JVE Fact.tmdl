		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'JVE Securities Title' = ```
			
			VAR maxdate =
			    MAX ( Period[Date] )
			RETURN
			    "Positional Balances from JVE Securities" & ", "
			        & SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) & ", "
			        & SELECTEDVALUE ( Framework[Framework Display] ) & ", "
			        & FORMAT ( maxdate, "MMM-YY" )
			
			```
		lineageTag: d76fff00-4a98-447b-979d-21d3b345ee6a

	measure 'JVE Adjustment Amount (CAD)' = ```
			
			VAR vSelectedCurrency = SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			VAR vLatestPeriodSelected = MAX(Period[Period])
			RETURN
			SUMX(
			    'Securities JVE Fact',
			    VAR vLocalCurr = 'Securities JVE Fact'[ISO3 Currency Cd]
			    VAR vFuncCurr = 'Securities JVE Fact'[Functional CCY cd]
			    VAR vFuncBSRate = 
			        CALCULATE(
			            SELECTEDVALUE('Fx Rate DQ'[Func BS Rate]),
			            'Fx Rate DQ'[FROM_CCY]=vLocalCurr,
			            'Fx Rate DQ'[TO_CCY]=vFuncCurr,
			            'Fx Rate DQ'[PERIOD]=vLatestPeriodSelected,
			            REMOVEFILTERS('Fx Rate DQ')
			        )
			    VAR vRepBSRate = 
			        CALCULATE(
			            SELECTEDVALUE('Fx Rate DQ'[Func BS Rate]),
			            'Fx Rate DQ'[FROM_CCY]=vFuncCurr,
			            'Fx Rate DQ'[TO_CCY]="CAD",
			            'Fx Rate DQ'[PERIOD]=vLatestPeriodSelected,
			            REMOVEFILTERS('Fx Rate DQ')
			        )
			    RETURN 'Securities JVE Fact'[Local Txn Amt]*vFuncBSRate*vRepBSRate
			    )
			
			```
		lineageTag: fd609f10-2966-4eca-b5e5-45c821fa5ef2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

