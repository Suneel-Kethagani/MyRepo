table 'Securities JVE Fact'
	lineageTag: 3f7839cc-5291-4682-97de-0f4c6165d655

	measure 'Book Value - Adjustment Local' = CALCULATE(Sum('Securities JVE Fact'[Local Txn Amt]),FILTER(ALL(Period[Date]),Period[Date]<=MAX(Period[Date])))
		lineageTag: 0f51cea4-9ffb-4837-b0e1-5d7494c62d71

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Book Value - Adjustment Rep' = ```
			
			VAR vSelectedCurrency = SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			
			VAR vBookValueLTD= 
			CALCULATE (
			    SWITCH (
				vSelectedCurrency,
				"CAD", 'Securities JVE Fact'[JVE Adjustment Amount (CAD)],
			    "HKD", 'Securities JVE Fact'[JVE Adjustment Amount (HKD)],
			    "USD", 'Securities JVE Fact'[JVE Adjustment Amount (USD)],
			    'Securities JVE Fact'[JVE Adjustment Amount (Func)]
			    ),
			    FILTER(ALL(Period[Date]),Period[Date]<=MAX(Period[Date]))
			)
			
			RETURN vBookValueLTD
			```
		lineageTag: dbd0924a-da34-4ad0-9c6c-0d2f2f1d3edf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

