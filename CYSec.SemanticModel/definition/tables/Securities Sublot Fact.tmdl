	measure 'AOCI Hedge Findur ID Sublot (SPH)' =
			
			VAR closePerd =
			    max('Period'[Period])
			RETURN
			    CALCULATE (
			        COUNT('Securities Sublot Fact'[AOCI Hedge Findur ID]),
			         All('Period'), 'Securities Sublot Fact'[As of Period] <= closePerd
			    )
		formatString: 0
		displayFolder: Sublot Rollforward Attributes
