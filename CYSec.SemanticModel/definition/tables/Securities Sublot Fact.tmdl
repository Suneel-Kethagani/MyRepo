table 'Securities Sublot Fact'
	lineageTag: 14d7f8dc-6853-439f-8d36-a256e695cbd9

	measure 'Balanced Amortized AOCI - Local' = ```
			
			
			    IF (
			        ISFILTERED ( 'Period'[Date] ),
			         SUM ( 'Securities Sublot Fact'[Balanced Amortized AOCI - Local (D)] ),
			        CALCULATE (
			             SUM ( 'Securities Sublot Fact'[Balanced Amortized AOCI - Local (D)] ),
			            LASTDATE ( 'Securities Sublot Fact'[As of Date] )
			        )
			    )
			
			```
		lineageTag: 9159c207-cfb8-4b1b-a880-0959f9f24e91

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Balance Remaining AOCI - Local' = ```
			
			
			    IF (
			        ISFILTERED ( 'Period'[Date] ),
			        SUM('Securities Sublot Fact'[Balance Remaining AOCI - Local (D)]),
			        CALCULATE (
			            SUM('Securities Sublot Fact'[Balance Remaining AOCI - Local (D)]),
			            LASTDATE ( 'Securities Sublot Fact'[As of Date]  )
			        )
			    )
			
			/*VAR closePerd =
			    MAX ( Period[Period End Date] )
			RETURN
			    CALCULATE (
			        SUM ( 'Sublot Fact'[Balance Remaining AOCI - Local (D)] ),
			        FILTER ( 'Sublot Fact', 'Sublot Fact'[As of Date] = closePerd )
			    )*/
			```
		lineageTag: 2e758712-549b-42d1-bc1c-fc7127c67f58

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Reporting Currency (Sublot)' =
			
			VAR SelectedCurrency =
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			VAR ReportingCurrency =
			    IF (
			        SelectedCurrency = "Company",
			        FIRSTNONBLANK ( 'Securities Sublot Fact'[Functional CCY Code], TRUE () ),
			        IF (
			            SelectedCurrency = "SCD Base",
			            FIRSTNONBLANK ( 'Securities Sublot Fact'[Base], TRUE () ),
			            SelectedCurrency
			        )
			    )
			RETURN
			    ReportingCurrency
		lineageTag: 4ed43c4f-5074-4a2a-a014-89b1ff74503f

	measure 'Balance Remaining AOCI - Rep' = ```
			
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        IF (
			            ISFILTERED ( 'Period'[Date] ),
			            SUM ( 'Securities Sublot Fact'[Balance Remaining AOCI - Base] ),
			            CALCULATE (
			                SUM ( 'Securities Sublot Fact'[Balance Remaining AOCI - Base] ),
			                LASTDATE ( 'Securities Sublot Fact'[As of Date] )
			            )
			        ),
			    IF (
			        ISFILTERED ( 'Period'[Date] ),
			        SUMX (
			            'Securities Sublot Fact',
			            'Securities Sublot Fact'[Balance Remaining AOCI - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        CALCULATE (
			            SUMX (
			                'Securities Sublot Fact',
			                'Securities Sublot Fact'[Balance Remaining AOCI - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			            ),
			            LASTDATE ( 'Securities Sublot Fact'[As of Date]  )
			        )
			    )
			)
			/*IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
			            SUM ( 'Securities Sublot Fact'[Balance Remaining AOCI - Base] ),
			            SUMX ( 'Securities Sublot Fact', 'Securities Sublot Fact'[Balance Remaining AOCI - Local (D)] ) * 'Securities Sublot Fact'[Rep Rate (Sublot)]
			        )
			VAR closePerd =
			    MAX ( Period[Period End Date] )
			RETURN
			    CALCULATE (
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
			            SUM ( 'Sublot Fact'[Balance Remaining AOCI - Base] ),
			            SUMX ( 'Sublot Fact', 'Sublot Fact'[Balance Remaining AOCI - Local (D)] ) * 'Sublot Fact'[Rep Rate (Sublot)]
			        ),
			        FILTER ( 'Sublot Fact', 'Sublot Fact'[As of Date] = closePerd )
			    )*/
			
			```
		lineageTag: 0ffcae09-1bcb-471f-8329-2880595b93f5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Balanced Amortized AOCI - Rep' =
			
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        IF (
			            ISFILTERED ( 'Period'[Date] ),
			            SUM ( 'Securities Sublot Fact'[Balanced Amortized AOCI - Base] ),
			            CALCULATE (
			                SUM ( 'Securities Sublot Fact'[Balanced Amortized AOCI - Base] ),
			                LASTDATE ( 'Securities Sublot Fact'[As of Date] )
			            )
			        ),
			    IF (
			        ISFILTERED ( 'Period'[Date] ),
			        SUMX (
			            'Securities Sublot Fact',
			            'Securities Sublot Fact'[Balanced Amortized AOCI - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        CALCULATE (
			            SUMX (
			                'Securities Sublot Fact',
			                'Securities Sublot Fact'[Balanced Amortized AOCI - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			            ),
			            LASTDATE ( 'Securities Sublot Fact'[As of Date] )
			        )
			    )
			)
			
			/*IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
			            SUM ( 'Securities Sublot Fact'[Balanced Amortized AOCI - Base] ),
			            SUMX ( 'Securities Sublot Fact', 'Securities Sublot Fact'[Balanced Amortized AOCI - Local (D)] ) * 'Securities Sublot Fact'[Rep Rate (Sublot)]
			        )
			VAR closePerd =
			    MAX ( Period[Period End Date] )
			RETURN
			    CALCULATE (
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
			            SUM ( 'Sublot Fact'[Balanced Amortized AOCI - Base] ),
			            SUMX ( 'Sublot Fact', 'Sublot Fact'[Balanced Amortized AOCI - Local (D)] ) * 'Sublot Fact'[Rep Rate (Sublot)]
			        ),
			        FILTER ( 'Sublot Fact', 'Sublot Fact'[As of Date] = closePerd )
			    )*/
		lineageTag: 9e17710a-548d-4fca-be1d-9487bfa526ce

		annotation PBI_FormatHint = {"isGeneralNumber":true}

