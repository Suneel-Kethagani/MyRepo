	measure 'AOCI Amortized - Local (SPH)' =
			
			
			VAR closePerd =
			    max('Period'[Period])
			RETURN
			    CALCULATE (
			        SUM('Securities Sublot Fact'[Balanced Amortized AOCI - Local (D)] ),
			         All('Period'), 'Securities Sublot Fact'[As of Period] <= closePerd
			    )
		displayFolder: Sublot Rollforward Attributes
		lineageTag: 5ad299e8-6091-42b7-8358-510833558756

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AOCI Amortized - Rep (SPH)' = ```
			
			VAR closePerd =
			    MAX ( 'Period'[Period] )
			RETURN
			    CALCULATE (
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
			            SUM ( 'Securities Sublot Fact'[Balanced Amortized AOCI - Base] ),
			            SUMX ( 'Securities Sublot Fact', 'Securities Sublot Fact'[Balanced Amortized AOCI - Local (D)] ) * 'Fx Rate DQ'[Rep Rate]),
			        All('Period'), 'Securities Sublot Fact'[As of Period] <= closePerd 
			    )
			```
		displayFolder: Sublot Rollforward Attributes
		lineageTag: 9feb3c02-4e36-4eda-8294-7d3c1d4eb8cb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

