	measure 'NAIC Initial SVO Rating' = ```
			
			VAR vMatchSourceTransID=SELECTEDVALUE('Securities Transaction GA Fact'[Match Src Transaction ID])
			VAR vTradeDate = 
			IF(
			    COUNTROWS('Securities Transaction GA Fact')>0,
			    CALCULATE(
			        MAX('Securities Transaction GA Fact'[Trade Date]),
			        'Securities Transaction GA Fact'[Source ID]=vMatchSourceTransID,
			        REMOVEFILTERS('Securities Transaction GA Fact')
			    )
			)
			VAR vSecurityNK =  SELECTEDVALUE('Securities Transaction GA Fact'[Security NK])
			VAR vSrcSecurityIDMarketID = IF(LEN(vSecurityNK)>0,LEFT(vSecurityNK,LEN(vSecurityNK)-12))
			VAR vLatestSecurityAsOfDate = 
			IF(
			    COUNTROWS('Securities Transaction GA Fact')>0,
			    CALCULATE(
			        MAX('Securities'[As Of Dt]),
			        Securities[Src Security ID]&"/"&Securities[Src Market ID]&"/"=vSrcSecurityIDMarketID,
			        Securities[As Of Dt]<=vTradeDate,
			        REMOVEFILTERS(Securities)
			    )
			)
			
			RETURN
			IF(
			    COUNTROWS('Securities Transaction GA Fact')>0,
			    IF(
			        ISINSCOPE('Securities Transaction GA Fact'[Transaction No]),
			        CALCULATE(
			            SELECTEDVALUE(Securities[NAIC Rating]),
			            Securities[Security NK]=vSrcSecurityIDMarketID&FORMAT(vLatestSecurityAsOfDate,"YYYYMMDD")&"/SCD"
			        )
			    )
			)
			
			
			```
		formatString: 0
		lineageTag: 34de1575-d198-4796-9b4e-5d43a70086f4

