	column 'Transfer Type (BV vs MV)' = ```
			
			SWITCH (
			    TRUE(),
			    NOT ( ISBLANK ( 'Securities Transaction GA Fact'[Transaction Purpose] ) ),"BV Transfer",
			    NOT ( ISBLANK ( 'Securities Transaction GA Fact'[Group Structure Relation] ) ),"MV Transfer",
			    BLANK ()
			    )
			
			
			```
		lineageTag: e930c894-103d-4618-a26a-742f449bf395
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Transfer Purpose (Inter or Intra)' = ```
			
