	measure 'Settle Amount - Rep (Sec Trans)' =
			
			VAR calc =
			SUMX (
			        SUMMARIZE (
			            'Securities Transaction GA Fact',
			            'Securities Transaction GA Fact'[Company Code & Name Display],
			            'Securities Transaction GA Fact'[Accounting Unit Code & Name Display],
			            'Securities Transaction GA Fact'[Portfolio Code & Name],
			            'Securities Transaction GA Fact'[Trans Type],
			            'Securities Transaction GA Fact'[Primary Security ID (Sec Tran)],
			            'Securities Transaction GA Fact'[Transaction No],
			            'Securities Transaction GA Fact'[Settle Amount (D)],
			            'Fx Rate DQ'[FX Join Key]
			        ),
			        'Securities Transaction GA Fact'[Settle Amount (D)] *[Rep Rate]
			    )
			RETURN
			    calc
		lineageTag: 6f1bd684-ec1a-41d3-ac74-781ba61dc688

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Settle Principal - Rep (Sec Trans)' = ```
			
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        MAX ( 'Securities Transaction GA Fact'[Settle Principal] ),
			  
			        MAXX (
			            'Securities Transaction GA Fact',
			            'Securities Transaction GA Fact'[Settle Principal] * 'Fx Rate DQ'[Rep Rate]
			        )
			)
