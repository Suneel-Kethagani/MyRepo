			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
			            SUM ( 'Securities Transaction AOCI GA Fact'[Sublot Amort AOCI - Local] ),
			            SUMX( 'Securities Transaction AOCI GA Fact','Securities Transaction AOCI GA Fact'[Sublot Amort AOCI - Local]* 'Fx Rate DQ'[Rep Rate])
			--SUM('Securities Transaction GA Fact'[Sublot Amort AOCI - CAD])
			),
			        ALL('Period'), 'Securities Transaction AOCI GA Fact'[Transasofdate] <= closePerd 
			    )
			RETURN CALC
