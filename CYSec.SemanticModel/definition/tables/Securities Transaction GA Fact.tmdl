	measure 'Amortized Cost - Rep (Sec Trans)' = ```
			
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        VAR vSummarizeTable = 
			        SUMMARIZE(
			            'Securities Transaction GA Fact',
			            'Securities Transaction GA Fact'[Functional Ccy Code],
			            'Securities Transaction GA Fact'[Base],
			            'Securities Transaction GA Fact'[As Of Period],
			            'Securities Transaction GA Fact'[FX Join Key]
			        )
			        VAR vSummarizeTableWithFXRate =
			        ADDCOLUMNS(
			            vSummarizeTable,
			            "@AmortizedCostLocal",
			            CALCULATE(
			                SUM('Securities Transaction GA Fact'[Amortized Cost Local])
			            ),
			            "@LocalToFuncFXRate",
			            VAR vLocalToFuncFXJoinKey = 'Securities Transaction GA Fact'[FX Join Key]
			            RETURN
			            CALCULATE(
			                MAX('Fx Rate DQ'[Func BS Rate]),
			                'Fx Rate DQ'[FX Join Key]=vLocalToFuncFXJoinKey,
			                ALL('Fx Rate DQ')
			            ),
			        
			            "@FuncToBaseFXRate",
			            VAR FuncToBaseFXJoinKey = 'Securities Transaction GA Fact'[Functional Ccy Code]&"/"&'Securities Transaction GA Fact'[Base]&"/"&'Securities Transaction GA Fact'[As Of Period]
			            RETURN
			            CALCULATE(
			                MAX('Fx Rate DQ'[Func BS Rate]),
			                'Fx Rate DQ'[FX Join Key]=FuncToBaseFXJoinKey,
			                ALL('Fx Rate DQ')
			            )
			        )
			        RETURN
			        SUMX(
			            vSummarizeTableWithFXRate,
			            [@AmortizedCostLocal]*[@LocalToFuncFXRate]*[@FuncToBaseFXRate]
			        ),
			
			        SUMX (
			            'Securities Transaction GA Fact',
			            'Securities Transaction GA Fact'[Amortized Cost Local] * 'Fx Rate DQ'[Rep Rate]
			        )
			)
			```
		lineageTag: 67e85eb4-4f0e-462b-a6c7-e87bff2edcce

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Realised Impairment - Rep (Sec Trans)' = ```
			
			
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        VAR vSummarizeTable = 
			        SUMMARIZE(
			            'Securities Transaction GA Fact',
			            'Securities Transaction GA Fact'[Functional Ccy Code],
			            'Securities Transaction GA Fact'[Base],
			            'Securities Transaction GA Fact'[As Of Period],
			            'Securities Transaction GA Fact'[FX Join Key]
			        )
			        VAR vSummarizeTableWithFXRate =
			        ADDCOLUMNS(
			            vSummarizeTable,
			            "@RealisedImpairmentLocal",
			            CALCULATE(
			                SUM('Securities Transaction GA Fact'[Realised Impairment Local])
			            ),
			            "@LocalToFuncFXRate",
			            VAR vLocalToFuncFXJoinKey = 'Securities Transaction GA Fact'[FX Join Key]
			            RETURN
			            CALCULATE(
			                MAX('Fx Rate DQ'[Func BS Rate]),
			                'Fx Rate DQ'[FX Join Key]=vLocalToFuncFXJoinKey,
			                ALL('Fx Rate DQ')
			            ),
			        
			            "@FuncToBaseFXRate",
			            VAR FuncToBaseFXJoinKey = 'Securities Transaction GA Fact'[Functional Ccy Code]&"/"&'Securities Transaction GA Fact'[Base]&"/"&'Securities Transaction GA Fact'[As Of Period]
			            RETURN
			            CALCULATE(
			                MAX('Fx Rate DQ'[Func BS Rate]),
			                'Fx Rate DQ'[FX Join Key]=FuncToBaseFXJoinKey,
			                ALL('Fx Rate DQ')
			            )
			        )
			        RETURN
			        SUMX(
			            vSummarizeTableWithFXRate,
			            [@RealisedImpairmentLocal]*[@LocalToFuncFXRate]*[@FuncToBaseFXRate]
			        ),
			
			        SUMX (
			            'Securities Transaction GA Fact',
			            'Securities Transaction GA Fact'[Realised Impairment Local] * 'Fx Rate DQ'[Rep Rate]
			        )
			)
			
			```
		lineageTag: 06272f41-de9c-4d3d-83f6-77e8120e1f3d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

