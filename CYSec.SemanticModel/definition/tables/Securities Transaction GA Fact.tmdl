	measure 'Report Portfolio Value' = ```
			
			VAR test =
			    SUMX (
			        ADDCOLUMNS (
			            SUMMARIZE (
			                'Securities Transaction GA Fact',
			                'Securities Transaction GA Fact'[Portfolio Code & Name],
			                "test-sum",
			                AVERAGE ( 'Securities Transaction GA Fact'[Base Portfolio Value] )
			            ),
			            "test2", [test-sum]
			        ),
			        [test2]
			    )
			RETURN
			    test
			
			```
