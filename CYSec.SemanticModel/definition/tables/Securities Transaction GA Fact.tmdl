	measure 'Realized Gain/Loss - Rep (Sec Trans)' = ```
			
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        
			            SUMX(
			                SUMMARIZE(
			                    'Securities Transaction GA Fact',
			                    'Securities Transaction GA Fact'[Bus Trans Number],
			                    'Securities Transaction GA Fact'[Realized Gain/Loss - Base]
			                ),
			                'Securities Transaction GA Fact'[Realized Gain/Loss - Base]
			            )
			    ,
			    SUMX(
			        SUMMARIZE(
			            'Securities Transaction GA Fact',
			            'Securities Transaction GA Fact'[Bus Trans Number],
			            'Securities Transaction GA Fact'[Realized Gain/Loss - Local],
			            "@Rep Rate",[Rep Rate]
			        ),
			        'Securities Transaction GA Fact'[Realized Gain/Loss - Local]* [@Rep Rate]
			    )
			)
			
