	measure 'Realized Gain/Loss - Adjustment Rep (Sec Trans)' = ```
			
			// VAR vSelectedCurrency = SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency])
			// VAR vListofGLAccts=CALCULATETABLE(
			//             VALUES('CAT Adjmt Config Table'[GL Acct Num]),
			//             'CAT Adjmt Config Table'[Measure Name] ="Realized")
			// VAR vMaxSelectedDate=MAX(Period[Date])
			// VAR vDateRange = FILTER(ALL(Period[Date]),Period[Date]<=vMaxSelectedDate)
			// VAR vRRep= 
			// SUMX(summarize('Securities Transaction GA Fact',Securities[Primary Security ID]),
			// IF(calculate(COUNTROWS('Securities GL Txn fact'),vDateRange)>0 && (NOT ISBLANK(Securities[Primary Security ID])),
			// CALCULATE(
			//         SWITCH (
			//                 vSelectedCurrency,
			//                 "CAD",[Adjustment Amount (CAD)],
			//                 "USD",[Adjustment Amount (USD)],
			//                 "HKD",[Adjustment Amount (HKD)],
			//                 [Adjustment Amount (Func)]
			//         ),
			//     TREATAS(vListOfGLAccts,'Securities GL Txn fact'[Account]),
			//     TREATAS(VALUES('Securities Transaction GA Fact'[Transaction No]),'Securities GL Txn fact'[SCD Lot Id]),
			//     vDateRange
			// )
			// )
			// )
			// RETURN vRRep
			VAR vSelectedCurrency =
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			VAR vListofGLAccts =
			    CALCULATETABLE (
			        VALUES ( 'CAT Adjmt Config Table'[GL Acct Num] ),
			        'CAT Adjmt Config Table'[Measure Name] = "Realized"
			    )
			VAR vMaxSelectedDate =
			    MAX ( Period[Date] )
			VAR vMaxAsOfPeriod =
			    MAX ( 'Consolidated GL Balance Fact'[As of Period] )
			RETURN
			    IF (
			        ISEMPTY (
			            CALCULATETABLE (
			                'Consolidated GL Balance Fact',
			                Period[Date] = vMaxSelectedDate
			            )
			        ),
			        BLANK (),
			        SUMX (
			            VALUES ( Securities[Primary Security ID] ),
			            CALCULATE (
			                SWITCH (
			                    vSelectedCurrency,
			                    "CAD", [Adjustment_Amount (CAD)],
			                    "USD", [Adjustment_Amount (USD)],
			                    "HKD", [Adjustment_Amount (HKD)],
			                    [Adjustment_Amount (Func)]
			                ),
			                TREATAS ( vListofGLAccts, 'Consolidated GL Balance Fact'[GL Acct (6 digits)] ),
			                TREATAS (
			                    VALUES ( 'Securities Transaction GA Fact'[Transaction No] ),
			                    'Consolidated GL Balance Fact'[SCD Lot Id]
			                ),
			                Period[Date] = vMaxSelectedDate,
			                'Consolidated GL Balance Fact'[As of Period] = vMaxAsOfPeriod
			            )
			        )
			    )
			```
