	measure 'Transaction History Title' = ```
			
			VAR maxdate =
			    CALCULATE (
			        MAX ( 'Securities Transaction GA Fact'[Transasofdate] ),
			        ALLEXCEPT (
			            'Securities Transaction GA Fact',
			            'Securities Transaction GA Fact'[Transasofdate]
			        )
			    )
			RETURN
			    "Transaction History" & ", "
			        & SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) & ", "
			        & SELECTEDVALUE ( Framework[Framework Display] ) & ", "
			        & FORMAT ( maxdate, "dd-mmm-yy" )
			
			```
		isHidden
		displayFolder: Position Research Attributes
		lineageTag: 952e5478-7e4b-4c0f-ba86-f6c5ed21b7c4

	measure 'Units - Trans Level (TH)' = ```
			
			 
			VAR closePeriod =
			    MAX ( 'Period'[Period] )
			VAR calc =
			    CALCULATE(SUMX (
			            SUMMARIZE ('Securities Transaction GA Fact',
			'Securities Transaction GA Fact'[Company Code & Name Display],
			'Securities Transaction GA Fact'[Accounting Unit Code & Name Display],
			'Securities Transaction GA Fact'[Portfolio Code & Name],
			'Securities Transaction GA Fact'[Trans Type],
			'Securities Transaction GA Fact'[Primary Security ID (Sec Tran)],
			'Securities Transaction GA Fact'[Transaction No],
			                "test-sum",
			                    
			                           CALCULATE (
			        AVERAGE('Securities Transaction GA Fact'[Units]),
			        ALL ( 'Period' ),
			        'Securities Transaction GA Fact'[As Of Period] <= closePeriod
			    )
			                    
			            ),
			        [test-sum]
			    ),ALL ( 'Period' ))
			RETURN
			    calc
			
			```
