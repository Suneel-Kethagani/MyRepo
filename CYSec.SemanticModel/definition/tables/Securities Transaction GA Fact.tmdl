	measure 'Income Gross Amount - Trans Rep (Sec Trans)' = ```
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        SUMX(
			            VALUES('Securities Transaction GA Fact'[Transaction No]),
			            CALCULATE(MAX ( 'Securities Transaction GA Fact'[Income Gross Amount - Base] ))
			        ),
			            
			        SUMX(
			            SUMMARIZE(
			                ADDCOLUMNS(
			                    'Securities Transaction GA Fact',
			                    "@BVRepAmt",'Securities Transaction GA Fact'[Income Gross Amount - Local] * 'Fx Rate DQ'[Rep Rate]
			                ),
			            'Securities Transaction GA Fact'[Transaction No],[@BVRepAmt]
			            ),
			            [@BVRepAmt]
			        )
			)
