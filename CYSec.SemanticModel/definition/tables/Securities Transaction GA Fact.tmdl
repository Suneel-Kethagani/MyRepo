", "Realised Impairment Local"}, {"REALISED_IMPAIRMENT_SEC_BASE_CCY", "Realised Impairment Sec Base"}, {"REALISED_IMPAIRMENT_CCY_BASE_CCY", "Realised Impairment Ccy Base"}, {"dgl_inception_trans_no", "Dgl Inception Trans No"}, {"IFRS9PURPOSE", "IFRS9 Purpose"}, {"processing_group_nm", "Processing Group Name"}, {"changed_date", "Changed Date"}}),
