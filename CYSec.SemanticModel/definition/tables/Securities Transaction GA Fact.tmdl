	column From/To = ```
			
			SWITCH(TRUE(),
			    'Securities Transaction GA Fact'[Nominal Incoming Amount] <> 0, "To",
			    'Securities Transaction GA Fact'[Nominal Outgoing Amount] <> 0,"From",
			    BLANK ()
			    )
			
			```
