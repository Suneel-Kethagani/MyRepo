	measure 'Transfer Market Value Amt (Sec Trans)' =
			
			CALCULATE(
					SUMX(
						'Securities Transaction GA Fact',
						VAR vNominal = 'Securities Transaction GA Fact'[Lot Nominal]
						VAR vPosTransLink = VALUE('Securities Transaction GA Fact'[POS Trans Link])
						VAR vTradeDate = 'Securities Transaction GA Fact'[Trade Date]
						VAR vPrice = CALCULATE(
							MAX('Securities Position Fact'[Price - Local (D)]),
							ALL('Period'),
							'Period'[Date] = vTradeDate,
							'Securities Position Fact'[Src Position ID] = vPosTransLink
						)
						RETURN
							vPrice * vNominal
					),
					'Securities Transaction GA Fact'[Trans Type] IN {
						"Reallocation Custodian+Custody External",
						"Reallocation Custody and Portfolio",
						"Reallocation Custody Internal",
						"Reallocation free codes",
						"Reallocation, Model Portfolio",
						"Reallocation, Security No.",
						"Reallocation, Security No.SD",
						"Rev. Reallocation Custody and Portfolio",
						"Rev.Reallocation Custody",
						"Rev.Reallocation custody + custodian",
						"Rev.Reallocation free codes",
						"Rev.Reallocation security ID",
						"Rev.Reallocation security IDSD",
						"Rev.Reallocation, Model Portfolio"
					},
					'Securities Transaction GA Fact'[Transaction Purpose] IN {
						"Inter-Company",
						"Intra-Company"
					},
					'Securities Transaction GA Fact'[Trans Status] = "Active"
				)
		lineageTag: 3a0f7c9f-8ee9-4b59-881d-0533c0286dc8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Processing Group Name (Sec Trans)' =
			
			CALCULATE (
			    FIRSTNONBLANK ( 'Securities Transaction GA Fact'[Processing Group Name], TRUE () ),
			    CROSSFILTER ( 'Securities Transaction GA Fact'[Security NK], 'Securities'[Security NK], BOTH )
			)
		lineageTag: f96e569e-ce9f-46b0-babb-8731b56a9015

	measure 'Trading Philosophy Code - IAS39 (Sec Tran)' = ```
			
			VAR MaxAsOfDate = MAX(Period[Date])
			VAR PortfolioCodes = VALUES(Portfolios[Portfolio Code])
			VAR FrameworkCodes = VALUES(Framework[Framework Display])
			VAR AssetTypes = VALUES('Securities'[SCD GL Classification])
			VAR BusEffFromTo =
			    FILTER(
			        'Accounting Framework Philosophy',
			        'Accounting Framework Philosophy'[Bus Eff Date From] <= MaxAsOfDate &&
			        'Accounting Framework Philosophy'[Bus Eff Date To] > MaxAsOfDate
			    )
			RETURN
			IF(COUNTROWS('Securities Transaction GA Fact')>0,
			CALCULATE(
			    FIRSTNONBLANK('Accounting Framework Philosophy'[Trading Philosophy], TRUE()),
			    CROSSFILTER('Securities Transaction GA Fact'[Security NK], Securities[Security NK], BOTH),
			    TREATAS(PortfolioCodes, 'Accounting Framework Philosophy'[Portfolio Cd]),
			    TREATAS(FrameworkCodes, 'Accounting Framework Philosophy'[Accounting Framework]),
			    TREATAS(AssetTypes, 'Accounting Framework Philosophy'[Asset Type Cd]),
			    // TREATAS(BusEffFromTo,'Securities Transaction GA Fact'[Trade Date]),
			    BusEffFromTo,
			    KEEPFILTERS('Securities Transaction GA Fact'[Framework Code] = "IAS39")
			))
			 
			```
		lineageTag: c3a57792-d544-458a-8e3a-d8bef2ff58ec

