	measure 'Sublot AOCI - Local (Sec Trans)' = ```
			
			var vAoci_key =
			SUMMARIZE (
			    'Securities Transaction GA Fact',
			    'Securities Transaction GA Fact'[Originating System No],
			    'Securities Transaction GA Fact'[Match Src Transaction ID],
			    'Securities Transaction GA Fact'[Source Id],
			    'Securities Transaction GA Fact'[Portfolio Code],
			    'Securities Transaction GA Fact'[Bus Trans Number],
			    'Securities Transaction GA Fact'[Framework Code],
			    'Securities Transaction GA Fact'[Dgl Inception Trans No]
			)
			var vResult = 
			CALCULATE( 
			    SUM('Securities Transaction AOCI GA Fact'[Sublot AOCI - Local]),
			    TREATAS (
			        vAoci_key,
			        'Securities Transaction AOCI GA Fact'[Originating System No],
			        'Securities Transaction GA Fact'[Match Src Transaction ID],
			        'Securities Transaction AOCI GA Fact'[Src Transaction Id],
			        'Securities Transaction AOCI GA Fact'[Portfolio Code],
			        'Securities Transaction AOCI GA Fact'[Bus Trans no],
			        'Securities Transaction AOCI GA Fact'[Framework Code],
			        'Securities Transaction AOCI GA Fact'[Dgl Inception Trans No]
			    )
			)
			
			RETURN vResult
			```
		lineageTag: 3a363f09-1e05-441f-b167-a4b117c6214f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sublot AOCI - Rep (Sec Trans)' = ```
			
			var vAoci_key =
			SUMMARIZE (
			    'Securities Transaction GA Fact',
			    'Securities Transaction GA Fact'[Originating System No],
			    'Securities Transaction GA Fact'[Match Src Transaction ID],
			    'Securities Transaction GA Fact'[Source Id],
			    'Securities Transaction GA Fact'[Portfolio Code],
			    'Securities Transaction GA Fact'[Bus Trans Number],
			    'Securities Transaction GA Fact'[Framework Code],
			    'Securities Transaction GA Fact'[Dgl Inception Trans No]
			)
			var vResult = 
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			    CALCULATE( 
			        SUM('Securities Transaction AOCI GA Fact'[Sublot AOCI - Base]),
			        TREATAS (
			            vAoci_key,
			            'Securities Transaction AOCI GA Fact'[Originating System No],
			            'Securities Transaction GA Fact'[Match Src Transaction ID],
			            'Securities Transaction AOCI GA Fact'[Src Transaction Id],
			            'Securities Transaction AOCI GA Fact'[Portfolio Code],
			            'Securities Transaction AOCI GA Fact'[Bus Trans no],
			            'Securities Transaction AOCI GA Fact'[Framework Code],
			            'Securities Transaction AOCI GA Fact'[Dgl Inception Trans No]
			        )
			    ),
			    CALCULATE( 
			        SUMX(
			            'Securities Transaction AOCI GA Fact',
			            'Securities Transaction AOCI GA Fact'[Sublot AOCI - Local] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        TREATAS (
			            vAoci_key,
			            'Securities Transaction AOCI GA Fact'[Originating System No],
			            'Securities Transaction GA Fact'[Match Src Transaction ID],
			            'Securities Transaction AOCI GA Fact'[Src Transaction Id],
			            'Securities Transaction AOCI GA Fact'[Portfolio Code],
			            'Securities Transaction AOCI GA Fact'[Bus Trans no],
			            'Securities Transaction AOCI GA Fact'[Framework Code],
			            'Securities Transaction AOCI GA Fact'[Dgl Inception Trans No]
			        )
			    )
			)
			
			RETURN vResult
