			in
			    #"Filtered Rows - Incremental Refresh"

	measure '# of Transactions' = COUNT ( 'Securities Transaction GA Fact'[Transaction No] )
		formatString: #,0
		lineageTag: 11afa9bf-16d3-4906-aea1-3911a2baf20f

	measure 'Max of Post Hour' =
			
			Hour(MAX('Securities Transaction GA Fact'[Post Time]))
		formatString: 0
		lineageTag: 84812f66-1478-4e10-b707-7db68f750a48

	measure 'Security Transactions Title' = ```
			
			VAR maxdate =
			    MAX ( 'Securities Transaction GA Fact'[Transasofdate] )
			VAR mindate =
			    MIN ( 'Securities Transaction GA Fact'[Transasofdate] )
			VAR fw =
			    SELECTEDVALUE ( Framework[Framework Display] )
			VAR Rep =
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) 
			RETURN
			    "Security Transactions" & ", " & Rep & ", " & fw & ", "
			        & FORMAT ( mindate, "dd-mmm-yy" ) & " - "
			        & FORMAT ( maxdate, "dd-mmm-yy" )
			
			```
		lineageTag: 92bc6fd6-8e74-4a79-a411-f335f119492a

	measure 'Security Description (Sec Tran)' = ```
			
			CALCULATE (
			    FIRSTNONBLANK ( 'Securities'[Security Description], TRUE () ),
			    CROSSFILTER ( 'Securities Transaction GA Fact'[Security NK], 'Securities'[Security NK], BOTH )
			)
			
			```
		displayFolder: Security Values
		lineageTag: fb13ea9c-7b70-43a2-8d6e-c9f106f180e3

	measure '# Trans Src ID' = COUNT ( 'Securities Transaction GA Fact'[Source ID] )
		formatString: #,0
		lineageTag: b999f91c-0c34-4f5a-bef5-df95b7921745

	measure 'Reporting Currency (Security Transaction)' = ```
			
			VAR SelectedCurrency =
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			VAR ReportingCurrency =
			    IF (
			        NOT ISEMPTY ( 'Securities Transaction GA Fact' ),
			        IF (
			            SelectedCurrency = "Company",
			            FIRSTNONBLANK ( 'Securities Transaction GA Fact'[Functional Ccy Code], TRUE () ),
			            IF (
			                SelectedCurrency = "SCD Base",
			                FIRSTNONBLANK ( 'Securities Transaction GA Fact'[Base], TRUE () ),
			                SelectedCurrency
			            )
			        )
			    )
			RETURN
			    ReportingCurrency
			
			```
		lineageTag: 1bb67709-32da-4e82-82c2-fbef76edb227

	measure 'Rep Rate (Security Transaction)' = ```
			
			VAR maxd =
			    MAX ( 'Period'[Period] )
			VAR fxrate =
			    SWITCH (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			        "USD",
			            CALCULATE (
			                MIN ( 'Securities Transaction GA Fact'[Local To USD Rate] ),
			                FILTER (
			                    'Securities Transaction GA Fact',
			                    'Securities Transaction GA Fact'[As Of Period] = maxd
			                )
			            ),
			        "CAD",
			            CALCULATE (
			                MIN ( 'Securities Transaction GA Fact'[Local To CAD Rate] ),
			                FILTER (
			                    'Securities Transaction GA Fact',
			                    'Securities Transaction GA Fact'[As Of Period] = maxd
			                )
			            ),
			        "HKD",
			            CALCULATE (
			                MIN ( 'Securities Transaction GA Fact'[Local To HKD Rate] ),
			                FILTER (
			                    'Securities Transaction GA Fact',
			                    'Securities Transaction GA Fact'[As Of Period] = maxd
			                )
			            ),
			        "Company",
			            CALCULATE (
			                MIN ( 'Securities Transaction GA Fact'[Local To FUNC Rate] ),
			                FILTER (
			                    'Securities Transaction GA Fact',
			                    'Securities Transaction GA Fact'[As Of Period] = maxd
			                )
			            )
			        ,"SCD Base",
			            CALCULATE (
			                MIN ( 'Securities Transaction GA Fact'[Local Exchange Rate] ),
			                FILTER (
			                    'Securities Transaction GA Fact',
			                    'Securities Transaction GA Fact'[As Of Period] = maxd
			                )
			            )
			    )
			RETURN
			    fxrate
			
			
			```
		formatString: 0.000000
		lineageTag: 82a4ce43-ca73-4525-a849-d95a0309f985

	measure 'Amortized Cost - Rep (TH)' = ```
			
			VAR closePeriod =
			    MAX ( 'Period'[Period] )
			RETURN
			    CALCULATE (
			        IF (
				SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
				SUM ( 'Securities Transaction GA Fact'[Amortized Cost - Base] ),
			 SUMX (
			        'Securities Transaction GA Fact',
			        'Securities Transaction GA Fact'[Sec Amortization Cost Local]  * 'Fx Rate DQ'[Rep Rate]
			    )
				),
			        ALL ( 'Period' ),
			        'Securities Transaction GA Fact'[As Of Period] <= closePeriod
			    )
			
			```
		isHidden
		displayFolder: Position Research Attributes
		lineageTag: 400085c1-2a71-49a5-8aef-be07cedf10bf

