		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Price - Rep (PH)' = ```
			
			VAR Prd =
			    MAX ( 'Period'[Period] )
			RETURN
			    IF (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
			        CALCULATE (
			            AVERAGE ( 'Securities Position Fact'[Price - Base] ),
			            ALL ( 'Period' ),
			            'Securities Position Fact'[As Of Period] <= Prd
			        ),
			        CALCULATE (
			            AVERAGEX (
			                'Securities Position Fact',
			                'Securities Position Fact'[Price - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			            ),
			            ALL ( 'Period' ),
			            'Securities Position Fact'[As Of Period] <= Prd
			        )
			    )
			
			```
		isHidden
		displayFolder: Position Research Attributes
		lineageTag: c2d9d569-f85e-4325-b24d-a300f00cdddb

