	measure 'ECL/CECL Impairment - Position Local (Sec Pos)' = ```
			
			
			SWITCH(SELECTEDVALUE ( Framework[Framework] ),
			"IFRS9",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			            SUM ( 'Securities Position Fact'[Balance CL Allowance - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			    CALCULATE (
			                SUM ( 'Securities Position Fact'[Balance CL Allowance - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )),
			"USGAAP",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Position Fact'[Balance Recog CL Allowance - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			    CALCULATE (
			        SUM ( 'Securities Position Fact'[Balance Recog CL Allowance - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )),
			"IAS39",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Position Fact'[Balance Impairment - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			    CALCULATE (
			        SUM ( 'Securities Position Fact'[Balance Impairment - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )),
			"JGAAP",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Position Fact'[Balance Impairment - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			    CALCULATE(
			        SUM ( 'Securities Position Fact'[Balance Impairment - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )),
			"NAIC",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			        SUM ( 'Securities Position Fact'[Balance Impairment - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			    CALCULATE (
			        SUM ( 'Securities Position Fact'[Balance Impairment - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    ))
			,BLANK())
			/*VAR FW =
			    SELECTEDVALUE ( Framework[Framework] )
			VAR IFRS9_FW =
			    CALCULATE (
			        SUM ( 'Securities Position Fact'[Balance CL Allowance - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			        FILTER (
			            'Securities Position Fact',
			            'Securities Position Fact'[As Of Date] =  MAX('Securities Position Fact'[As Of Date])
			        )
			    )
			VAR USGAAP_FW =
			    CALCULATE (
			        SUM ( 'Securities Position Fact'[Balance Recog CL Allowance - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			        FILTER (
			            'Securities Position Fact',
			            'Securities Position Fact'[As Of Date] =  MAX('Securities Position Fact'[As Of Date])
			        )
			    )
			VAR IAS39_JGAAP_NAIC_FW =
			    CALCULATE (
			        SUM ( 'Securities Position Fact'[Balance Impairment - Local] )
			            + SUM ( 'Securities Position Fact'[Balance Write Off - Local] ),
			       FILTER (
			            'Securities Position Fact',
			            'Securities Position Fact'[As Of Date] =  MAX('Securities Position Fact'[As Of Date])
			        )
			    )
			RETURN
			    IF (
			        FW = "IFRS9",
			        IFRS9_FW,
			        IF (
			            FW = "USGAAP",
			            USGAAP_FW,
			            IF (
			                ( FW = "IAS39"
			                    || FW = "JGAAP"
			                    || FW = "NAIC" ),
			                IAS39_JGAAP_NAIC_FW,
			                BLANK ()
			            )
			        )
			    )*/
			
			```
		lineageTag: b5215e16-19ce-4c71-8890-2487771a8d7d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ECL/CECL Impairment - Position Rep (Sec Pos)' = ```
			
			VAR FW =
			    SELECTEDVALUE ( Framework[Framework] )
			VAR IFRS9_FW = 'Securities Position Fact'[Balance CL Allowance - Rep (Sec Pos)] + 'Securities Position Fact'[Balance Write Off - Rep (Sec Pos)]
			VAR USGAAP_FW = 'Securities Position Fact'[Balance Recog CL Allowance - Rep (Sec Pos)] + 'Securities Position Fact'[Balance Write Off - Rep (Sec Pos)]
			VAR IAS39_JGAAP_NAIC_FW = 'Securities Position Fact'[OTTI Impairment - Rep (Sec Pos)] + 'Securities Position Fact'[Balance Write Off - Rep (Sec Pos)]
			RETURN
			    SWITCH(
			        TRUE(),
			        FW = "IFRS9",IFRS9_FW,
			        FW = "USGAAP",USGAAP_FW,
			        FW = "IAS39"|| FW = "JGAAP"|| FW = "NAIC",IAS39_JGAAP_NAIC_FW,
			        BLANK ()    
			    )
			
			```
		lineageTag: 52da3671-e662-43ef-99d3-872f483924bc

