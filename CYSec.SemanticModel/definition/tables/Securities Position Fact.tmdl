				  spos.`AOCI_HEDGE_PAR` AS `AOCI Hedge Par`,
				  spos.`AOCI_REMAIN_BALANCE_NON_BV_CCY_BASE` AS `AOCI Remain Balance Non BV - Base`,
				  spos.`AOCI_REMAIN_BALANCE_NON_BV_CCY_LOCAL` AS `AOCI Remain Balance Non BV - Local (D)`,
				  spos.`AOCI_REMAIN_BALANCE_REP_CCY_BASE` AS `AOCI Remain Balance Rep - Base`,
				  spos.`AOCI_REMAIN_BALANCE_REP_CCY_LOCAL` AS `AOCI Remain Balance Rep - Local (D)`,
				  spos.`BALANCE_COMMITMENT_CCY_LOCAL` AS `Balance Commitment - Local`,
				  spos.`INCOME_DEFAULT_AMOUNT_CCY_LOCAL` AS `Income Default Amount - Local (D)`,
				  spos.`INCOME_DEFAULT_AMOUNT_CCY_BASE` AS `Income Default Amount - Base`,
				  spos.`NEXT_INTEREST_PAYMENT_CCY_LOCAL` AS `Next Interest Payment - Local`,
				  spos.`NEXT_INTEREST_PAYMENT_CCY_BASE` AS `Next Interest Payment - Base`,
				  spos.`NEXT_PRINCIPAL_PAYMENT_CCY_LOCAL` AS `Next Principal Payment - Local`,
				  spos.`NEXT_PRINCIPAL_PAYMENT_CCY_BASE` AS `Next Principal Payment - Base`,
				  spos.`BALANCE_UNPAID_COMMITMENT_CCY_LOCAL` AS `Balance Unpaid Commitment`,
				  spos.`POS_ACCRUAL_BASE` AS `Pos Accrual - Base`,
				  spos.`NEXT_DIVIDEND_CCY_LOCAL` AS `Next Dividend - Local (D)`,
				  spos.`BOOK_YIELD` AS `Current Yield Book Price (D)`,
				  spos.`CONVEXITY` AS `Convexity`,
				  spos.`CURRENT_YIELD` AS `Current Yield (D)`,
				  spos.`DIRTY_PRICE` AS `Dirty Price`,
