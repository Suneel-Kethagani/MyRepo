	measure 'Maturity Days (Sec Pos)' = ```
			
			var mat = 
			CALCULATE (
			    FIRSTNONBLANK ( 'Securities'[Maturity Days 2 (D)], TRUE () ),
			    CROSSFILTER ( 'Securities Position Fact'[Security NK], 'Securities'[Security NK], BOTH )
			)
			var calc = 
			IF (
			    mat < 0,
			    mat * -1,
			    mat
			)
