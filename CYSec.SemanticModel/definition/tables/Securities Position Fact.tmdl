	measure 'Trading Philosophy Code - IAS39 (Sec Pos)' =
			
			VAR MaxAsOfDate = MAX(Period[Date])
			VAR PortfolioCodes = VALUES(Portfolios[Portfolio Code])
			VAR FrameworkCodes = VALUES(Framework[Framework Display])
			VAR AssetTypes = VALUES('Securities'[SCD GL Classification])
			VAR BusEffFromTo =
			    FILTER(
			        'Accounting Framework Philosophy',
			        'Accounting Framework Philosophy'[Bus Eff Date From] <= MaxAsOfDate &&
			        'Accounting Framework Philosophy'[Bus Eff Date To] > MaxAsOfDate
			    )
			RETURN
			IF(COUNTROWS('Securities Position Fact')>0,
			CALCULATE(
			    FIRSTNONBLANK('Accounting Framework Philosophy'[Trading Philosophy], TRUE()),
			    CROSSFILTER('Securities Position Fact'[Security NK], Securities[Security NK], BOTH),
			    TREATAS(PortfolioCodes, 'Accounting Framework Philosophy'[Portfolio Cd]),
			    TREATAS(FrameworkCodes, 'Accounting Framework Philosophy'[Accounting Framework]),
			    TREATAS(AssetTypes, 'Accounting Framework Philosophy'[Asset Type Cd]),
			    // TREATAS(BusEffFromTo,'Securities Transaction GA Fact'[Trade Date]),
			    BusEffFromTo,
			    KEEPFILTERS('Securities Position Fact'[Framework Code] = "IAS39")
			))
		lineageTag: d0c7d23a-aef5-4473-aa89-3f70d35371da

	measure 'Trading Philosophy Code - JGAAP (Sec Pos)' =
			
			VAR MaxAsOfDate = MAX(Period[Date])
			VAR PortfolioCodes = VALUES(Portfolios[Portfolio Code])
			VAR FrameworkCodes = VALUES(Framework[Framework Display])
			VAR AssetTypes = VALUES('Securities'[SCD GL Classification])
