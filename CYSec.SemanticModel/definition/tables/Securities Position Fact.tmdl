	measure 'Fair Value Unaccrued - Rep (Indo Pos)' = ```
			
			--SCD Base price * Units
			VAR calc =
			    CALCULATE ( SUMX( 'Securities Position Fact','Securities Position Fact'[Price - Base]  * 'Securities Position Fact'[Units (D)]),
			        FILTER (
			            'Securities Position Fact',
			            'Securities Position Fact'[As Of Date]
			                = MAX ( 'Securities Position Fact'[As Of Date] )
			        )
			    )
			RETURN
			    calc
			
