	measure 'FV Final - Local (Sec Pos)' = ```
			
			VAR vIFRS9Purpose = SUMMARIZE('Securities Position Fact',Securities[Primary Security ID],'Securities Position Fact'[IFRS9 Purpose])
			VAR vIFRS9Chk = ADDCOLUMNS(vIFRS9Purpose,"@IFRS9_Chk",IF('Securities Position Fact'[IFRS9 Purpose] IN {"FVTPL","FVOCI"},1))
			VAR vIFRS9Max = ADDCOLUMNS(vIFRS9Chk,"@IFRS9_Max",CALCULATE(MAXX(vIFRS9Chk,[@IFRS9_Chk]),REMOVEFILTERS('Securities Position Fact'[IFRS9 Purpose])))
			
			VAR vIAS39Purpose = SUMMARIZE('Securities Position Fact',Securities[Primary Security ID],'Securities Position Fact'[Purpose])
			VAR vIAS39Chk = ADDCOLUMNS(vIAS39Purpose,"@IAS39_Chk",IF('Securities Position Fact'[Purpose] IN {"FVTPL","FVOCI","AFS"},1))
			VAR vIAS9Max = ADDCOLUMNS(vIAS39Chk,"@IAS39_Max",CALCULATE(MAXX(vIAS39Chk,[@IAS39_Chk]),REMOVEFILTERS('Securities Position Fact'[Purpose])))
			
			VAR vResult =
			SWITCH(
			    SELECTEDVALUE (Framework[Framework]),    
			    "IFRS9",    
			    SUMX(
			        SUMMARIZE('Securities Position Fact',[IFRS9 Purpose]),
			        IF([IFRS9 Purpose] IN {"FVTPL","FVOCI"},'Securities Position Fact'[Carrying Value - Local],[Fair Value Unaccrued - Local]
			        )
			    )+SUMX(SUMMARIZE(vIFRS9Max,Securities[Primary Security ID],[@IFRS9_Max]),IF([@IFRS9_Max]=1,[Carrying Value - Adjustment Local])),
			    "IAS39",
			    SUMX(
			        SUMMARIZE('Securities Position Fact',[Purpose]),
			        IF([Purpose] IN {"FVTPL","FVOCI","AFS"},'Securities Position Fact'[Carrying Value - Local],[Fair Value Unaccrued - Local]        
			        )
			    )+SUMX(SUMMARIZE(vIAS9Max,Securities[Primary Security ID],[@IAS39_Max]),IF([@IAS39_Max]=1,[Carrying Value - Adjustment Local]))
			    ,[Fair Value Unaccrued - Local]
			)
			
			RETURN vResult
			
			```
		lineageTag: 2713e153-31c0-41f3-83c8-b03ab5d5260b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'FV Final - Rep (Sec Pos)' = ```
			
			VAR vIFRS9Purpose = SUMMARIZE('Securities Position Fact',Securities[Primary Security ID],'Securities Position Fact'[IFRS9 Purpose])
			VAR vIFRS9Chk = ADDCOLUMNS(vIFRS9Purpose,"@IFRS9_Chk",IF('Securities Position Fact'[IFRS9 Purpose] IN {"FVTPL","FVOCI"},1))
			VAR vIFRS9Max = ADDCOLUMNS(vIFRS9Chk,"@IFRS9_Max",CALCULATE(MAXX(vIFRS9Chk,[@IFRS9_Chk]),REMOVEFILTERS('Securities Position Fact'[IFRS9 Purpose])))
			
			VAR vIAS39Purpose = SUMMARIZE('Securities Position Fact',Securities[Primary Security ID],'Securities Position Fact'[Purpose])
			VAR vIAS39Chk = ADDCOLUMNS(vIAS39Purpose,"@IAS39_Chk",IF('Securities Position Fact'[Purpose] IN {"FVTPL","FVOCI","AFS"},1))
			VAR vIAS9Max = ADDCOLUMNS(vIAS39Chk,"@IAS39_Max",CALCULATE(MAXX(vIAS39Chk,[@IAS39_Chk]),REMOVEFILTERS('Securities Position Fact'[Purpose])))
			
			VAR vResult =
			SWITCH(
			    SELECTEDVALUE (Framework[Framework]),    
			    "IFRS9",    
			    SUMX(
			        SUMMARIZE('Securities Position Fact',[IFRS9 Purpose]),
			        IF([IFRS9 Purpose] IN {"FVTPL","FVOCI"},'Securities Position Fact'[Carrying Value - Rep (Sec Pos)],[Fair Value Unaccrued - Rep (Sec Pos)]
			        )
			    )+SUMX(SUMMARIZE(vIFRS9Max,Securities[Primary Security ID],[@IFRS9_Max]),IF([@IFRS9_Max]=1,[Carrying Value - Adjustment Rep])),
			    "IAS39",
			    SUMX(
			        SUMMARIZE('Securities Position Fact',[Purpose]),
			        IF([Purpose] IN {"FVTPL","FVOCI","AFS"},'Securities Position Fact'[Carrying Value - Rep (Sec Pos)],[Fair Value Unaccrued - Rep (Sec Pos)]        
			        )
			    )+SUMX(SUMMARIZE(vIAS9Max,Securities[Primary Security ID],[@IAS39_Max]),IF([@IAS39_Max]=1,[Carrying Value - Adjustment Rep]))
			    ,[Fair Value Unaccrued - Rep (Sec Pos)]
			)
			
			RETURN vResult
			
			```
		lineageTag: 3d3f9f9e-0609-40b3-9486-ab24cff97bbb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

