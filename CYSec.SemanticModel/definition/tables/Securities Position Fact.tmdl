table 'Securities Position Fact'
	lineageTag: 3da8a732-fd5d-48f7-8975-8ac0112d39a7

	refreshPolicy
		policyType: basic
		rollingWindowGranularity: month
		rollingWindowPeriods: 16
		incrementalGranularity: month
		incrementalPeriods: 16
		pollingExpression = Securities_Position_Fact_PBI_Config
		sourceExpression = ```
			let
			LastNDays= Text.From(#"Last N Days Position Data"),
			Sql = "SELECT
			  spos.`SECURITY_NK` AS `Security NK`,
			  spos.`SECURITY_PAYMENT_NK` AS `Security Payment NK`,
			  spos.`AS_OF_DT` AS `As Of Date`,
			  spos.`AS_OF_PERIOD` AS `As Of Period`,
			  spos.`REGION` AS `Region`,
			  CAST(spos.`SRC_POSITION_ID` AS INT) AS `Src Position ID`,
			  spos.`SRC_SECURITY_ID` AS `Src Security ID`,
			  spos.`SRC_MARKET_ID` AS `Src Market ID`,
			  spos.`SRC_SECURITY` AS `Src Security`,
			  spos.`ASSET_PORTFOLIO_CODE` AS `Asset Portfolio Code`,
			  spos.`PORTFOLIO_GROUP_CODE` AS `Portfolio Group Code`,
			  spos.`PORTFOLIO_CD` AS `Portfolio Code`,
			  spos.`PORTFOLIO_NK` AS `Portfolio Nk`,
			  spos.`FRAMEWORK_CD` AS `Framework Code`,
			  spos.`GL_CLASS` AS `GL Class`,
			  spos.`WASH_SALE_PARENT_SECURITY_ID` AS `Wash Sale Parent Security ID`,
			  spos.`PORTFOLIO_CODE_NAME` AS `Portfolio Code & Name`,
			  spos.`ACCOUNTING_UNIT_CODE_NAME` AS `Accounting Unit Code & Name`,
			  spos.`COMPANY_CODE_NAME` AS `Company Code & Name`,
			  spos.`SCD_SECURITY_ID` AS `SCD Security ID`,
			  spos.`LEG` AS `Leg`,
			  spos.`CALCULATED_DATE` AS `Calculated Date`,
			  spos.`UNITS` AS `Units (D)`,
			  spos.`CONTRACTS` AS `Contracts`,
			  spos.`SETTLE_TRADE_BALANCE` AS `Settle Trade Balance`,
			  spos.`ORIGINAL_FACE` AS `Original Face (D)`,
			  spos.`POOL_FACTOR` AS `Pool Factor`,
			  spos.`UNIT_BASIS` AS `Unit Basis`,
			  spos.`NOMINAL` AS `Nominal (D)`,
			  spos.`QUOTE_FACTOR` AS `Quote Factor`,
			  spos.`CURRENT_FACE` AS `Current Face (D)`,
			  spos.`ACCRUED_MARKET_VALUE_BASE` AS `Fair Value Accrued - Base`,
			  spos.`MARKET_VALUE_BASE` AS `Fair Value Unaccrued - Base`,
			  spos.`COST_BASE` AS `Original Cost - Base`,
			  spos.`PRICE_BASE` AS `Price - Base`,
			  spos.`UNIT_COST_BASE` AS `Unit Cost - Base`,
			  spos.`UNREALIZED_ON_CURRENCY_BASE` AS `Unrealized Gain/Loss CCY - Base`,
			  spos.`UNREALIZED_ON_INVESTMENT_BASE` AS `Unrealized Gain/Loss Sec - Base`,
			  spos.`UNREALIZED_BASE` AS `Unrealized Gain/Loss - Base`,
			  spos.`ACCRUAL_BASE` AS `Accrual - Base`,
			  spos.`WITHELD_AMOUNT_BASE` AS `Withheld - Base`,
			  spos.`WITHHOLDING_RATE` AS `Withholding Rate`,
			  spos.`LOCAL_EXCHANGE_RATE` AS `Local Exchange Rate`,
			  spos.`ACCRUED_MARKET_VALUE_LOCAL` AS `Fair Value Accrued - Local (D)`,
			  spos.`ACCOUNTING_STATUS` AS `Accounting Status`,
			  spos.`PORTFOLIO_CALCULATION` AS `Portfolio Calculation`,
			  spos.`MARKET_VALUE_LOCAL` AS `Fair Value Unaccrued - Local (D)`,
			  spos.`PRICE_LOCAL` AS `Price - Local (D)`,
			  spos.`COST_LOCAL` AS `Original Cost - Local (D)`,
			  spos.`UNIT_COST_LOCAL` AS `Unit Cost - Local (D)`,
			  spos.`UNREALIZED_ON_CURRENCY_LOCAL` AS `Unrealized Gain/Loss CCY - Local (D)`,
			  spos.`UNREALIZED_ON_INVESTMENT_LOCAL` AS `Unrealized Gain/Loss Sec - Local (D)`,
			  spos.`UNREALIZED_LOCAL` AS `Unrealized Gain/Loss - Local (D)`,
			  spos.`ACCRUAL_LOCAL` AS `Accrual - Local (D)`,
			  spos.`WITHELD_AMOUNT_LOCAL` AS `Withheld - Local (D)`,
			  spos.`AMORTIZED_COST_BASE` AS `Amortized Cost - Base`,
			  spos.`AMORTIZED_COST_LOCAL` AS `Amortized Cost - Local (D)`,
			  spos.`YIELD` AS `Yield`,
			  spos.`YIELD_TO_WORST` AS `Yield To Worst`,
			  spos.`UNDERLIER_SECURITY_NK` AS `Underlier Security Nk`,
			  spos.`LOCAL_CCY_CD` AS `Local`,
