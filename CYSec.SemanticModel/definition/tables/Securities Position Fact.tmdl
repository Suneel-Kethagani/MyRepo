				  spos.`BALANCE_IMPAIRMENT_CCY_BASE` AS `Balance Impairment - Base`,
				  spos.`AOCI_REMAIN_BALANCE_BV_CCY_LOCAL` AS `AOCI Remain Balance BV - Local (D)`,
				  spos.`AOCI_REMAIN_BALANCE_BV_CCY_BASE` AS `AOCI Remain Balance BV - Base`,
				  spos.`BALANCE_DEFERRED_PL_CCY_LOCAL` AS `Balance Deferred PL - Local (D)`,
				  spos.`BALANCE_DEFERRED_PL_CCY_BASE` AS `Balance Deferred PL - Base`,
				  spos.`INCOME_ACCRUAL_CCY_LOCAL` AS `Income Accrual - Local (D)`,
				  spos.`INCOME_ACCRUAL_CCY_BASE` AS `Income Accrual - Base`,
				  spos.`BALANCE_EXPECTED_RESTITUT_CCY_LOCAL` AS `Balance Expected Restitution - Local`,
				  spos.`BALANCE_EXPECTED_RESTITUT_CCY_BASE` AS `Balance Expected Restitution - Base`,
				  spos.`CARRYING_VALUE_CCY_LOCAL` AS `Carrying Value - Local (D)`,
				  spos.`CARRYING_VALUE_CCY_BASE` AS `Carrying Value - Base`,
				  spos.`UPDATED_TS` AS `Updated Ts`,
				  spos.`ADJUSTED_BOOK_VALUE_LOCAL` AS `Adjusted Book Value Local`,
				  spos.`ADJUSTED_BOOK_VALUE_BASE` AS `Adjusted Book Value Base`,
				  spos.`ISSUER_LONG_COMP_NAME` AS `SCD Issuer Long Company Name`,
				  spos.`SCD_DEFAULT_DATE` AS `SCD Default Date`,
				  spos.`SCD_DEFAULT_DATE_FC` AS `Accrue In Default`,
				  spos.`UNSETTLED_INT_DIV_AMOUNT_BASE_CCY` AS `Unsettled Int Div Amount Base CCY`,
				  spos.`UNSETTLED_INT_DIV_AMOUNT_LOCAL_CCY` AS `Unsettled Int Div Amount Local CCY`,
				  spos.`BALANCE_ACQUISITION_PRE_DIS_BASE_CCY` AS `Balance Acquisition Pre Dis Base CCY`,
				  spos.`BALANCE_ACQUISITION_PRE_DIS_LOCAL_CCY` AS `Balance Acquisition Pre Dis Local CCY`,
				  spos.`PURPOSE` AS `Purpose`,
				  spos.`IFRS9PURPOSE` AS `IFRS9 Purpose`,
				  spos.`BALANCE_BOOK_VALUE_LOCAL_CCY_NATIVE` AS `Balance Book Value Local Native`,
				  spos.`BALANCE_BOOK_VALUE_BASE_CCY_NATIVE` AS `Balance Book Value Base Native`,
				  spos.`CALCULATION_DATE_FULL` AS `Calculation Date Full`,
				  spos.`LONG_SHORT_INDICATOR` AS `Long Short Indicator`,
				  spos.`ACCRUED_INTEREST_EOP_LOCAL_CCY` AS `Accrued Interest EOP Local`,
				  spos.`ACCRUED_INTEREST_EOP_BASE_CCY` AS `Accrued Interest EOP Base`,
				  spos.`BALANCE_RETURN_OF_CAPITAL_BASE_CCY` AS `Balance Return Of Capital Base`,
				  spos.`BALANCE_RETURN_OF_CAPITAL_LOCAL_CCY` AS `Balance Return Of Capital Local`,
				  spos.`BALANCE_CALLED_CAPITAL_BASE_CCY` AS `Balance Called Capital Base`,
				  spos.`BALANCE_CALLED_CAPITAL_LOCAL_CCY` AS `Balance Called Capital Local`,
				  spos.`BALANCE_RECALLABLE_BASE_CCY` AS `Balance Recallable Base`,
				  spos.`BALANCE_RECALLABLE_LOCAL_CCY` AS `Balance Recallable Local`,
				  spos.`FX_JOIN_KEY` AS `FX Join Key`,
				  spos.`BALANCE_NAIC_CARRYING_VALUE_LOCAL_CCY` AS `Balance NAIC Carrying Value Local`,
				  spos.`BALANCE_NAIC_CARRYING_VALUE_BASE_CCY` AS `Balance NAIC Carrying Value Base`,
				  spos.`BALANCE_NAIC_SEC_ADJ_LOCAL_CCY` AS `Balance NAIC Sec Adj Local`,
				  spos.`BALANCE_NAIC_SEC_ADJ_BASE_CCY` AS `Balance NAIC Sec Adj Base`,
				  spos.`CALCULATED_UNREALIZED_GAIN_LOSS_LOCAL` AS `Calculated Unrealized Gain/Loss – Local`,
				  spos.`ML_BUSINESS_GROUP` AS `ML Business Group`,
				  spos.`SCD_GL_CLASSIFICATION` AS `SCD GL Classification`,
				  spos.`issue_volume` AS `Issue Volume`,
				  spos.`structure` AS `Structure`,
				  spos.`ACCRUED_INTEREST_QC_STATIC` AS `Accrued Interest QC (Static)`,
				  spos.`ACCRUED_INTEREST_PC_STATIC` AS `Accrued Interest PC (Static)`
				from "&Catalog&".inv_semantic_ga.SECURITIES_POSITION_FACT_DQ as spos
				where 
				(
				    (
				        (as_of_dt=last_day(as_of_dt)) or 
				        datediff((select max(as_of_dt) from "&Catalog&".inv_semantic_ga.SECURITIES_POSITION_FACT_DQ),as_of_dt) <="&LastNDays&
				    ")"&
				    " and ( as_of_dt >= '"&Date.ToText(Date.From(RangeStart),"yyyy-M-d")&"' and as_of_dt<'"&Date.ToText(Date.From(RangeEnd),"yyyy-M-d") &"' )"&
				    " and ( as_of_dt >= '"&Date.ToText(Date.From(pCutOffDate),"yyyy-M-d")&"')"&
				")",
				    Source = Value.NativeQuery(Databricks.Catalogs(HostName, HTTPPath, [Catalog=null, Database=null, EnableAutomaticProxyDiscovery=null,CommandTimeout= #duration(0,5,0,0)]){[Name=Catalog,Kind="Database"]}[Data], Sql, null, [EnableFolding=true]),
				    #"Filtered Rows" = Table.SelectRows(Source, each true)
				in
				    #"Filtered Rows"
				```

