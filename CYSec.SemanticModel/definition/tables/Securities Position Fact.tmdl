	measure 'Income Impairment - Local (Sec Pos)' =
			
			IF (
			    COUNTROWS ( 'Securities Position Fact' ) > 0,
			    CALCULATE (
			        SUM ( 'Securities Transaction GA Fact'[Book Value - Local unsigned] ) * -1,
			        //Step1: Identify the impairments for the position
			        TREATAS (
			            VALUES ( 'Securities Position Fact'[Src Position ID] ),
			            'Securities Transaction GA Fact'[POS Trans Link]
			        ),
			        'Securities Transaction GA Fact'[Bus Trans Code] = "TaxLotCorr",
			        'Securities Transaction GA Fact'[Transaction Purpose]
			            IN { "Income Impairment Reversal", "Income Impairment" },
			        'Securities Transaction GA Fact'[Trans Status] = "Active",
			        //Step2: Aggregate the cummulative impairment for the position
			        FILTER (
			            ALL ( Period[Date] ),
			            Period[Date] <= MAX ( Period[Date] )
			        ),
			        ALLSELECTED ( Securities ),
			        VALUES ( Securities[Primary Security ID] )
			    )
			)
		lineageTag: 6da94c57-e7f0-45c5-b1da-504327b38373

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Income Impairment - Rep (Sec Pos)' =
			
			IF (
			    COUNTROWS ( 'Securities Position Fact' ) > 0,
			    CALCULATE (
			        SWITCH (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			            "SCD Base", SUM ( 'Securities Transaction GA Fact'[Book Value - Base unsigned] ) * -1,
			            SUMX (
			                'Securities Transaction GA Fact',
			                'Securities Transaction GA Fact'[Book Value - Local unsigned] * [Rep Rate]
			            ) * -1
			        ),
			        //Step1: Identify the impairments for the position
			        TREATAS (
			            VALUES ( 'Securities Position Fact'[Src Position ID] ),
			            'Securities Transaction GA Fact'[POS Trans Link]
			        ),
			        'Securities Transaction GA Fact'[Bus Trans Code] = "TaxLotCorr",
			        'Securities Transaction GA Fact'[Transaction Purpose]
			            IN { "Income Impairment Reversal", "Income Impairment" },
			        'Securities Transaction GA Fact'[Trans Status] = "Active",
			        //Step2: Aggregate the cummulative impairment for the position
			        FILTER (
			            ALL ( Period[Date] ),
			            Period[Date] <= MAX ( Period[Date] )
			        ),
			        ALLSELECTED ( Securities ),
			        VALUES ( Securities[Primary Security ID] )
			    )
			)
		lineageTag: 95bb2fe5-654a-4c1e-bc68-148810bb8180

		annotation PBI_FormatHint = {"isGeneralNumber":true}

