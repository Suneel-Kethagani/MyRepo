			bv = "Original Book Value",
			    SUM('Securities Position Fact'[Fair Value Unaccrued - Local (D)])-SUM('Securities Position Fact'[Original Cost - Local (D)]),
			curr in {"IDR","JPY","KRW","VND"},
			    ROUND(SUM('Securities Position Fact'[Fair Value Unaccrued - Local (D)])-SUM('Securities Position Fact'[Book Value - Local (D)]),0),
