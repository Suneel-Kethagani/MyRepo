			  spos.`LOCAL_TO_HKD_RATE` AS `Local to HKD Rate`,
			  spos.`NEXT_COUPON_AMOUNT` AS `Next Coupon Amount (D)`,
			  spos.`AOCI_HEDGE_PAR` AS `AOCI Hedge Par`,
			  spos.`AOCI_REMAIN_BALANCE_NON_BV_CCY_BASE` AS `AOCI Remain Balance Non BV - Base`,
			  spos.`AOCI_REMAIN_BALANCE_NON_BV_CCY_LOCAL` AS `AOCI Remain Balance Non BV - Local (D)`,
			  spos.`AOCI_REMAIN_BALANCE_REP_CCY_BASE` AS `AOCI Remain Balance Rep - Base`,
			  spos.`AOCI_REMAIN_BALANCE_REP_CCY_LOCAL` AS `AOCI Remain Balance Rep - Local (D)`,
			  spos.`BALANCE_COMMITMENT_CCY_LOCAL` AS `Balance Commitment - Local`,
			  spos.`INCOME_DEFAULT_AMOUNT_CCY_LOCAL` AS `Income Default Amount - Local (D)`,
			  spos.`INCOME_DEFAULT_AMOUNT_CCY_BASE` AS `Income Default Amount - Base`,
			  spos.`NEXT_INTEREST_PAYMENT_CCY_LOCAL` AS `Next Interest Payment - Local`,
			  spos.`NEXT_INTEREST_PAYMENT_CCY_BASE` AS `Next Interest Payment - Base`,
			  spos.`NEXT_PRINCIPAL_PAYMENT_CCY_LOCAL` AS `Next Principal Payment - Local`,
			  spos.`NEXT_PRINCIPAL_PAYMENT_CCY_BASE` AS `Next Principal Payment - Base`,
			  spos.`BALANCE_UNPAID_COMMITMENT_CCY_LOCAL` AS `Balance Unpaid Commitment`,
			  spos.`POS_ACCRUAL_BASE` AS `Pos Accrual - Base`,
			  spos.`NEXT_DIVIDEND_CCY_LOCAL` AS `Next Dividend - Local (D)`,
			  spos.`BOOK_YIELD` AS `Current Yield Book Price (D)`,
			  spos.`CONVEXITY` AS `Convexity`,
			  spos.`CURRENT_YIELD` AS `Current Yield (D)`,
			  spos.`DIRTY_PRICE` AS `Dirty Price`,
			  spos.`MODIFIED_DURATION_YTM` AS `Modified Duration YTM`,
			  spos.`MODIFIED_DURATION_YC` AS `Modified Duration YC`,
			  spos.`ORIGINAL_BOOK_YIELD` AS `Original Book Yield (D)`,
			  spos.`BALANCE_COST_VALUE_CCY_LOCAL` AS `Balance Cost Value - Local`,
			  spos.`BALANCE_COST_VALUE_CCY_BASE` AS `Balance Cost Value - Base`,
			  spos.`BALANCE_BOOK_VALUE_CCY_LOCAL` AS `Book Value - Local (D)`,
			  spos.`BALANCE_BOOK_VALUE_CCY_BASE` AS `Book Value - Base`,
			  spos.`BALANCE_INT_APPR_CCY_LOCAL` AS `Balance Int Appr - Local`,
			  spos.`BALANCE_INT_APPR_CCY_BASE` AS `Balance Int Appr - Base`,
			  spos.`BALANCE_OID_APPR_CCY_LOCAL` AS `Balance OID Appr - Local`,
			  spos.`BALANCE_OID_APPR_CCY_BASE` AS `Balance OID Appr - Base`,
			  spos.`BALANCE_CL_ALLOWANCE_CCY_LOCAL` AS `Balance CL Allowance - Local`,
			  spos.`BALANCE_CL_ALLOWANCE_CCY_BASE` AS `Balance CL Allowance - Base`,
			  spos.`BALANCE_RECOG_CL_ALLOWANCE_CCY_LOCAL` AS `Balance Recog CL Allowance - Local`,
			  spos.`BALANCE_RECOG_CL_ALLOWANCE_CCY_BASE` AS `Balance Recog CL Allowance - Base`,
			  spos.`BALANCE_WRITE_OFF_CCY_LOCAL` AS `Balance Write Off - Local`,
			  spos.`BALANCE_WRITE_OFF_CCY_BASE` AS `Balance Write Off - Base`,
			  spos.`BALANCE_IMPAIRMENT_CCY_LOCAL` AS `Balance Impairment - Local`,
			  spos.`BALANCE_IMPAIRMENT_CCY_BASE` AS `Balance Impairment - Base`,
			  spos.`AOCI_REMAIN_BALANCE_BV_CCY_LOCAL` AS `AOCI Remain Balance BV - Local (D)`,
			  spos.`AOCI_REMAIN_BALANCE_BV_CCY_BASE` AS `AOCI Remain Balance BV - Base`,
			  spos.`BALANCE_DEFERRED_PL_CCY_LOCAL` AS `Balance Deferred PL - Local (D)`,
			  spos.`BALANCE_DEFERRED_PL_CCY_BASE` AS `Balance Deferred PL - Base`,
			  spos.`INCOME_ACCRUAL_CCY_LOCAL` AS `Income Accrual - Local (D)`,
			  spos.`INCOME_ACCRUAL_CCY_BASE` AS `Income Accrual - Base`,
			  spos.`BALANCE_EXPECTED_RESTITUT_CCY_LOCAL` AS `Balance Expected Restitution - Local`,
			  spos.`BALANCE_EXPECTED_RESTITUT_CCY_BASE` AS `Balance Expected Restitution - Base`,
			  spos.`CARRYING_VALUE_CCY_LOCAL` AS `Carrying Value - Local (D)`,
			  spos.`CARRYING_VALUE_CCY_BASE` AS `Carrying Value - Base`,
			  spos.`UPDATED_TS` AS `Updated Ts`,
			  spos.`ADJUSTED_BOOK_VALUE_LOCAL` AS `Adjusted Book Value Local`,
			  spos.`ADJUSTED_BOOK_VALUE_BASE` AS `Adjusted Book Value Base`,
			  spos.`ISSUER_LONG_COMP_NAME` AS `SCD Issuer Long Company Name`,
			  spos.`SCD_DEFAULT_DATE` AS `SCD Default Date`,
			  spos.`SCD_DEFAULT_DATE_FC` AS `Accrue In Default`,
			  spos.`UNSETTLED_INT_DIV_AMOUNT_BASE_CCY` AS `Unsettled Int Div Amount Base CCY`,
			  spos.`UNSETTLED_INT_DIV_AMOUNT_LOCAL_CCY` AS `Unsettled Int Div Amount Local CCY`,
			  spos.`BALANCE_ACQUISITION_PRE_DIS_BASE_CCY` AS `Balance Acquisition Pre Dis Base CCY`,
			  spos.`BALANCE_ACQUISITION_PRE_DIS_LOCAL_CCY` AS `Balance Acquisition Pre Dis Local CCY`,
			  spos.`PURPOSE` AS `Purpose`,
			  spos.`IFRS9PURPOSE` AS `IFRS9 Purpose`,
			  spos.`BALANCE_BOOK_VALUE_LOCAL_CCY_NATIVE` AS `Balance Book Value Local Native`,
			  spos.`BALANCE_BOOK_VALUE_BASE_CCY_NATIVE` AS `Balance Book Value Base Native`,
			  spos.`CALCULATION_DATE_FULL` AS `Calculation Date Full`,
			  spos.`LONG_SHORT_INDICATOR` AS `Long Short Indicator`,
			  spos.`ACCRUED_INTEREST_EOP_LOCAL_CCY` AS `Accrued Interest EOP Local`,
			  spos.`ACCRUED_INTEREST_EOP_BASE_CCY` AS `Accrued Interest EOP Base`,
			  spos.`BALANCE_RETURN_OF_CAPITAL_BASE_CCY` AS `Balance Return Of Capital Base`,
			  spos.`BALANCE_RETURN_OF_CAPITAL_LOCAL_CCY` AS `Balance Return Of Capital Local`,
			  spos.`BALANCE_CALLED_CAPITAL_BASE_CCY` AS `Balance Called Capital Base`,
			  spos.`BALANCE_CALLED_CAPITAL_LOCAL_CCY` AS `Balance Called Capital Local`,
			  spos.`BALANCE_RECALLABLE_BASE_CCY` AS `Balance Recallable Base`,
			  spos.`BALANCE_RECALLABLE_LOCAL_CCY` AS `Balance Recallable Local`,
			  spos.`FX_JOIN_KEY` AS `FX Join Key`,
			  spos.`BALANCE_NAIC_CARRYING_VALUE_LOCAL_CCY` AS `Balance NAIC Carrying Value Local`,
			  spos.`BALANCE_NAIC_CARRYING_VALUE_BASE_CCY` AS `Balance NAIC Carrying Value Base`,
			  spos.`BALANCE_NAIC_SEC_ADJ_LOCAL_CCY` AS `Balance NAIC Sec Adj Local`,
			  spos.`BALANCE_NAIC_SEC_ADJ_BASE_CCY` AS `Balance NAIC Sec Adj Base`,
			  spos.`CALCULATED_UNREALIZED_GAIN_LOSS_LOCAL` AS `Calculated Unrealized Gain/Loss – Local`,
			  spos.`ML_BUSINESS_GROUP` AS `ML Business Group`,
			  spos.`SCD_GL_CLASSIFICATION` AS `SCD GL Classification`,
			  spos.`issue_volume` AS `Issue Volume`,
			  spos.`structure` AS `Structure`,
			  spos.`ACCRUED_INTEREST_QC_STATIC` AS `Accrued Interest QC (Static)`,
			  spos.`ACCRUED_INTEREST_PC_STATIC` AS `Accrued Interest PC (Static)`
			from "&Catalog&".inv_semantic_ga.SECURITIES_POSITION_FACT_DQ as spos
			where 
			(
			    (
			        (as_of_dt=last_day(as_of_dt)) or 
			        datediff((select max(as_of_dt) from "&Catalog&".inv_semantic_ga.SECURITIES_POSITION_FACT_DQ),as_of_dt) <="&LastNDays&
			    ")"&
			    " and ( as_of_dt >= '"&Date.ToText(Date.From(RangeStart),"yyyy-M-d")&"' and as_of_dt<'"&Date.ToText(Date.From(RangeEnd),"yyyy-M-d") &"' )"&
			    " and ( as_of_dt >= '"&Date.ToText(Date.From(pCutOffDate),"yyyy-M-d")&"')"&
			")",
			    Source = Value.NativeQuery(Databricks.Catalogs(HostName, HTTPPath, [Catalog=null, Database=null, EnableAutomaticProxyDiscovery=null,CommandTimeout= #duration(0,5,0,0)]){[Name=Catalog,Kind="Database"]}[Data], Sql, null, [EnableFolding=true]),
			    #"Filtered Rows" = Table.SelectRows(Source, each true)
			in
			    #"Filtered Rows"
			```

	measure 'Security Position Title' = ```
			
			VAR maxdate =
			    MAX ( 'Securities Position Fact'[As Of Date] )
			RETURN
			    "Security Position" & ", "
			        & SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) & ", "
			        & SELECTEDVALUE ( Framework[Framework Display] ) & ", "
			        & FORMAT ( maxdate, "dd-mmm-yy" )
			
			```
		lineageTag: fa1daf8d-ffc3-465a-a222-8436c193afd3

	measure 'Reporting Currency (Security Position)' = ```
			
			VAR SelectedCurrency =
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			VAR ReportingCurrency =
			    IF (
			        NOT ISEMPTY ( 'Securities Position Fact' ),
			        IF (
			            SelectedCurrency = "Company",
			            FIRSTNONBLANK ( 'Securities Position Fact'[Functional Ccy Code], TRUE () ),
			            IF (
			                SelectedCurrency = "SCD Base",
			                FIRSTNONBLANK ( 'Securities Position Fact'[Base], TRUE () ),
			                SelectedCurrency
			            )
			        )
			    )
			RETURN
			    ReportingCurrency
			
			```
		lineageTag: ec12969e-9a03-4452-9249-b0bad4baaa35

	measure 'Rep Rate (Security Position)' = ```
			
			VAR maxd =
			    MAX ( 'Period'[Period] )
			VAR fxrate =
			    SWITCH (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			        "USD",
			            CALCULATE (
			                MIN ( 'Securities Position Fact'[Local to USD Rate] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Period] = maxd
			                )
			            ),
			        "CAD",
			            CALCULATE (
			                MIN ( 'Securities Position Fact'[Local to CAD Rate] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Period] = maxd
			                )
			            ),
			        "HKD",
			            CALCULATE (
			                MIN ( 'Securities Position Fact'[Local to HKD Rate] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Period] = maxd
			                )
			            ),
			        "Company",
			            CALCULATE (
			                MIN ( 'Securities Position Fact'[Local to Func Rate] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Period] = maxd
			                )
			            ),
			        "SCD Base",
			            CALCULATE (
			                MIN ( 'Securities Position Fact'[Local Exchange Rate] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Period] = maxd
			                )
			            )
			    )
			RETURN
			    fxrate
			
			```
		formatString: 0.000000
		lineageTag: 9fc8528b-3f4e-425e-b775-ddf4708a6b28

	measure 'Fair Value Accrued - Rep (Sec Pos)' = ```
			
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Position Fact'[Fair Value Accrued - Base]),
			    CALCULATE (
			        SUM('Securities Position Fact'[Fair Value Accrued - Base]),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			),
			
			 IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX('Securities Position Fact', 'Securities Position Fact'[Fair Value Accrued - Local (D)]* 'Fx Rate DQ'[Rep Rate] ),
			
			            CALCULATE (
			                    SUMX('Securities Position Fact', 'Securities Position Fact'[Fair Value Accrued - Local (D)]* 'Fx Rate DQ'[Rep Rate] ),
			                LASTDATE('Securities Position Fact'[As Of Date])
			            )
			        ))
