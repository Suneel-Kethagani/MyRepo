			//              "CAD",[Adjustment Amount (CAD)],
			//                 "USD",[Adjustment Amount (USD)],
			//                 "HKD",[Adjustment Amount (HKD)],
			//                 [Adjustment Amount (Func)]
			//      ),
			//  TREATAS(vListOfGLAccts,'Securities GL Txn fact'[Account]),
			//  vDateRange
			//  )
			// )
			// )
			// RETURN VResult
			VAR vSelectedCurrency = SELECTEDVALUE ('Reporting Currency'[Rep In Currency])
			VAR vListofGLAccts=CALCULATETABLE(
			            VALUES('CAT Adjmt Config Table'[GL Acct Num]),
			            'CAT Adjmt Config Table'[Measure Name] ="Unrealized")
			
			VAR vMaxSelectedDate =
			    MAX ( Period[Date] )
			VAR vMaxAsOfPeriod =
			    MAX ( 'Consolidated GL Balance Fact'[As of Period] )
			RETURN
			    IF (
			        ISEMPTY (
			            CALCULATETABLE (
			                'Consolidated GL Balance Fact',
			                Period[Date] = vMaxSelectedDate
			            )
			        ),
			        BLANK (),
			        SUMX (
			            VALUES ( Securities[Primary Security ID] ),
			            CALCULATE (
			                SWITCH (
			                    vSelectedCurrency,
			                    "CAD", [Adjustment_Amount (CAD)],
			                    "USD", [Adjustment_Amount (USD)],
			                    "HKD", [Adjustment_Amount (HKD)],
			                    [Adjustment_Amount (Func)]
			                ),
			                TREATAS ( vListOfGLAccts, 'Consolidated GL Balance Fact'[GL Acct (6 digits)] ),
			                Period[Date] = vMaxSelectedDate,
			                'Consolidated GL Balance Fact'[As of Period] = vMaxAsOfPeriod
			            )
			        )
			    )
			```
		lineageTag: 3c2855ea-09ec-47d8-ad14-c55fcfd52e22

