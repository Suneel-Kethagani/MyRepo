	measure 'Income Impairment Details - Local (Sec Pos)' = ```
			
			    CALCULATE (
			        SUM ( 'Securities Transaction GA Fact'[Book Value - Local unsigned] ) * -1,
			        //Step1: Identify the impairments for the position
			        /*TREATAS (
			            VALUES ( 'Securities Position Fact'[Src Position ID] ),
			            'Securities Transaction GA Fact'[POS Trans Link]
			        ),*/
			        'Securities Transaction GA Fact'[Bus Trans Code] = "TaxLotCorr",
			        'Securities Transaction GA Fact'[Transaction Purpose]
			            IN { "Income Impairment Reversal", "Income Impairment" },
			        'Securities Transaction GA Fact'[Trans Status] = "Active",
			        //Step2: Aggregate the cummulative impairment for the position
			        FILTER (
			            ALL ( Period[Date] ),
			            Period[Date] <= MAX ( Period[Date] )
			        ),
			    ALLSELECTED ( Securities ),
			        VALUES ( Securities[Primary Security ID] )
			    )
			
			```
		lineageTag: 9a1ab2bc-f79a-4ff9-a73e-c782014162f0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Income Impairment Details - Rep (Sec Pos)' = ```
			
			    CALCULATE (
			        SWITCH (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			            "SCD Base", SUM ( 'Securities Transaction GA Fact'[Book Value - Base unsigned] ) * -1,
			            SUMX (
			                'Securities Transaction GA Fact',
			                'Securities Transaction GA Fact'[Book Value - Local unsigned] * [Rep Rate]
			            ) * -1
			        ),
			        //Step1: Identify the impairments for the position
			        /*TREATAS (
			            VALUES ( 'Securities Position Fact'[Src Position ID] ),
			            'Securities Transaction GA Fact'[POS Trans Link]
			        ),*/
			        'Securities Transaction GA Fact'[Bus Trans Code] = "TaxLotCorr",
			        'Securities Transaction GA Fact'[Transaction Purpose]
			            IN { "Income Impairment Reversal", "Income Impairment" },
			        'Securities Transaction GA Fact'[Trans Status] = "Active",
			        //Step2: Aggregate the cummulative impairment for the position
			        FILTER (
			            ALL ( Period[Date] ),
			            Period[Date] <= MAX ( Period[Date] )
			        ),
			        ALLSELECTED ( Securities ),
			        VALUES ( Securities[Primary Security ID] )
			    )
			
			```
		lineageTag: 0ea59777-8600-443e-8e0a-0c5b2e2bbad2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Accrual - Adjustment Local - opt' = ```
			
			VAR vListofGLAccts =
			    CALCULATETABLE(
			        VALUES('CAT Adjmt Config Table'[GL Acct Num]),
			        'CAT Adjmt Config Table'[Measure Name] = "Accrual"
			    )
			 
			VAR vMaxSelectedDate = MAX(Period[Date])
			VAR vMaxAsOfPeriod =
			    MAX('Consolidated GL Balance Fact'[As of Period])
			 
			RETURN
			IF (
			    ISEMPTY(
			        CALCULATETABLE(
			            'Consolidated GL Balance Fact',
			            Period[Date] = vMaxSelectedDate
			        )
			    ),
			    BLANK(),
			    SUMX(
			        VALUES(Securities[Primary Security ID]),
			        CALCULATE(
			            SUM('Consolidated GL Balance Fact'[Local Balance Amt]),
			            TREATAS(
			                vListofGLAccts,
			                'Consolidated GL Balance Fact'[GL Acct (6 digits)]
			            ),
			            Period[Date] = vMaxSelectedDate,
			            'Consolidated GL Balance Fact'[As of Period] = vMaxAsOfPeriod
			        )
			    )
			)
			 
			```
		lineageTag: 2136feaa-3f86-49eb-85ec-e714f47fcc05

		annotation PBI_FormatHint = {"isGeneralNumber":true}

