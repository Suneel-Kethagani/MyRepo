				  spos.`ULTIMATE_PARENT_COUNTRY` AS `Ultimate Parent Country`,
				  spos.`NEXT_COUPON_DATE` AS `Next Coupon Date`,
				  spos.`SCD_SECURITY_TYPE` AS `SCD Security Type`,
				  spos.`ST_CLASSIFICATION` AS `St Classification`,
				  spos.`EQUITY_ASSET_CLASS` AS `Equity Asset Class`,
				  spos.`FIXED_INCOME_ASSET_CLASS` AS `Fixed Income Asset Class`,
				  spos.`SECURITY_ID_2` AS `Security ID 2`,
				  spos.`ISSUER_NAME` AS `Issuer Name`,
				  spos.`JR_ID` AS `Jr ID`,
				  spos.`JR_NAME` AS `Jr Name`,
				  spos.`PARENT_ISSUER` AS `Parent Issuer`,
				  spos.`PORTAMV` AS `Portamv`,
				  spos.`PORTBC` AS `Portbc`,
				  spos.`GROUPAMV` AS `Groupamv`,
				  spos.`GROUPBC` AS `Groupbc`,
				  spos.`BLOCKTRADE_BBG_ID` AS `Blocktrade Bbg ID`,
				  spos.`OFF_BALANCE_COST` AS `Off Balance Cost`,
				  spos.`SWAP_INDEX` AS `Swap Index`,
				  spos.`DAY_COUNT` AS `Day Count`,
				  spos.`PAY_FREQUENCY` AS `Pay Frequency`,
				  spos.`RESET_FREQUENCY` AS `Reset Frequency`,
				  spos.`MONTH_END_STATUS` AS `Month End Status`,
				  spos.`PRICE_DATE` AS `Price Date`,
				  spos.`PORTFOLIO_GROUP_OBJECTIVE` AS `Portfolio Group1`,
				  spos.`DOMICILE_COUNTRY_CODE` AS `Domicile Country Code`,
				  spos.`ASIA_ASSET_CLASS_CODE_IN` AS `Asia Asset Class Code Indonesia`,
				  spos.`ASIA_ASSET_CLASS_CODE_VI` AS `Asia Asset Class Code Vietnam`,
				  spos.`ASIA_ASSET_CLASS_DESC_IN` AS `Asia Asset Class Desc Indonesia`,
				  spos.`ASIA_ASSET_CLASS_DESC_VI` AS `Asia Asset Class Desc Vietnam`,
				  spos.`FUNCTIONAL_CCY_CD` AS `Functional Ccy Code`,
				  spos.`LOCAL_TO_FUNC_RATE` AS `Local to Func Rate`,
