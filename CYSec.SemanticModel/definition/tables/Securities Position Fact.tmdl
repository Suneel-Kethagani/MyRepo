	measure 'Impairment Amount QC (Sec Pos)' = ```
			
			VAR curr = 
			SELECTEDVALUE('Securities Position Fact'[Local])
			VAR activity =
			    SELECTEDVALUE ( 'Impairment Slicer'[Values] )
			VAR target =
			    SWITCH(TRUE(),
			    NOT curr IN {"KRW","VND","JPY","IDR"},
			        SELECTEDVALUE(  'Securities Position Fact'[Nominal (D)] ) * (1-SELECTEDVALUE ( 'Target Loss'[Loss Percent] )/100),
			        ROUND(SELECTEDVALUE(  'Securities Position Fact'[Nominal (D)] ) * (1-SELECTEDVALUE ( 'Target Loss'[Loss Percent] )/100),0))
			
			VAR BV =
			    SUM ( 'Securities Position Fact'[Book Value - Base] )
			VAR calc =
			    IF (
			        activity = "Credit Impairment",
			        BV - target,
			        IF (
			            activity = "Credit Recovery",
			            target - BV,
			            SELECTEDVALUE( 'Securities Position Fact'[Fair Value Unaccrued - Local (D)] ) - BV
			        )
			    )
			RETURN
			    calc
			```
		lineageTag: f258bbfa-ae6f-4e77-888e-a7358a2281a8

