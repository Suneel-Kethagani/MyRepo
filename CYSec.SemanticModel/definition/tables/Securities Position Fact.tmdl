	measure 'AOCI Remain Balance Non BV - Rep (Sec Pos)' = ```
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Position Fact'[AOCI Remain Balance Non BV - Base]),
			    CALCULATE(
			        SUM('Securities Position Fact'[AOCI Remain Balance Non BV - Base]),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			),
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX (
			        'Securities Position Fact',
			        'Securities Position Fact'[AOCI Remain Balance Non BV - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			    ),
			    CALCULATE(
			        SUMX (
			            'Securities Position Fact',
			            'Securities Position Fact'[AOCI Remain Balance Non BV - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			))
			/*CALCULATE (
			IF (
				SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
				SUM ( 'Securities Position Fact'[AOCI Remain Balance Non BV - Base] ),
			    IF (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "USD",
			        SUM ( 'Securities Position Fact'[AOCI Remain Balance Non BV - USD] ),
			        IF (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "CAD",
			            SUM ( 'Securities Position Fact'[AOCI Remain Balance Non BV - CAD] ),
						IF (
							SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "Company",
							SUM ( 'Securities Position Fact'[AOCI Remain Balance Non BV - FUNC] ),
							SUM ( 'Securities Position Fact'[AOCI Remain Balance Non BV - HKD] )
							)
						)
					)
				),
			    FILTER(
			        'Securities Position Fact',
			        'Securities Position Fact'[As Of Date] = MAX('Securities Position Fact'[As Of Date])
			        )
				)
			*/
			
			
			```
		lineageTag: 856ac8fc-897d-4465-a751-98973690b85f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

