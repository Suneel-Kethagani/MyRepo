	measure 'Current Book Value - Position Rep (Sec Pos)' =
			
			/*'Securities Position Fact'[Book Value - Rep (Sec Pos)]+'Securities Position Fact'[AOCI Remain Balance BV - Rep (Sec Pos)]+ 'Securities Position Fact'[OTTI Impairment - Rep (Sec Pos)]*/
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Position Fact'[Adjusted Book Value Base]),
			    CALCULATE (
			        SUM('Securities Position Fact'[Adjusted Book Value Base]),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			),
			
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX (
			        'Securities Position Fact',
			        'Securities Position Fact'[Adjusted Book Value Local] * 'Fx Rate DQ'[Rep Rate]
			    ),
			    CALCULATE (
			        SUMX (
			            'Securities Position Fact',
			            'Securities Position Fact'[Adjusted Book Value Local] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			))
		isHidden
