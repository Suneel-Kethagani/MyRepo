	measure 'Accrued Interest EOP - Rep (Sec Pos)' = ```
			
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Position Fact'[Accrued Interest EOP Base]),
			    CALCULATE (
			        SUM('Securities Position Fact'[Accrued Interest EOP Base]),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			),
			
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX('Securities Position Fact', 'Securities Position Fact'[Accrued Interest EOP Local] *'Fx Rate DQ'[Rep Rate]),
			
			            CALCULATE (
			                    SUMX('Securities Position Fact', 'Securities Position Fact'[Accrued Interest EOP Local] *'Fx Rate DQ'[Rep Rate]),
			                LASTDATE('Securities Position Fact'[As Of Date])
			            )
			    )   
			)
