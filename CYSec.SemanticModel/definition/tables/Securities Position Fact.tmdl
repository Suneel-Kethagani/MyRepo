	measure 'Book Value - Rep (PH)' = ```
			
			VAR Prd =
			    MAX ( 'Period'[Period] )
			RETURN
			    IF (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) = "SCD Base",
			        CALCULATE (
			            /*SUM ( 'Securities Position Fact'[Book Value - Base] ),*/
			SUMX('Securities Position Fact','Securities Position Fact'[Book Value - Base]+'Securities Position Fact'[AOCI Remain Balance BV - Base]+'Securities Position Fact'[Balance Impairment - Base]),
			            ALL ( 'Period' ),
			            'Securities Position Fact'[As Of Period] <= Prd
			        ),
			        CALCULATE (
			           /* SUMX (
			                'Securities Position Fact',
			                'Securities Position Fact'[Book Value - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			            ),*/
			SUMX('Securities Position Fact',
			('Securities Position Fact'[Book Value - Local (D)] * 'Fx Rate DQ'[Rep Rate])+
			('Securities Position Fact'[AOCI Remain Balance BV - Local (D)]*  'Fx Rate DQ'[Rep Rate])+
			('Securities Position Fact'[Balance Impairment - Local] * 'Fx Rate DQ'[Rep Rate])),
			            ALL ( 'Period' ),
			            'Securities Position Fact'[As Of Period] <= Prd
			        )
			    )
			
			```
