	measure 'Adjusted GL Class (Sec Pos)' = ```
			
			VAR vMaxPeriodDate = MAX(Period[Date])
			VAR vAddRankFlagTable = 
			CALCULATETABLE(
			    ADDCOLUMNS(
			        'Adjust GL Reclass Fact',
			        "@Rank",RANKX('Adjust GL Reclass Fact','Adjust GL Reclass Fact'[Txn Dt])
			    ),
			    REMOVEFILTERS(period),
			    'Adjust GL Reclass Fact'[Txn Dt]<=vMaxPeriodDate
			)
			
			RETURN 
			IF(COUNTROWS('Securities Position Fact')>0,
			MAXX(
			    vAddRankFlagTable, IF ([@Rank]=1 , 'Adjust GL Reclass Fact'[gl classification] )
			)
			)
			```
		lineageTag: ebb37aee-6652-4604-9619-3d099efd1573

	measure 'Balance Called Capital - Rep (Sec Pos)' =
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Position Fact'[Balance Called Capital Base]),
			    CALCULATE (
			        SUM('Securities Position Fact'[Balance Called Capital Base]),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			),
			
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUMX (
			        'Securities Position Fact',
			        'Securities Position Fact'[Balance Called Capital Local] * 'Fx Rate DQ'[Rep Rate]
			    ),
			    CALCULATE (
			        SUMX (
			            'Securities Position Fact',
			            'Securities Position Fact'[Balance Called Capital Local] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
