	column 'As of date Slicer Formatted' =
			
			
			VAR vMaxPosDate = MAX('Securities Position Fact'[As Of Date])
			
			RETURN
			
			SWITCH(
			
			TRUE(),
			
			'Securities Position Fact'[As Of Date]=vMaxPosDate,"Latest",
			
			ENDOFMONTH('Securities Position Fact'[As Of Date])='Securities Position Fact'[As Of Date],"Latest",
			
			FORMAT('Securities Position Fact'[As Of Date],"DD-MMM-YYYY")
			
			)
		lineageTag: 1922a073-c55b-48d5-aba0-18de1e625a33
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

