	measure 'ECL/CECL Impairment - Local (Sec Pos)' =
			
			SUMX(SUMMARIZE('Securities Position Fact',Securities[Asset Class]),
			IF(Securities[Asset Class] IN {"Equity","Other Invested Asset"},[OTTI Impairment - Local (Sec Pos)],[ECL/CECL Impairment - Position Local (Sec Pos)]))+[ECL/CECL Impairment - Adjustment Local (Sec Pos)]
		lineageTag: 2fbf0555-09ee-4ad8-b80d-e550f6a175a3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Purpose Codes (Sec Pos)' = ```
			
			VAR FW =
			    SELECTEDVALUE ( Framework[Framework] )
			RETURN
			    CALCULATE (
			        IF (
			            FW = "IAS39",
			            SELECTEDVALUE ( Portfolios[IAS39 Trading Philosophy Code (D)] ),
			            IF (
			                FW = "USGAAP",
			                SELECTEDVALUE ( Portfolios[USGAAP Trading Philosophy Code (D)] ),
			                IF (
			                    FW = "JGAAP",
			                    SELECTEDVALUE ( Portfolios[JGAAP Trading Philosophy Code (D)] ),
			                    IF (
			                        FW = "IFRS9",
			                        
			                        SELECTEDVALUE ( Portfolios[IFRS Trading Philosophy Code (D)] ),
			                        --(FW= "USTAX" || FW= "NAIC"),
			                        IF (
			                            NOT (
			                                ISEMPTY ( 'Securities Position Fact' )
			                            ),
			                            "AFS"
			                        )
			                    )
			                )
			            )
			        ),
			                FILTER (
			            'Securities Position Fact',
			            'Securities Position Fact'[As Of Date]
			                = MAX ( 'Securities Position Fact'[As Of Date] )
			        )
			    )
			
			```
		lineageTag: 14850d14-8632-4195-af4b-6b19ba6cbddf

