	measure 'Current Book Value - Position Local (Sec Pos)' =
			
			/*'Securities Position Fact'[Book Value - Local]+'Securities Position Fact'[AOCI Remain Balance BV - Local]+ 'Securities Position Fact'[OTTI Impairment - Local (Sec Pos)]*/
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM ( 'Securities Position Fact'[Adjusted Book Value Local] ),
			    CALCULATE (
			        SUM ( 'Securities Position Fact'[Adjusted Book Value Local] ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
