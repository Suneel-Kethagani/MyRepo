	measure 'Price - Rep' = ```
			
			
			SWITCH(
			SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
			"SCD Base",
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM('Securities Position Fact'[Price - Base]),
			    CALCULATE(
			        SUM('Securities Position Fact'[Price - Base]),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			),
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    AVERAGEX( 
			        'Securities Position Fact',
			        'Securities Position Fact'[Price - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			    ),
			    CALCULATE(
			        AVERAGEX( 
			            'Securities Position Fact',
			            'Securities Position Fact'[Price - Local (D)] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        LASTDATE('Securities Position Fact'[As Of Date])
			    )
			)) 
			/*VAR maxd =
			    MAX ( 'Securities Position Fact'[As Of Date] )
			VAR calc =
			    SWITCH (
			        SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			        "USD",
			            CALCULATE (
			                SUM ( 'Securities Position Fact'[Price - USD]),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Date] = maxd
			                )
			            ),
			        "CAD",
			            CALCULATE (
			                SUM ( 'Securities Position Fact'[Price - CAD] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Date] = maxd
			                )
			            ),
			        "HKD",
			            CALCULATE (
			                SUM ( 'Securities Position Fact'[Price - HKD] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Date] = maxd
			                )
			            ),
			        "Company",
			            CALCULATE (
			                SUM ( 'Securities Position Fact'[Price - FUNC] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Date] = maxd
			                )
			            ),
			        "SCD Base",
			            CALCULATE (
			                SUM( 'Securities Position Fact'[Price - Base] ),
			                FILTER (
			                    'Securities Position Fact',
			                    'Securities Position Fact'[As Of Date] = maxd
			                )
			            )
			    )
			RETURN
			    calc*/
			
