	column 'Lookthrough Zero Remove Filter' = ```
			
			COALESCE ( 'Securities Lookthrough Position Fact'[Nominal (D)], 0 )
			    + COALESCE ( [Balance Book Value Local Ccy], 0 )
			    + COALESCE ( 'Securities Lookthrough Position Fact'[Market Value Local], 0 )
			    + COALESCE ( 'Securities Lookthrough Position Fact'[Accrual Local], 0 )
			
			```
		lineageTag: 39e4b983-059f-4199-91ef-eb5b8e83547b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Investor Portfolio Code & Name' =
			
			VAR vStandalonePortfolioCode='Securities Lookthrough Position Fact'[Standalone Portfolio Code]
			VAR vAsOfPeriod = 'Securities Lookthrough Position Fact'[As Of Period]
			
			VAR vValue = CALCULATE(MAX(Portfolios[Portfolio Code & Name]),Portfolios[Asset Portfolio Code]=vStandalonePortfolioCode,Portfolios[As of Period]=VALUE(vAsOfPeriod),REMOVEFILTERS('Securities Lookthrough Position Fact'))
			RETURN vValue
		lineageTag: e1ebd42c-0f44-4136-91e9-f5d49d15453e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Investor Accounting Unit Code & Name' =
			
			VAR vStandalonePortfolioCode='Securities Lookthrough Position Fact'[Standalone Portfolio Code]
			VAR vAsOfPeriod = 'Securities Lookthrough Position Fact'[As Of Period]
			
			VAR vValue = CALCULATE(MAX('Accounting Unit'[Accounting Unit Code & Name]),Portfolios[Asset Portfolio Code]=vStandalonePortfolioCode,Portfolios[As of Period]=VALUE(vAsOfPeriod),REMOVEFILTERS('Securities Lookthrough Position Fact'))
			RETURN vValue
		lineageTag: 5ab39eb4-37fa-4b90-b5f7-6f0c25012040
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Investor Company Code & Name' =
			
			VAR vStandalonePortfolioCode='Securities Lookthrough Position Fact'[Standalone Portfolio Code]
			VAR vAsOfPeriod = 'Securities Lookthrough Position Fact'[As Of Period]
			
			VAR vValue = CALCULATE(MAX(Company[Company Code & Name]),Portfolios[Asset Portfolio Code]=vStandalonePortfolioCode,Portfolios[As of Period]=VALUE(vAsOfPeriod),REMOVEFILTERS('Securities Lookthrough Position Fact'))
			RETURN vValue
		lineageTag: 04c53116-dcde-4444-a41c-6bba2ec4ed4d
		summarizeBy: none

