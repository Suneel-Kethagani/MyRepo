	measure 'Market Value Rep' = ```
			
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			        IF (
			            ISFILTERED ( 'Period'[Date] ),
			            SUM ( 'Securities Lookthrough Position Fact'[Market Value Base] ),
			            CALCULATE (
			                SUM ( 'Securities Lookthrough Position Fact'[Market Value Base] ),
			                LASTDATE ( 'Securities Lookthrough Position Fact'[Effective Date] )
			            )
			        ),
			    IF (
			        ISFILTERED ( 'Period'[Date] ),
			        SUMX (
			            'Securities Lookthrough Position Fact',
			            'Securities Lookthrough Position Fact'[Market Value Local (D)] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        CALCULATE (
			            SUMX (
			                'Securities Lookthrough Position Fact',
			                'Securities Lookthrough Position Fact'[Market Value Local (D)] * 'Fx Rate DQ'[Rep Rate]
			            ),
			            LASTDATE ( 'Securities Lookthrough Position Fact'[Effective Date] )
			        )
			    )
			)
			
			```
