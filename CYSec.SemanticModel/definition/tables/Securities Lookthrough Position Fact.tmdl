	measure 'Security Lookthrough Position Title' =
			
			VAR Maxdate =
			    MAX ( 'Securities Lookthrough Position Fact'[Effective Date] )
			VAR Mindate =
			    MIN ( 'Period'[Start of Month] )
			RETURN
			    "Security Lookthrough Position, "
			        & SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) & ", "
			        & SELECTEDVALUE ( 'Framework'[Framework Display] ) & ", "
			        & FORMAT ( mindate, "dd-mmm-yy" ) & " - "
			        & FORMAT ( Maxdate, "dd-mmm-yy" )
		lineageTag: a8337596-b528-4b65-ba71-07048fb3bf08

