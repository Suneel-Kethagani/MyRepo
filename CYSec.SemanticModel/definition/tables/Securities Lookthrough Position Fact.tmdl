table 'Securities Lookthrough Position Fact'
	lineageTag: e865d2e8-2384-4e70-83c5-0b2c6def5db1

	measure 'Rep Rate (Security Lookthrough)' =
			
			AVERAGEX( 'Securities Lookthrough Position Fact', 1 * 'Fx Rate DQ'[Rep Rate])
		formatString: 0.000000
		lineageTag: b12b760e-3346-44b8-9332-194e8388cab7

	measure 'Ownership %' =
			
			SWITCH (
			    TRUE (),
			    ISFILTERED ( 'Securities Lookthrough Position Fact'[Company Code Name] ),
			        SUMX (
			            SUMMARIZE (
			                'Securities Lookthrough Position Fact',
			                'Securities Lookthrough Position Fact'[Portfolio Code Name],
			                'Securities Lookthrough Position Fact'[Primary security ID & Desc Lookthrough Position],
			                'Securities Lookthrough Position Fact'[Ownership Percentage]
			            ),
			            'Securities Lookthrough Position Fact'[Ownership Percentage]
			        ),
			    HASONEVALUE ( 'Securities Lookthrough Position Fact'[Primary security ID & Desc Lookthrough Position] ),
			        SUMX (
			            SUMMARIZE (
			                'Securities Lookthrough Position Fact',
			                'Securities Lookthrough Position Fact'[Portfolio Code Name],
			                'Securities Lookthrough Position Fact'[Primary security ID & Desc Lookthrough Position],
			                'Securities Lookthrough Position Fact'[Ownership Percentage]
			            ),
			            'Securities Lookthrough Position Fact'[Ownership Percentage]
			        ),
			    BLANK ()
			)
		formatString: 0.00000
		lineageTag: e83ec703-5c83-4f6b-b300-3af0a80c2151

		changedProperty = FormatString

	measure 'Reporting Currency (look Position)' = ```
			
			VAR SelectedCurrency =
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			VAR ReportingCurrency =
			    IF (
			        NOT ISEMPTY ( 'Securities Lookthrough Position Fact' ),
			        IF (
			            SelectedCurrency = "Company",
			            FIRSTNONBLANK ( 'Securities Lookthrough Position Fact'[Functional Ccy Cd], TRUE () ),
			            IF (
			                SelectedCurrency = "SCD Base",
			                FIRSTNONBLANK ( 'Securities Lookthrough Position Fact'[Base], TRUE () ),
			                SelectedCurrency
			            )
			        )
			    )
			RETURN
			    ReportingCurrency
			
			```
		lineageTag: 32bef179-7255-4953-898e-48dde14b3c29

	measure 'Nominal (Lookthrough)' =
			
			IF (
			    ISFILTERED ( 'Period'[Date] ),
			    SUM ( 'Securities Lookthrough Position Fact'[Nominal (D)] ),
			    CALCULATE (
			        SUM ( 'Securities Lookthrough Position Fact'[Nominal (D)] ),
			        LASTDATE ( 'Securities Lookthrough Position Fact'[Effective Date] )
			    )
			)
