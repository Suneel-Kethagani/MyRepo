table 'Securities Elim Transaction PL Tax Lot Fact'
	lineageTag: 4138735e-4f64-4b4a-8f22-6e042dd59d15

	measure 'Real Amortization - Local' = SUM ( 'Securities Elim Transaction PL Tax Lot Fact'[Real Amortisation Local Ccy])
		lineageTag: 0c84effc-e1fe-4435-83ef-238dac81fd27

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Real Amortization - Rep' = ```
			
			VAR Selected_Currency = SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] )
			RETURN
			IF(
			    Selected_Currency = "SCD Base",
			    SUM ('Securities Elim Transaction PL Tax Lot Fact'[Real Amortisation Base Ccy] ),
			    SUMX (
			        'Securities Elim Transaction PL Tax Lot Fact',
			        'Securities Elim Transaction PL Tax Lot Fact'[Real Amortisation Local Ccy]
			        * SWITCH (
			            SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			            "Company", 'Securities Elim Transaction PL Tax Lot Fact'[Local To Func Rate],
			            "USD", 'Securities Elim Transaction PL Tax Lot Fact'[Local To USD Rate],
			            "CAD", 'Securities Elim Transaction PL Tax Lot Fact'[Local To CAD Rate],
			            "HKD", 'Securities Elim Transaction PL Tax Lot Fact'[Local To HKD Rate]
			            )
			        )
			)
			   
			```
		lineageTag: 6e5e1b37-0712-4d85-a3d6-30f1eee53469

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Securities Elim Transactions Title' = ```
			
			VAR maxdate =
			    MAX ( Period[Date] )
			RETURN
			    "Security Elim Transactions" & ", "
			        & SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ) & ", "
			        & SELECTEDVALUE ( Framework[Framework Display] ) & ", "
			        & FORMAT ( maxdate, "MMM-YY" )
			
			```
		lineageTag: acd2ad8f-23d1-4986-a739-903e82240c74

	measure 'Sublot AOCI - Local (Sec Elim)' = ```
			
			var vAoci_key =
			SUMMARIZE (
			    'Securities Elim Transaction PL Tax Lot Fact',
			    'Securities Elim Transaction PL Tax Lot Fact'[Originating System No],
			    'Securities Elim Transaction PL Tax Lot Fact'[Match Src Transaction ID],
			    'Securities Elim Transaction PL Tax Lot Fact'[Src Transaction ID],
			    'Securities Elim Transaction PL Tax Lot Fact'[Bus Trans No],
			    'Securities Elim Transaction PL Tax Lot Fact'[Framework CD]
			)
			var vResult = 
			CALCULATE( 
			    SUM('Securities Elim Transaction PL Tax Lot AOCI Fact'[Sublot AOCI - Local]),
			    TREATAS (
			        vAoci_key,
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Originating System No],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Match Src Transaction ID],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Src Transaction Id],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Bus Trans no],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Framework Code]
			    )
			)
			
			RETURN vResult
			```
		lineageTag: f8e790bb-c9c4-47f0-adb6-d3bdc8dece60

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sublot Amort AOCI - Local (Sec Elim)' = ```
			
			var vAoci_key =
			SUMMARIZE (
			    'Securities Elim Transaction PL Tax Lot Fact',
			    'Securities Elim Transaction PL Tax Lot Fact'[Originating System No],
			    'Securities Elim Transaction PL Tax Lot Fact'[Match Src Transaction ID],
			    'Securities Elim Transaction PL Tax Lot Fact'[Src Transaction ID],
			    'Securities Elim Transaction PL Tax Lot Fact'[Bus Trans No],
			    'Securities Elim Transaction PL Tax Lot Fact'[Framework CD]
			)
			var vResult = 
			CALCULATE( 
			    SUM('Securities Elim Transaction PL Tax Lot AOCI Fact'[Sublot Amort AOCI - local]),
			    TREATAS (
			        vAoci_key,
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Originating System No],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Match Src Transaction ID],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Src Transaction Id],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Bus Trans no],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Framework Code]
			    )
			)
			
			RETURN vResult
			```
		lineageTag: 8d3c0c8d-d7ac-41a6-b181-8a7d45c380fb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sublot Amort AOCI - Rep (Sec Elim)' = ```
			
			var vAoci_key =
			SUMMARIZE (
			    'Securities Elim Transaction PL Tax Lot Fact',
			    'Securities Elim Transaction PL Tax Lot Fact'[Originating System No],
			    'Securities Elim Transaction PL Tax Lot Fact'[Match Src Transaction ID],
			    'Securities Elim Transaction PL Tax Lot Fact'[Src Transaction ID],
			    'Securities Elim Transaction PL Tax Lot Fact'[Bus Trans No],
			    'Securities Elim Transaction PL Tax Lot Fact'[Framework CD]
			)
			var vResult = 
			SWITCH (
			    SELECTEDVALUE ( 'Reporting Currency'[Rep In Currency] ),
			    "SCD Base",
			    CALCULATE( 
			        SUM('Securities Elim Transaction PL Tax Lot AOCI Fact'[Sublot Amort AOCI - Base]),
			        TREATAS (
			        vAoci_key,
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Originating System No],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Match Src Transaction ID],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Src Transaction Id],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Bus Trans no],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Framework Code]
			        )
			    ),
			    CALCULATE( 
			        SUMX(
			            'Securities Elim Transaction PL Tax Lot AOCI Fact',
			            'Securities Elim Transaction PL Tax Lot AOCI Fact'[Sublot Amort AOCI - Local] * 'Fx Rate DQ'[Rep Rate]
			        ),
			        TREATAS (
			        vAoci_key,
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Originating System No],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Match Src Transaction ID],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Src Transaction Id],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Bus Trans no],
			        'Securities Elim Transaction PL Tax Lot AOCI Fact'[Framework Code]
			        )
			    )
			)
			
			RETURN vResult
			```
		lineageTag: ce3a2974-e434-445a-bfaa-e51cfaef0421

		annotation PBI_FormatHint = {"isGeneralNumber":true}

