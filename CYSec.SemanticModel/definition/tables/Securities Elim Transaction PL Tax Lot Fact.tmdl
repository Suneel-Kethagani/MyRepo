	measure 'Yield For Math Adj (Sec Elim)' =
			
			CALCULATE (
			    MAX('Securities Elim Transaction PL Tax Lot Fact'[Yield For Math Adj]),
			    CROSSFILTER('Securities Elim Lot Fact'[Security Nk],Securities[Security NK],Both)
			    )
		lineageTag: 363bba9f-e413-44e1-a76e-4b87be94ce76

