	measure 'Dbrs - Change' =
			
			VAR maxDateRange =
			    MAX ( 'Period'[Period] )
			VAR _min =
			    EDATE ( MIN ( 'Period'[End of Month] ), -1 )
			VAR priorDateRange =
			    VALUE ( YEAR ( _min ) & FORMAT ( MONTH ( _min ), "00" ) )
			VAR minval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Dbrs], TRUE () ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Dbrs], TRUE () ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			VAR minsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			RETURN
			        IF (
			        minsec > 0
			            && maxsec > 0
			            && minval <> maxval,
			        CONCATENATE (
			             minval,
			            CONCATENATE ( " -> ", maxval )
			        ),
			        IF (
			            AND ( ISBLANK ( minval ), NOT ( ISBLANK ( maxval ) ) ),
			             maxval,
			            BLANK ()
			        )
			    )
		displayFolder: Security Changes Measures
		lineageTag: 0396e384-4c59-4820-9bd7-1839e6e1e8be

