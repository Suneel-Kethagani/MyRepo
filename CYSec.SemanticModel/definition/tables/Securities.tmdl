			            'Securities'[As Of Period] = maxDateRange
			        )
			    
			VAR minNAICIns =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[ML NAIC Instrument Type Cd], TRUE () ), 
			            'Securities'[As Of Period] = priorDateRange
			        )
			    
			VAR maxNAICIns =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[ML NAIC Instrument Type Cd], TRUE () ),  
			            'Securities'[As Of Period] = maxDateRange
			        )
			    
			VAR minSecGroup =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Asset Group], TRUE () ),  
			            'Securities'[As Of Period] = priorDateRange
			        )
			    
			VAR maxSecGroup =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Asset Group], TRUE () ),    
			            'Securities'[As Of Period] = maxDateRange
			        )
			    
			RETURN
			    IF (
			        AND ( OR ( minsec = 0, ISBLANK ( minsec ) ), maxsec > 0 ),
			        "New",
			        IF (
			            AND ( minsec > 0, OR ( maxsec = 0, ISBLANK ( maxsec ) ) ),
			            "Removed",
			            IF (
			                COALESCE ( minDesc, "" ) <> COALESCE ( maxDesc, "" )
			                    || COALESCE ( minCusip, "" ) <> COALESCE ( maxCusip, "" )
			                    || COALESCE ( minspshrtterm, "" ) <> COALESCE ( maxspshrtterm, "" )
			                    || COALESCE ( minCoupon, "" ) <> COALESCE ( maxCoupon, "" )
			                    || COALESCE ( minnxtcalldt, "" ) <> COALESCE ( maxnxtcalldt, "" )
			                    || COALESCE ( minnxtsinkdt, "" ) <> COALESCE ( maxnxtsinkdt, "" )
			                    || COALESCE ( minfltsp, "" ) <> COALESCE ( maxfltsp, "" )
			                    || COALESCE ( minlsredt, "" ) <> COALESCE ( maxlsredt, "" )
			                    || COALESCE ( minnxtcallpx, "" ) <> COALESCE ( maxnxtcallpx, "" )
			                    || COALESCE ( minshrout, "" ) <> COALESCE ( maxshrout, "" )
			                    || COALESCE ( minmoodys, "" ) <> COALESCE ( maxmoodys, "" )
			                    || COALESCE ( minsp, "" ) <> COALESCE ( maxsp, "" )
			                    || COALESCE ( minfitch, "" ) <> COALESCE ( maxfitch, "" )
			                    || COALESCE ( mindbrs, "" ) <> COALESCE ( maxdbrs, "" )
			                    || COALESCE ( minInternal, "" ) <> COALESCE ( maxInternal, "" )
			                   --|| COALESCE ( minmoodylgterm, "" ) <> COALESCE ( maxmoodylgterm, "" )
			                    || COALESCE ( minfitchlg, "" ) <> COALESCE ( maxfitchlg, "" )
			                    || COALESCE ( minPsecId, "" ) <> COALESCE ( maxPsecId, "" )
			                    || COALESCE ( minassettype, "" ) <> COALESCE ( maxassettype, "" )
			                    || COALESCE ( minassetclass, "" ) <> COALESCE ( maxassetclass, "" )
			                   || COALESCE ( minrtgmdyiss, "" ) <> COALESCE ( maxrtgmdyiss, "" )
			                   || COALESCE ( minrtgsplg, "" ) <> COALESCE ( maxrtgsplg, "" )
			                   || COALESCE ( minrtgspout, "" ) <> COALESCE ( maxrtgspout, "" )
			                    || COALESCE ( minMLIRR, "" ) <> COALESCE ( maxMLIRR, "" )
			                    || COALESCE ( minMLMFC, "" ) <> COALESCE ( maxMLMFC, "" )
			                    || COALESCE ( minfitchshtterm, "" ) <> COALESCE ( maxfitchshtterm, "" )
			                    || COALESCE ( minmatdt, "" ) <> COALESCE ( maxmatdt, "" )
			                    || COALESCE ( minasia, "" ) <> COALESCE ( maxasia, "" )
			                    || COALESCE ( minmoodyshtterm, "" ) <> COALESCE ( maxmoodyshtterm, "" )
			                   || COALESCE ( minrtgmdylg, "" ) <> COALESCE ( maxrtgmdylg, "" )
			                || COALESCE ( minNAICIns, "" ) <> COALESCE ( maxNAICIns, "" )
			                    || COALESCE ( minInstype, "" ) <> COALESCE ( maxInstype, "" )
			                    || COALESCE ( minSecGroup, "" ) <> COALESCE ( maxSecGroup, "" )
			                    || COALESCE ( minFAS157, "" ) <> COALESCE ( maxFAS157, "" ),
			                "Changed",
			                BLANK ()
			            )
			        )
			    )
			
