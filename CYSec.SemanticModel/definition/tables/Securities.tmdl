	measure 'Primary Security ID - Change' =
			
			VAR maxDateRange =
			    MAX ( 'Period'[Period] )
			VAR _min =
			    EDATE ( MIN ( 'Period'[End of Month] ), -1 )
			VAR priorDateRange =
			    VALUE ( YEAR ( _min ) & FORMAT ( MONTH ( _min ), "00" ) )
			VAR minval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Primary Security ID], TRUE () ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Primary Security ID], TRUE () ),
			        'Securities'[As Of Period]=maxDateRange
			    )
			VAR minsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period]=priorDateRange
			    )
			VAR maxsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period]=maxDateRange
			    )
			RETURN
			    IF (
			        minsec > 0
			            && maxsec > 0
			            && minval <> maxval,
			        CONCATENATE ( minval, CONCATENATE ( " -> ", maxval ) ),
			        IF ( AND ( ISBLANK ( minval ), NOT ( ISBLANK ( maxval ) ) ), maxval, BLANK () )
			    )
		displayFolder: Security Changes Measures
		lineageTag: 47f729ad-01fd-4771-8398-59602f7e87d0

	measure 'Next Call Date - Change' = ```
			
			VAR maxDateRange =
			    MAX ( 'Period'[Period] )
			VAR _min =
			    EDATE ( MIN ( 'Period'[End of Month] ), -1 )
			VAR priorDateRange =
			    VALUE ( YEAR ( _min ) & FORMAT ( MONTH ( _min ), "00" ) )
			VAR minval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Next Call Date], TRUE () ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Next Call Date], TRUE () ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			VAR minsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			RETURN
			    IF (
			        minsec > 0
			            && maxsec > 0
			            && minval <> maxval,
			        CONCATENATE (
			            FORMAT ( minval, "DD-MMM-YY" ),
			            CONCATENATE ( " -> ", FORMAT ( maxval, "DD-MMM-YY" ) )
			        ),
			        IF (
			            AND ( ISBLANK ( minval ), NOT ( ISBLANK ( maxval ) ) ),
			            FORMAT ( maxval, "DD-MMM-YY" ),
			            BLANK ()
			        )
			    )
			
			```
		displayFolder: Security Changes Measures
		lineageTag: 526995c5-7397-41a9-9374-7de6542caa97

