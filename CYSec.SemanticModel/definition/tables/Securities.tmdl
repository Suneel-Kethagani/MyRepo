	measure 'Company Code & Name (Held Sec)' =
			
			var pos = DISTINCTCOUNT('Securities Position Fact'[Src Security Id])
			var trans = DISTINCTCOUNT('Securities Transaction GA Fact'[Src Security ID])
			var pos_com = FIRSTNONBLANK('Securities Position Fact'[Company Code & Name Display],TRUE())
			var trans_com = FIRSTNONBLANK('Securities Transaction GA Fact'[Company Code & Name Display],TRUE())
			var calc = if(pos>0,pos_com,if(trans>0,trans_com))
			return calc
		lineageTag: 96114bd3-6cfe-4eb4-bec3-2dbd042f2213

