	measure 'Coupon Spread - Change' = ```
			
			VAR maxDateRange =
			    MAX ( 'Period'[Period] )
			VAR _min =
			    EDATE ( MIN ( 'Period'[End of Month] ), -1 )
			VAR priorDateRange =
			    VALUE ( YEAR ( _min ) & FORMAT ( MONTH ( _min ), "00" ) )
			VAR minval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Coupon Spread], TRUE () ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Coupon Spread], TRUE () ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			VAR minsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			RETURN
			    IF (
			        minsec > 0
			            && maxsec > 0
			            && minval <> maxval,
			        CONCATENATE (
			             minval,
			            CONCATENATE ( " -> ", maxval )
			        ),
			        IF (
			            AND ( ISBLANK ( minval ), NOT ( ISBLANK ( maxval ) ) ),
			             maxval,
			            BLANK ()
			        )
			    )
			
			```
		displayFolder: Security Changes Measures
		lineageTag: d6ab8af0-7e4d-43d7-8fd6-d618e84bb6f5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Last Refix Date - Change' = ```
			
			VAR maxDateRange =
			    MAX ( 'Period'[Period] )
			VAR _min =
			    EDATE ( MIN ( 'Period'[End of Month] ), -1 )
			VAR priorDateRange =
			    VALUE ( YEAR ( _min ) & FORMAT ( MONTH ( _min ), "00" ) )
			VAR minval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Last Refix Date], TRUE () ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Last Refix Date], TRUE () ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			VAR minsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			RETURN
			    IF (
			        minsec > 0
			            && maxsec > 0
			            && minval <> maxval,
			        CONCATENATE (
			            FORMAT ( minval, "DD-MMM-YY" ),
			            CONCATENATE ( " -> ", FORMAT ( maxval, "DD-MMM-YY" ) )
			        ),
			        IF (
			            AND ( ISBLANK ( minval ), NOT ( ISBLANK ( maxval ) ) ),
			            FORMAT ( maxval, "DD-MMM-YY" ),
			            BLANK ()
			        )
			    )
			
			```
		displayFolder: Security Changes Measures
		lineageTag: 723179e1-95b3-4f4f-9fda-4e3ebe58c029

