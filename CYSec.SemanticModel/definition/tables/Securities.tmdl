			VAR priorDateRange =
			    VALUE ( YEAR ( _min ) & FORMAT ( MONTH ( _min ), "00" ) )
			VAR minval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Maturity Date], TRUE () ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxval =
			    CALCULATE (
			        LASTNONBLANK ( 'Securities'[Maturity Date], TRUE () ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			VAR minsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = priorDateRange
			    )
			VAR maxsec =
			    CALCULATE (
			        COUNTROWS ( 'Securities' ),
			        'Securities'[As Of Period] = maxDateRange
			    )
			RETURN
			    IF (
			        minsec > 0
			            && maxsec > 0
			            && minval <> maxval,
			        CONCATENATE (
			            FORMAT ( minval, "DD-MMM-YY" ),
			            CONCATENATE ( " -> ", FORMAT ( maxval, "DD-MMM-YY" ) )
			        ),
			        IF (
			            AND ( ISBLANK ( minval ), NOT ( ISBLANK ( maxval ) ) ),
			            FORMAT ( maxval, "DD-MMM-YY" ),
			            BLANK ()
			        )
			    )
			
			```
