	measure 'Security - Change Filter' =
			
			VAR SecChange = 'Securities'[Security - Change]
			VAR slicer =
			    SELECTEDVALUE ( 'Portfolio Change Types'[Type] )
			RETURN
			    SWITCH (
			        TRUE (),
			        slicer = "All", 1,
			        SecChange = slicer, 1,
			        0
			    )
		formatString: 0
		displayFolder: Security Changes Measures
		lineageTag: d947fa76-fae5-4a07-8162-af06bbe1e8c6

	measure '#Secs - Changes' = DISTINCTCOUNTNOBLANK('Securities'[Src Security ID])
