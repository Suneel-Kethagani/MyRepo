	measure 'Maturity Days' = ```
			
			--Flip signs
			IF (
			    MIN ( 'Securities'[Maturity Days (D)] ) < 0,
			    MIN ( 'Securities'[Maturity Days (D)] ) * -1,
			    MIN ( 'Securities'[Maturity Days (D)] )
			)
			
			```
		formatString: 0
		lineageTag: fdd208a4-3e62-43da-a680-caca14b4903d

