	column 'SecurityID Slicer - Restated' =
			'Securities'[Security Description - Restated] & " - "
			            & 'Securities'[Security ID 2 - Restated]
			            & " - "
			            & IF ( 'Securities'[Isin - Restated] <> "N/S", 'Securities'[Isin - Restated] )
			            & " - "
			            & 'Securities'[Sedol - Restated]
			            & " - "
			            & 'Securities'[Ticker - Restated]
			            & " - "
			            & IF ( 'Securities'[ID BB Global - Restated]  <> "Not Specified", 'Securities'[ID BB Global - Restated] )
			            & " - "
			            & 'Securities'[Primary Security ID - Restated]
			            & " - "
			            & 'Securities'[Src Security ID]
			            & " - "
			            & 'Securities'[SCD Security ID - Restated]
			            & " - "
			            & 'Securities'[Cusip - Restated]
			            & " - "
			            & 'Securities'[Official PPN - Restated]
			            & " - "
			            & 'Securities'[ML Private Asset ID - Restated]
		lineageTag: 46e5874c-0fea-418a-8f62-a72ae60eef6d
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'ID BB Global - Restated' =
			
			VAR vLatestAsOfDate = CALCULATE(MAX(Securities[As Of Dt]),ALLEXCEPT(Securities,Securities[Src Security ID],Securities[Src Market ID]))
			VAR vRestatedValue= CALCULATE(MAX(Securities[ID BB Global]),ALLEXCEPT(Securities,Securities[Src Security ID],Securities[Src Market ID]),Securities[As Of Dt]=vLatestAsOfDate)
			RETURN vRestatedValue
