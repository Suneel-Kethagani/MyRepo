	measure 'Filter Date' = ```
			
			var maxSec = CALCULATE(MAX(Securities[As Of Dt]),ALLEXCEPT(Securities,Securities[Src Security ID],Securities[Src Market ID]))
			var calc = IF(maxSec=MAX(Securities[As Of Dt]),1,0)
			return calc
			
			```
		formatString: 0
		isHidden
		lineageTag: 53d7cc80-17ac-4cec-a876-dc91ee9e0a82

	measure 'All Security Filter (Held/Transacted/Minor Type)' = ```
			
			VAR vSecurityType = SELECTEDVALUE(Securities[ML Minor Type])
			RETURN 
			IF(
			    vSecurityType IN {"SEEDMF","SEEDETF","SEEDSEG", "MUTUAL FUND", "SEGFUND", "ETF", "NON TRADITIONAL SEED"},
			    1,
			    [#SrcSecID]
			)
			```
		formatString: 0
		isHidden
		lineageTag: 18f5ec62-82f5-4992-b588-f3566d650be0

		changedProperty = IsHidden

	measure 'Is Active Security' =
			
			
			VAR vMenduPageDate = VALUE(FORMAT(MAX(period[date]),"YYYYMM"))
			
			RETURN CALCULATE(COUNTROWS(Securities),KEEPFILTERS(Securities[As Of Period]=vMenduPageDate))
		formatString: 0
		lineageTag: 0cb8fade-ee3f-4f7c-994d-c2473ddc4356

