	column 'Country of Issue - Long' = ```
			
			VAR VCountryofIssue = Securities[Country Of Issue]
			VAR VCountryDim = 
			                CALCULATE(
			                    FIRSTNONBLANK('Country Dim'[Country Long Nm],TRUE()), 
			                    'Country Dim'[ISO2 Country Cd]=VCountryofIssue)
			RETURN 
			VCountryDim
			```
		lineageTag: e5ff7ff8-c1c2-4d53-b1a4-f052ed2fc63e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Country of Issue - Short' = ```
			
			VAR VcountryCode = Securities[Country Of Issue] 
			VAR VCountryDim = 
			     CALCULATE (
			          FIRSTNONBLANK('Country Dim'[Country Short Nm],TRUE()),'COUNTRY DIM'[ISO2 Country Cd] = VcountryCode )
			RETURN
			    VCountryDim
			```
		lineageTag: 071044d1-e97a-4b1b-af6f-58617eaf47cd
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'ML IRR Rating (Adj)' = ```
			
			VAR vSecurityNK=Securities[Security NK]
			VAR Vratingfromsecurityratingperiod = Calculate(SELECTEDVALUE('Security Ratings Periods Fact'[Rating CD]),
			'Security Ratings Periods Fact'[Security NK]= vSecurityNK,
			'Security Ratings Periods Fact'[Rating Agency CD]="MANULIFE INTERNAL RISK RATING")
			
			RETURN
			COALESCE('Securities'[ML IRR Rating],Vratingfromsecurityratingperiod
			)
			
			```
		lineageTag: 9b6761e5-ede2-4cc2-a0a8-04e4219735e9
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'ML MFC Equivalent Rtg' = ```
			
			VAR vSecurityNK=Securities[Security NK]
			VAR vRatingFromSecurityRatingPeriod = 
			CALCULATE(
			    SELECTEDVALUE('Security Ratings Periods Fact'[Rating CD]),
			   'Security Ratings Periods Fact'[Security NK]= vSecurityNK,
			   'Security Ratings Periods Fact'[Rating Agency CD]= "MANULIFE EQUIVALENT RATING"
			)
			RETURN
			COALESCE(Securities[ML MFC Equivalent Rating],vRatingFromSecurityRatingPeriod)
			```
		lineageTag: b405fd62-5ac6-4aea-ac10-a52cfaeba04b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Private Placement (Adj)' =
			
			COALESCE(securities[Private Placement],Securities[Scd Private Placement Indicator])
		lineageTag: 443d90b0-455f-4aab-895a-f6c1100d792d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'ML LICAT Inferred Rating' =
			
			
			VAR vSecurityNK=Securities[Security NK]
			
			VAR vRatingFromSecurityRatingTable=
			
			CALCULATE(
			
			    SELECTEDVALUE('Security Ratings Periods Fact'[Rating CD]),
			
			    'Security Ratings Periods Fact'[Security NK]= vSecurityNK,
			
			    'Security Ratings Periods Fact'[Rating Agency CD]= "MANULIFE LICAT INFERRED RATING"
			
			)
			RETURN
			
			COALESCE(Securities[ML LICAT Inferred Rating ORG],vRatingFromSecurityRatingTable)
		lineageTag: 16c1b665-c7b9-4b6f-9c22-6705528ba9b6
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Endorsement Indicator' =
			
			VAR vSecurityNK=Securities[Security NK]
			Var VendorsementFromSecurtiyRating = calculate(SELECTEDVALUE('Security Ratings Periods Fact'[Endorsement Indicator]),
			'Security Ratings Periods Fact'[Security NK]= vSecurityNK,
			'Security Ratings Periods Fact'[Rating Agency CD]="MANULIFE EQUIVALENT RATING")
			RETURN
			COALESCE(VendorsementFromSecurtiyRating,"")
		lineageTag: 2cd6c299-3776-41cf-9089-9d924ac4ecf8
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

