	column 'Latest As of Dt' =
			
			
			VAR vMaxPosDate = MAX('Securities Position Fact'[As Of Date])
			
			RETURN
			
			SWITCH(
			
			TRUE(),
			
			Securities[As Of Dt]=vMaxPosDate,"Latest",
			
			ENDOFMONTH(Securities[As Of Dt])=Securities[As Of Dt],"Latest",
			
			FORMAT(Securities[As Of Dt],"DD-MMM-YYYY")
			
			)
		lineageTag: 26a267ac-2cf1-49de-8ef6-974d8638e32d
		summarizeBy: none

