				            'Securities Transaction Costs GA Fact',[Consumption Fee - Local] * [Rep Rate]
				        ),
				        USERELATIONSHIP('Fx Rate DQ'[FX Join Key],'Securities Transaction Costs GA Fact'[FX Join Key])
				    )
				)
				```
			lineageTag: e4386505-75c7-4412-b1f3-fb5865350834

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		measure 'Reverse Cash Settlement - Local' =
				
				CALCULATE(
				        SUM('Securities Transaction Costs GA Fact'[Transaction Cost Local]),
				        'Securities Transaction Costs GA Fact'[Cost_Name]="Reverse Cash Settlement"
				)
			lineageTag: 92692ab6-97a0-4e97-8972-a737fd70ca80

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		measure 'Reverse Cash Settlement - Rep' = ```
				
				    SWITCH(
				    SELECTEDVALUE('Reporting Currency'[Rep In Currency]),
				    "SCD Base",
				    CALCULATE(
				        SUM('Securities Transaction Costs GA Fact'[Transaction Cost Base]),
				        'Securities Transaction Costs GA Fact'[Cost_Name]="Reverse Cash Settlement"
				    ),
				    CALCULATE(
				        SUMX (
				            'Securities Transaction Costs GA Fact',[Reverse Cash Settlement - Local] * [Rep Rate]
				        ),
				        USERELATIONSHIP('Fx Rate DQ'[FX Join Key],'Securities Transaction Costs GA Fact'[FX Join Key])
				    )
				)
				```
			lineageTag: f42b58f6-c1df-4de2-9c2b-c4829f82c523

			annotation PBI_FormatHint = {"isGeneralNumber":true}

