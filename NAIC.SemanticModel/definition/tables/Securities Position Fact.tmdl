table 'Securities Position Fact'
	lineageTag: edc4ab73-1a02-4c56-b34f-1b3c4aa30d0a
	sourceLineageTag: 3da8a732-fd5d-48f7-8975-8ac0112d39a7

	measure Adjustment = -([Final Sch DA BACV] + [Final Sch E2 BACV])
		lineageTag: 6fda7ffe-7ae3-457d-9f1d-469a1d569f23

	measure 'Final Sch DA BACV' = CALCULATE('Securities Position Fact'[Book Value - Local], filter(Securities, DATEDIFF(Securities[Issue Dt],Securities[Maturity Date], DAY) >= 90 && DATEDIFF(Securities[Issue Dt],Securities[Maturity Date], DAY) <=365 && Securities[Issue Dt] <> BLANK() && Securities[Maturity Date] <> BLANK()),'Securities Position Fact'[GL Class] = "MM" || 'Securities Position Fact'[GL Class] = "BOND")
		lineageTag: 178cc09f-ca6d-4cc3-b15e-0e6dadb41193

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Maturity Days From Purchase Date' = DATEDIFF([Issue Dt (Sec Pos)],[Maturity Date (Sec Pos)], DAY)
		formatString: 0
		lineageTag: 39ee7ce0-6bb2-4703-969d-e1da171f1db9

	measure 'Final Sch E2 BACV' = CALCULATE('Securities Position Fact'[Book Value - Local], filter(Securities, DATEDIFF(Securities[Issue Dt],Securities[Maturity Date], DAY) < 90 && Securities[Issue Dt] <> BLANK() && Securities[Maturity Date] <> BLANK()),'Securities Position Fact'[GL Class] = "MM" || 'Securities Position Fact'[GL Class] = "BOND")
		lineageTag: 82cd2995-adaf-4505-ad29-bcaec43fc98c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Final BACV' = 'Securities Position Fact'[Carrying Value - Local] + 'Securities Position Fact'[Adjustment]
		lineageTag: 79721227-46f9-4922-b7ff-c1a4387e65d3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Statement Value - STAT basis' = [Book Value - Local]
		lineageTag: 36651d2f-d8b3-42fb-acaa-84bc3a02bff3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Numeric/Alpha Des' = LEFT([NAIC Designation (Sec Pos)],3)
		lineageTag: 40c0478f-bf72-4bf3-84f0-0a692b91d227

	measure 'Final Sch DA BACV_USD' = CALCULATE(sum('Securities Position Fact'[Book Value - USD]), filter(Securities, DATEDIFF(Securities[Issue Dt],Securities[Maturity Date], DAY) >= 90 && DATEDIFF(Securities[Issue Dt],Securities[Maturity Date], DAY) <=365 && Securities[Issue Dt] <> BLANK() && Securities[Maturity Date] <> BLANK()),'Securities Position Fact'[GL Class] = "MM" || 'Securities Position Fact'[GL Class] = "BOND")
		lineageTag: 2c054102-3344-45c7-a5ac-61b8d0556551

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Final Sch E2 BACV_USD' = CALCULATE(sum('Securities Position Fact'[Book Value - USD]), filter(Securities, DATEDIFF(Securities[Issue Dt],Securities[Maturity Date], DAY) < 90 && Securities[Issue Dt] <> BLANK() && Securities[Maturity Date] <> BLANK()),'Securities Position Fact'[GL Class] = "MM" || 'Securities Position Fact'[GL Class] = "BOND")
		lineageTag: 32d825e2-9aa1-4979-9394-45206d504bde

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Adjustment_USD = -([Final Sch DA BACV_USD] + [Final Sch E2 BACV_USD])
		lineageTag: 9b25a123-8faa-4757-819f-d49ee6db7883

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Final BACV_USD' = sum('Securities Position Fact'[Carrying Value - USD]) + 'Securities Position Fact'[Adjustment_USD]
		lineageTag: 90e087c3-11b5-41d0-bcaf-b615ebaf7245

		annotation PBI_FormatHint = {"isGeneralNumber":true}

