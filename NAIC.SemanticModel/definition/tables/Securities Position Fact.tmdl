	measure 'Dup Final Sch DA BACV' = ```
			
			// VAR TradeDate = CALCULATE (
			//         MIN ( 'Securities Transaction GA Fact'[Trade Date] ),
			//         TREATAS (
			//             VALUES ( 'Securities Position Fact'[Src Position ID] ),
			//             'Securities Transaction GA Fact'[POS Trans Link]
			//         ),
			//         'Securities Transaction GA Fact'[Trans Status] = "Active",
			//         ALLSELECTED ( Securities[Primary Security ID] )
			//     )
			// VAR TradeDate = [DupTradeDateCalc]    
			// VAR MaturityDate = MAX(Securities[Maturity Date])
			// VAR DaystoMat = MaturityDate-TradeDate
			// RETURN
			// IF(NOT ISBLANK(TradeDate) && NOT ISBLANK(MaturityDate) && DaystoMat>=90 && DaystoMat<=365,CALCULATE([Book Value - Local],'Securities Position Fact'[GL Class] in {"MM" ,"BOND"}))
			// VAR TradeDate =
			//     CALCULATE (
			//         [DupTradeDateCalc],
			//         REMOVEFILTERS ( Securities )  
			//     )
			
			// VAR MaturityDate =
			//     MAX ( Securities[Maturity Date] )
			
			// VAR DaystoMat =
			//     MaturityDate - TradeDate
			
			// RETURN
			// IF (
			//     NOT ISBLANK ( TradeDate )
			//         && NOT ISBLANK ( MaturityDate )
			//         && DaystoMat >= 90
			//         && DaystoMat <= 365,
			//     CALCULATE (
			//         [Book Value - Local],
			//         KEEPFILTERS ( 'Securities Position Fact'[GL Class] IN { "MM", "BOND" } )
			//     )
			// )
			// RETURN MaturityDate>=90 && MaturityDate<=365
			// VAR Days90 = TradeDate+90
			// VAR Days365 = TradeDate+365
			// VAR isindatarange = not ISBLANK(MaturityDate) && MaturityDate>=Days90 && MaturityDate<=Days365
			// var maturitydates = filter(all(Securities[Maturity Date]), Securities[Maturity Date] <> BLANK() && Securities[Maturity Date]>=Days90 && Securities[Maturity Date]<=Days365)
			// VAR validGLKeys = CALCULATETABLE(VALUES('Securities Position Fact'[Security NK]),'Securities Position Fact'[GL Class] in {"MM" ,"BOND"})
			// RETURN
			// IF (NOT ISBLANK(TradeDate) && isindatarange, CALCULATE([Book Value - Local],'Securities Position Fact'[GL Class] in {"MM" ,"BOND"}))
			// // IF (NOT ISBLANK(TradeDate), CALCULATE([Book Value - Local],maturitydates,TREATAS(validGLKeys,Securities[Security NK])))
			
			// var a = [DupTradeDateCalc] 
			// var maturitydates = filter(all(Securities[Maturity Date]), not ISBLANK( Securities[Maturity Date]) && DATEDIFF(a,Securities[Maturity Date], DAY) >= 90 && DATEDIFF(a,Securities[Maturity Date], DAY) <=365 )
			// return 
			// if (not ISBLANK(a), CALCULATE([Book Value - Local],maturitydates,'Securities Position Fact'[GL Class] in {"MM" ,"BOND"}))
			// //  CALCULATE('Securities Position Fact'[Book Value - Local], filter(Securities, DATEDIFF(a,Securities[Maturity Date], DAY) >= 90 && DATEDIFF(a,Securities[Maturity Date], DAY) <=365 && Securities[Maturity Date] <> BLANK()),'Securities Position Fact'[GL Class] = "MM" || 'Securities Position Fact'[GL Class] = "BOND")
			CALCULATE (
			    [Book Value - Local],
			    'Securities Position Fact'[GL Class] IN { "MM", "BOND" },
			    FILTER (
			        ALL ( Securities ),
			        VAR TradeDate =
			            CALCULATE (
			                MIN ( 'Securities Transaction GA Fact'[Trade Date] ),
			                TREATAS (
			                    DISTINCT ( 'Securities Position Fact'[Src Position ID] ),
			                    'Securities Transaction GA Fact'[POS Trans Link]
			                ),
			
			                'Securities Transaction GA Fact'[Trans Status] = "Active"
			            )
			        VAR MaturityDate = Securities[Maturity Date]
			        VAR DaysToMat = MaturityDate - TradeDate
			        RETURN
			            NOT ISBLANK ( TradeDate )
			                && NOT ISBLANK ( MaturityDate )
			                && DaysToMat >= 90
			                && DaysToMat <= 365
			    )
			)
			
			```
		lineageTag: 201f13b3-4c0b-4342-bdf0-fb55b3b23ed2

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

